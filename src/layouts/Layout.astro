---
import '../styles/global.css';
const {
  title,
  description = 'Free developer tools for DevOps engineers and sysadmins.',
  canonicalURL = new URL(Astro.url.pathname, 'https://opsbash.com').href,
  ogTitle = title,
  ogDescription = description,
} = Astro.props;
const year = new Date().getFullYear();
const gaId = import.meta.env.PUBLIC_GA_ID;
const currentPath = Astro.url.pathname;

const isDropdownPage = ['/json-yaml-converter', '/chmod-calculator', '/gitignore-generator', '/docker-compose-converter'].includes(currentPath);
const isBlogPage = currentPath === '/blog' || currentPath.startsWith('/blog/');

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "OpsBash",
  "url": "https://opsbash.com",
  "logo": "https://opsbash.com/favicon-512x512.png",
  "description": "Free DevOps tools for engineers. Cron expression generator, CIDR calculator and more.",
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "contact@opsbash.com",
    "contactType": "customer support"
  },
  "sameAs": [
    "https://github.com/Rishmish94/opsbash-cron"
  ]
};
---

<!DOCTYPE html>
<html lang="en" class="dark scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="opsbash.com" />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:url" content={canonicalURL} />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={ogDescription} />
  <link rel="sitemap" href="/sitemap.xml" />
  <link rel="icon" href="/favicon.ico" sizes="48x48" />
  <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <!-- Fonts: Inter + JetBrains Mono only -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <slot name="head" />
  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5316820319132733" crossorigin="anonymous"></script>
  <!-- Google Analytics -->
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
  <script define:vars={{ gaId }} is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', gaId);
  </script>
</head>
<body class="antialiased" style="background:var(--bg-primary);">

  <!-- Command palette overlay -->
  <div id="cmd-overlay" role="dialog" aria-label="Command palette" aria-modal="true">
    <div id="cmd-modal">
      <div id="cmd-input-wrap">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             style="color:var(--text-secondary);flex-shrink:0;" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input id="cmd-search" type="text" placeholder="Search tools..." autocomplete="off" spellcheck="false" />
        <span id="cmd-esc-hint">ESC</span>
      </div>
      <div id="cmd-results" role="listbox"></div>
      <div id="cmd-footer">
        <span class="cmd-kbd"><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
        <span class="cmd-kbd"><kbd>↵</kbd> open</span>
        <span class="cmd-kbd"><kbd>/</kbd> open</span>
      </div>
    </div>
  </div>

  <!-- Mobile overlay backdrop -->
  <div id="mobile-overlay" aria-hidden="true"></div>

  <!-- Mobile slide-in menu -->
  <div id="mobileNav" role="dialog" aria-label="Navigation menu">
    <!-- Header row -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
      <div class="mobile-logo">
        <span class="logo-ops">OpsBash</span><span class="logo-com">.com</span>
        <span class="logo-badge">⚡ Free Tools</span>
      </div>
      <button id="mobileCloseBtn" aria-label="Close menu"
        style="width:32px;height:32px;display:flex;align-items:center;justify-content:center;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--text-secondary);cursor:pointer;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Categorized tool links -->
    {[
      { cat: 'Automation',  tools: [{ href: '/cron-builder',            label: 'Cron Builder'              }] },
      { cat: 'Networking',  tools: [{ href: '/cidr-calculator',         label: 'CIDR Calculator'           }] },
      { cat: 'Security',    tools: [{ href: '/jwt-decoder',             label: 'JWT Decoder'               }] },
      { cat: 'Development', tools: [
          { href: '/json-yaml-converter',      label: 'JSON to YAML Converter' },
          { href: '/gitignore-generator',      label: 'gitignore Generator'    },
        ]},
      { cat: 'Containers',  tools: [{ href: '/docker-compose-converter', label: 'Docker Run to Compose'    }] },
      { cat: 'Linux',       tools: [{ href: '/chmod-calculator',         label: 'chmod Calculator'          }] },
    ].map(({ cat, tools }) => (
      <div style="margin-bottom:16px;">
        <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-secondary);margin-bottom:4px;padding:0 2px;">{cat}</p>
        {tools.map(({ href, label }) => (
          <a href={href}
            style={'display:block;padding:9px 10px;text-decoration:none;font-size:13px;font-weight:500;border-radius:6px;margin-bottom:1px;transition:background 0.1s;color:' + (currentPath === href ? '#F8FAFC' : 'var(--text-primary)') + ';background:' + (currentPath === href ? 'rgba(248,250,252,0.08)' : 'transparent')}>
            {label}
          </a>
        ))}
      </div>
    ))}

    <!-- Blog link -->
    <div style="margin-bottom:16px;">
      <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-secondary);margin-bottom:4px;padding:0 2px;">Content</p>
      <a href="/blog"
        style={'display:block;padding:9px 10px;text-decoration:none;font-size:13px;font-weight:500;border-radius:6px;margin-bottom:1px;transition:background 0.1s;color:' + (isBlogPage ? '#F8FAFC' : 'var(--text-primary)') + ';background:' + (isBlogPage ? 'rgba(248,250,252,0.08)' : 'transparent')}>
        Blog
      </a>
    </div>

    <!-- Bottom actions -->
    <div style="margin-top:auto;padding-top:20px;border-top:1px solid var(--border);display:flex;flex-direction:column;gap:8px;">
      <a href="https://github.com/Rishmish94/opsbash-cron"
         target="_blank"
         rel="noopener noreferrer"
         style="display:inline-flex;align-items:center;gap:6px;color:#F8FAFC;text-decoration:none;">
        <svg width="20" height="20" viewBox="0 0 24 24"
             fill="currentColor">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
        GitHub
      </a>
      <a href="https://ko-fi.com/rishmish"
         target="_blank"
         rel="noopener noreferrer"
         class="kofi-btn"
         style="display:inline-flex;align-items:center;background:#F97316;color:#000000;font-weight:700;padding:8px 16px;border-radius:9999px;text-decoration:none;white-space:nowrap;">
        Buy me a Koffee
      </a>
    </div>
  </div>

  <!-- Page wrapper -->
  <div class="flex flex-col min-h-screen">

    <!-- ── NAV ── -->
    <header id="main-nav" class="fixed top-0 left-0 right-0 z-30">
      <div class="max-w-[1280px] mx-auto px-5 h-16 flex items-center justify-between gap-6">

        <!-- Wordmark -->
        <a href="/" class="logo-link">
          <span class="logo-text">
            <span class="logo-ops">OpsBash</span><span class="logo-com">.com</span>
          </span>
          <span class="logo-badge">⚡ Free Tools</span>
        </a>

        <!-- Center nav links -->
        <nav class="hidden md:flex items-center gap-6">
          <a href="/cron-builder" class={'nav-link' + (currentPath === '/cron-builder' ? ' nav-active' : '')}>Cron Builder</a>
          <a href="/cidr-calculator" class={'nav-link' + (currentPath === '/cidr-calculator' ? ' nav-active' : '')}>CIDR Calculator</a>
          <a href="/jwt-decoder" class={'nav-link' + (currentPath === '/jwt-decoder' ? ' nav-active' : '')}>JWT Decoder</a>

          <!-- All Tools dropdown -->
          <div class="dropdown-wrap" id="all-tools-dropdown">
            <button class={'nav-link' + (isDropdownPage ? ' nav-active' : '')} id="all-tools-trigger" aria-haspopup="true" aria-expanded="false">
              All Tools
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                   style="display:inline;margin-left:3px;vertical-align:middle;">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
            <div class="dropdown-menu">
              <span class="dropdown-category">Automation</span>
              <a href="/cron-builder" class="dropdown-item">Cron Builder</a>

              <span class="dropdown-category">Networking</span>
              <a href="/cidr-calculator" class="dropdown-item">CIDR Calculator</a>

              <span class="dropdown-category">Security</span>
              <a href="/jwt-decoder" class="dropdown-item">JWT Decoder</a>

              <span class="dropdown-category">Development</span>
              <a href="/json-yaml-converter" class="dropdown-item">JSON to YAML Converter</a>
              <a href="/gitignore-generator" class="dropdown-item">gitignore Generator</a>

              <span class="dropdown-category">Containers</span>
              <a href="/docker-compose-converter" class="dropdown-item">Docker Run to Compose</a>

              <span class="dropdown-category">Linux</span>
              <a href="/chmod-calculator" class="dropdown-item">chmod Calculator</a>
            </div>
          </div>

          <a href="/blog" class={'nav-link' + (isBlogPage ? ' nav-active' : '')}>Blog</a>
        </nav>

        <!-- Right side -->
        <div class="flex items-center gap-3">
          <!-- GitHub star (ghost button) -->
          <a href="https://github.com/Rishmish94/opsbash-cron"
             target="_blank"
             rel="noopener noreferrer"
             class="github-btn"
             title="Star on GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24"
                 fill="currentColor">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </a>

          <!-- Ko-fi orange button -->
          <a href="https://ko-fi.com/rishmish" target="_blank" rel="noopener noreferrer"
            class="hidden md:inline-flex items-center kofi-btn">
            <img src="/logos/coffee.svg" alt="coffee" width="16" height="16"
                 style="display:inline-block;vertical-align:middle;margin-right:6px;">
            Buy me a Koffee
          </a>

          <!-- Mobile hamburger -->
          <button id="mobileMenuBtn"
            class="flex items-center justify-center w-8 h-8 rounded-lg border transition-colors"
            style="border-color:var(--border);color:var(--text-secondary);background:transparent;cursor:pointer;"
            aria-label="Open menu">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Push content below fixed nav -->
    <div style="height:64px;" aria-hidden="true"></div>

    <slot />

    <!-- ── FOOTER ── -->
    <footer style="background:var(--bg-primary);border-top:1px solid var(--border);margin-top:auto;">
      <div class="max-w-[1280px] mx-auto px-5 py-12">

        <!-- Three columns -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-8 md:gap-12 mb-10">

          <!-- Tools -->
          <div>
            <p style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-secondary);margin-bottom:14px;">Tools</p>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px;">
              <li><a href="/cron-builder"              class="footer-link" style="font-size:13px;">Cron Builder</a></li>
              <li><a href="/cidr-calculator"           class="footer-link" style="font-size:13px;">CIDR Calculator</a></li>
              <li><a href="/jwt-decoder"               class="footer-link" style="font-size:13px;">JWT Decoder</a></li>
              <li><a href="/json-yaml-converter"       class="footer-link" style="font-size:13px;">JSON to YAML</a></li>
              <li><a href="/chmod-calculator"          class="footer-link" style="font-size:13px;">chmod Calculator</a></li>
              <li><a href="/gitignore-generator"       class="footer-link" style="font-size:13px;">gitignore Generator</a></li>
              <li><a href="/docker-compose-converter"  class="footer-link" style="font-size:13px;">Docker Compose</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <p style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-secondary);margin-bottom:14px;">Legal</p>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px;">
              <li><a href="/privacy-policy" class="footer-link" style="font-size:13px;">Privacy Policy</a></li>
              <li><a href="/terms"          class="footer-link" style="font-size:13px;">Terms</a></li>
              <li><a href="/about"          class="footer-link" style="font-size:13px;">About</a></li>
              <li><a href="/contact"        class="footer-link" style="font-size:13px;">Contact</a></li>
            </ul>
          </div>

          <!-- Connect -->
          <div class="col-span-2 md:col-span-1">
            <p style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-secondary);margin-bottom:14px;">Connect</p>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px;">
              <li>
                <a href="https://www.linkedin.com/in/rishmish94/" target="_blank" rel="noopener noreferrer"
                   class="footer-link" style="font-size:13px;">LinkedIn</a>
              </li>
              <li>
                <a href="https://ko-fi.com/rishmish" target="_blank" rel="noopener noreferrer"
                   class="footer-link" style="font-size:13px;">Ko-fi</a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Bottom bar -->
        <div style="border-top:1px solid var(--border);padding-top:20px;">
          <p style="font-size:12px;color:var(--text-secondary);">© {year} OpsBash. Built for engineers. All tools run client-side.</p>
        </div>
      </div>
    </footer>

  </div><!-- /page wrapper -->

  <script is:inline>
  (function () {

    // ── Nav solid on scroll ────────────────────────────────────────────────────
    var nav = document.getElementById('main-nav');
    function syncNav() {
      if (!nav) return;
      if (window.scrollY > 20) nav.classList.add('nav-scrolled');
      else                     nav.classList.remove('nav-scrolled');
    }
    window.addEventListener('scroll', syncNav, { passive: true });
    syncNav();

    // ── GitHub star count ──────────────────────────────────────────────────────
    var starLabel = document.getElementById('gh-star-label');
    if (starLabel) {
      fetch('https://api.github.com/repos/Rishmish94/opsbash-cron')
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (d) {
          if (d && typeof d.stargazers_count === 'number' && d.stargazers_count > 0) {
            starLabel.textContent = '★ ' + d.stargazers_count;
          }
        })
        .catch(function () {});
    }

    // ── All Tools dropdown click toggle ────────────────────────────────────────
    var allToolsTrigger  = document.getElementById('all-tools-trigger');
    var allToolsDropdown = document.getElementById('all-tools-dropdown');
    if (allToolsTrigger && allToolsDropdown) {
      allToolsTrigger.addEventListener('click', function (e) {
        e.stopPropagation();
        var open = allToolsDropdown.classList.toggle('open');
        allToolsTrigger.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      document.addEventListener('click', function (e) {
        if (allToolsDropdown && !allToolsDropdown.contains(e.target)) {
          allToolsDropdown.classList.remove('open');
          if (allToolsTrigger) allToolsTrigger.setAttribute('aria-expanded', 'false');
        }
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          allToolsDropdown.classList.remove('open');
          if (allToolsTrigger) allToolsTrigger.setAttribute('aria-expanded', 'false');
        }
      });
    }

    // ── Mobile menu ────────────────────────────────────────────────────────────
    var mobileMenuBtn  = document.getElementById('mobileMenuBtn');
    var mobileCloseBtn = document.getElementById('mobileCloseBtn');
    var mobileNav      = document.getElementById('mobileNav');
    var overlay        = document.getElementById('mobile-overlay');

    function openMenu()  {
      if (mobileNav) mobileNav.classList.add('open');
      if (overlay)   overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      if (mobileNav) mobileNav.classList.remove('open');
      if (overlay)   overlay.classList.remove('open');
      document.body.style.overflow = '';
    }
    if (mobileMenuBtn)  mobileMenuBtn.addEventListener('click', openMenu);
    if (mobileCloseBtn) mobileCloseBtn.addEventListener('click', closeMenu);
    if (overlay)        overlay.addEventListener('click', closeMenu);

    // ── Command palette ────────────────────────────────────────────────────────
    var TOOLS = [
      { name:'Cron Expression Generator', desc:'Build and validate cron expressions for Linux, AWS, GitHub Actions and Kubernetes', url:'/cron-builder', cat:'Automation',
        icon:'<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' },
      { name:'CIDR Calculator', desc:'Calculate subnet masks, usable hosts and network ranges for IPv4 and IPv6', url:'/cidr-calculator', cat:'Networking',
        icon:'<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>' },
      { name:'JWT Decoder', desc:'Decode JWT tokens and inspect header, payload and expiry status instantly', url:'/jwt-decoder', cat:'Security',
        icon:'<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>' },
      { name:'JSON to YAML Converter', desc:'Convert between JSON and YAML formats in real time with bidirectional support', url:'/json-yaml-converter', cat:'Dev',
        icon:'<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>' },
      { name:'chmod Calculator', desc:'Calculate Linux file permissions between octal, symbolic and visual formats', url:'/chmod-calculator', cat:'Linux',
        icon:'<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>' },
      { name:'gitignore Generator', desc:'Generate .gitignore files for any technology stack with one click download', url:'/gitignore-generator', cat:'Dev',
        icon:'<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/>' },
      { name:'Docker Compose Converter', desc:'Convert docker run commands to docker-compose.yml and back', url:'/docker-compose-converter', cat:'Containers',
        icon:'<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>' }
    ];

    var cmdOverlay = document.getElementById('cmd-overlay');
    var cmdSearch  = document.getElementById('cmd-search');
    var cmdResults = document.getElementById('cmd-results');
    var idx = -1;

    function icon(paths) {
      return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">' + paths + '</svg>';
    }

    function render(list) {
      idx = -1;
      if (!list.length) {
        cmdResults.innerHTML = '<div id="cmd-empty">No tools match.</div>';
        return;
      }
      cmdResults.innerHTML = list.map(function (t, i) {
        return '<a href="' + t.url + '" class="cmd-item" role="option" data-i="' + i + '">' +
          '<div class="cmd-item-icon">' + icon(t.icon) + '</div>' +
          '<div class="cmd-item-info"><div class="cmd-item-name">' + t.name + '</div>' +
          '<div class="cmd-item-desc">' + t.desc + '</div></div>' +
          '<span class="cmd-item-tag">' + t.cat + '</span></a>';
      }).join('');
    }

    function openCmd() {
      if (!cmdOverlay) return;
      cmdOverlay.classList.add('open');
      document.body.style.overflow = 'hidden';
      if (cmdSearch) { cmdSearch.value = ''; cmdSearch.focus(); }
      render(TOOLS);
    }
    function closeCmd() {
      if (!cmdOverlay) return;
      cmdOverlay.classList.remove('open');
      document.body.style.overflow = '';
      idx = -1;
    }

    document.addEventListener('keydown', function (e) {
      var tag  = document.activeElement ? document.activeElement.tagName : '';
      var busy = tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';
      if (e.key === '/' && !busy && cmdOverlay && !cmdOverlay.classList.contains('open')) {
        e.preventDefault(); openCmd(); return;
      }
      if (!cmdOverlay || !cmdOverlay.classList.contains('open')) return;
      var items = cmdResults.querySelectorAll('.cmd-item');
      if (e.key === 'Escape') { closeCmd(); }
      else if (e.key === 'ArrowDown') {
        e.preventDefault();
        idx = Math.min(idx + 1, items.length - 1);
        items.forEach(function (el, i) { el.classList.toggle('cmd-active', i === idx); });
        if (items[idx]) items[idx].scrollIntoView({ block: 'nearest' });
      }
      else if (e.key === 'ArrowUp') {
        e.preventDefault();
        idx = Math.max(idx - 1, 0);
        items.forEach(function (el, i) { el.classList.toggle('cmd-active', i === idx); });
        if (items[idx]) items[idx].scrollIntoView({ block: 'nearest' });
      }
      else if (e.key === 'Enter' && idx >= 0 && items[idx]) {
        e.preventDefault();
        window.location.href = items[idx].getAttribute('href');
      }
    });

    if (cmdSearch) {
      cmdSearch.addEventListener('input', function () {
        var q = this.value.toLowerCase().trim();
        render(!q ? TOOLS : TOOLS.filter(function (t) {
          return t.name.toLowerCase().indexOf(q) !== -1 ||
                 t.desc.toLowerCase().indexOf(q) !== -1 ||
                 t.cat.toLowerCase().indexOf(q) !== -1;
        }));
      });
    }
    if (cmdOverlay) {
      cmdOverlay.addEventListener('click', function (e) { if (e.target === cmdOverlay) closeCmd(); });
    }
    window.__openCmdPalette = openCmd;

    // ── Scroll reveal ──────────────────────────────────────────────────────────
    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(function (el) { obs.observe(el); });
    } else {
      document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('visible'); });
    }

  })();
  </script>



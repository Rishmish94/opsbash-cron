---
// src/components/NewsletterSignup.astro
---

<div class="bg-gradient-to-r from-blue-500/10 to-purple-500/10 border border-blue-500/20 rounded-lg p-6 my-8">
  <h3 class="text-xl font-bold text-white mb-2">
    Get DevOps tips in your inbox
  </h3>
  <p class="text-gray-400 mb-4 text-sm">
    New tools, tutorials, and guides. No spam. Unsubscribe anytime.
  </p>
  <form
    action="https://buttondown.com/api/emails/embed-subscribe/opsbash"
    method="post"
    target="popupwindow"
    onsubmit="window.open('https://buttondown.com/opsbash', 'popupwindow')"
    class="flex flex-col sm:flex-row gap-2"
  >
    <label for="email" class="sr-only">Email address</label>
    <input
      type="email"
      name="email"
      id="email"
      placeholder="your@email.com"
      required
      class="flex-1 bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-500 focus:outline-none focus:border-blue-500 text-sm"
    />
    <button
      type="submit"
      class="bg-blue-500 hover:bg-blue-600 text-white font-bold px-6 py-2.5 rounded-lg transition text-sm whitespace-nowrap"
    >
      Subscribe
    </button>
  </form>
  <p class="text-gray-600 text-xs mt-2">Join DevOps engineers. First issue soon.</p>
</div>

---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does chmod 644 mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "chmod 644 gives the owner read and write permissions while group members and everyone else can only read the file. In symbolic notation this is rw-r--r--. This is the standard permission for regular files like configuration files, HTML files, and documents that should be readable by everyone but only editable by the owner. It is the most commonly used permission set for web server files."
      }
    },
    {
      "@type": "Question",
      "name": "What does chmod 755 mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "chmod 755 gives the owner full read, write and execute permissions while group members and everyone else can read and execute the file but not write to it. In symbolic notation this is rwxr-xr-x. This is the standard permission for executable files and directories that should be publicly accessible but only modifiable by the owner. Web server directories typically use 755."
      }
    },
    {
      "@type": "Question",
      "name": "How do you calculate chmod permissions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Each permission digit represents three binary bits for read, write and execute. Read is worth 4, write is worth 2, and execute is worth 1. You add these values together for each group. So 7 means all three permissions, 6 means read and write, 5 means read and execute, and 4 means read only. A chmod calculator makes this instant by letting you tick checkboxes and showing the number automatically."
      }
    },
    {
      "@type": "Question",
      "name": "What does chmod mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "chmod stands for change mode. It is a Linux and Unix command used to change the access permissions of files and directories. Every file on a Linux system has permissions controlling who can read it, write to it, or execute it. You specify permissions either as an octal number like 755 or as symbolic notation like rwxr-xr-x."
      }
    },
    {
      "@type": "Question",
      "name": "What is the execute permission used for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The execute permission on a file means the system is allowed to run it as a program or script. On a directory, execute permission means the user is allowed to enter the directory and access its contents. Without execute permission on a directory you cannot cd into it even if you can see it listed with ls."
      }
    },
    {
      "@type": "Question",
      "name": "Is chmod 777 safe to use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "chmod 777 gives every user on the system full read, write and execute permissions. This is almost never appropriate on a production server because it allows any user or process to modify or execute the file. It is occasionally useful for temporary debugging but should never be left on sensitive files or directories in a live environment."
      }
    }
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "chmod Calculator",
  "url": "https://opsbash.com/chmod-calculator",
  "description": "Calculate Linux file permissions instantly. Convert between octal, symbolic and chmod command formats. Free online chmod calculator with visual permission builder.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<Layout
  title="chmod Calculator | OpsBash"
  description="Calculate Linux file permissions instantly. Convert between octal, symbolic and chmod command formats. Free online chmod calculator with visual permission builder."
  canonicalURL="https://opsbash.com/chmod-calculator"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />

<div style="background: var(--bg);">
<div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">

  <!-- ── HERO ──────────────────────────────────────────────────────────────── -->
  <section class="pt-12 pb-10 text-center animate-fade-in-up">
    <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold mb-6"
         style="background: #1A1A1A; color: #F8FAFC; border: 1px solid #334155;">
      ⚡ Free Online Tool
    </div>
    <h1 class="font-black tracking-tight mb-4 leading-tight"
        style="font-size: clamp(1.8rem, 4vw, 2.75rem); letter-spacing: -0.03em; color: #F8FAFC; background: none; -webkit-text-fill-color: #F8FAFC;">
      chmod Calculator – Unix File Permission Calculator
    </h1>
    <p class="text-base max-w-2xl mx-auto leading-relaxed" style="color: var(--fg2);">
      Build Linux file permissions visually. Click the permission cards to toggle them or type an octal value for instant reverse lookup. Runs entirely in your browser.
    </p>
  </section>

  <!-- ── TOOL ──────────────────────────────────────────────────────────────── -->
  <section class="pb-16">

    <!-- Presets -->
    <div class="mb-5">
      <p class="text-[10px] font-semibold uppercase tracking-wider mb-3" style="color: var(--fg3);">Common Presets</p>
      <div class="flex flex-wrap gap-2">
        <button class="preset-btn rounded-xl px-3 py-2.5 text-left transition-all"
                style="background: var(--card); border: 1px solid var(--border);" data-octal="755">
          <div class="font-mono text-sm font-bold" style="color: #F8FAFC;">755</div>
          <div class="text-[10px] mt-0.5" style="color: var(--fg3);">Standard executable</div>
        </button>
        <button class="preset-btn rounded-xl px-3 py-2.5 text-left transition-all"
                style="background: var(--card); border: 1px solid var(--border);" data-octal="644">
          <div class="font-mono text-sm font-bold" style="color: #F8FAFC;">644</div>
          <div class="text-[10px] mt-0.5" style="color: var(--fg3);">Standard file</div>
        </button>
        <button class="preset-btn rounded-xl px-3 py-2.5 text-left transition-all"
                style="background: var(--card); border: 1px solid var(--border);" data-octal="777">
          <div class="font-mono text-sm font-bold" style="color: #F8FAFC;">777</div>
          <div class="text-[10px] mt-0.5" style="color: var(--fg3);">Full permissions</div>
        </button>
        <button class="preset-btn rounded-xl px-3 py-2.5 text-left transition-all"
                style="background: var(--card); border: 1px solid var(--border);" data-octal="700">
          <div class="font-mono text-sm font-bold" style="color: #F8FAFC;">700</div>
          <div class="text-[10px] mt-0.5" style="color: var(--fg3);">Private executable</div>
        </button>
        <button class="preset-btn rounded-xl px-3 py-2.5 text-left transition-all"
                style="background: var(--card); border: 1px solid var(--border);" data-octal="600">
          <div class="font-mono text-sm font-bold" style="color: #F8FAFC;">600</div>
          <div class="text-[10px] mt-0.5" style="color: var(--fg3);">Private file</div>
        </button>
        <button class="preset-btn rounded-xl px-3 py-2.5 text-left transition-all"
                style="background: var(--card); border: 1px solid var(--border);" data-octal="400">
          <div class="font-mono text-sm font-bold" style="color: #F8FAFC;">400</div>
          <div class="text-[10px] mt-0.5" style="color: var(--fg3);">Read only</div>
        </button>
        <button class="preset-btn rounded-xl px-3 py-2.5 text-left transition-all"
                style="background: var(--card); border: 1px solid var(--border);" data-octal="664">
          <div class="font-mono text-sm font-bold" style="color: #F8FAFC;">664</div>
          <div class="text-[10px] mt-0.5" style="color: var(--fg3);">Group writable</div>
        </button>
        <button class="preset-btn rounded-xl px-3 py-2.5 text-left transition-all"
                style="background: var(--card); border: 1px solid var(--border);" data-octal="775">
          <div class="font-mono text-sm font-bold" style="color: #F8FAFC;">775</div>
          <div class="text-[10px] mt-0.5" style="color: var(--fg3);">Group executable</div>
        </button>
      </div>
    </div>

    <!-- Output panel -->
    <div class="rounded-2xl p-5 sm:p-6 mb-4" style="background: var(--card); border: 1px solid var(--border);">
      <!-- Filename -->
      <div class="mb-5">
        <label for="filenameInput" class="block text-[10px] font-semibold uppercase tracking-wider mb-2" style="color: var(--fg3);">Filename</label>
        <input id="filenameInput" type="text" value="filename" spellcheck="false" autocomplete="off"
          class="rounded-xl px-4 py-2.5 w-full max-w-xs focus:outline-none transition-all"
          style="font-family: 'Fira Code', monospace; font-size: 0.875rem; color: var(--fg); background: var(--bg); border: 1px solid var(--border);" />
      </div>
      <!-- Outputs row -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">

        <!-- Octal -->
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-wider mb-2" style="color: var(--fg3);">Octal notation</p>
          <input id="octalInput" type="text" value="755" maxlength="3" spellcheck="false"
            autocomplete="off" inputmode="numeric"
            class="w-full rounded-xl px-4 py-3 focus:outline-none transition-all text-center"
            style="font-family: 'Fira Code', monospace; font-size: 1.75rem; font-weight: 800; letter-spacing: 0.18em; color: #F8FAFC; background: var(--bg); border: 1px solid var(--border);" />
          <p class="mt-1.5 text-[10px]" style="color: var(--fg3);">Type a value to reverse lookup</p>
        </div>

        <!-- Symbolic -->
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-wider mb-2" style="color: var(--fg3);">Symbolic notation</p>
          <input id="symbolicInput" type="text" value="rwxr-xr-x" maxlength="9" spellcheck="false"
            autocomplete="off"
            class="w-full rounded-xl px-4 py-3 focus:outline-none transition-all text-center"
            style="font-family: 'Fira Code', monospace; font-size: 1.1rem; font-weight: 600; letter-spacing: 0.06em; color: #F8FAFC; background: var(--bg); border: 1px solid var(--border);" />
          <p class="mt-1.5 text-[10px]" style="color: var(--fg3);">Type a value to reverse lookup</p>
        </div>

        <!-- chmod command -->
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-wider mb-2" style="color: var(--fg3);">chmod command</p>
          <div class="flex items-stretch gap-2">
            <code id="chmodCmd"
              class="flex-1 rounded-xl px-4 py-3 text-sm font-semibold block truncate"
              style="font-family: 'Fira Code', monospace; color: #F8FAFC; background: var(--bg); border: 1px solid var(--border); line-height: 1.75rem;">
              chmod 755 filename
            </code>
            <button id="copyBtn"
              class="flex items-center gap-1.5 px-3 rounded-xl text-xs font-medium transition-all shrink-0"
              style="background: transparent; color: #F8FAFC; border: 1px solid #334155;">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              <span id="copyBtnText">Copy</span>
            </button>
          </div>
        </div>

      </div>
    </div>

    <!-- Permission grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

      <!-- Owner -->
      <div class="rounded-2xl p-5" style="background: var(--card); border: 1px solid var(--border);">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h2 class="text-base font-semibold" style="color: var(--fg);">Owner</h2>
            <p class="text-xs" style="color: var(--fg3);">u (user)</p>
          </div>
          <div class="text-center leading-none">
            <div id="digit-o" class="text-3xl font-black font-mono" style="color: #F8FAFC;">7</div>
            <div class="text-[9px] uppercase tracking-wider mt-1" style="color: var(--fg3);">octal</div>
          </div>
        </div>
        <div class="grid grid-cols-3 gap-2">
          <div id="card-or" class="perm-card rounded-xl p-3 text-center cursor-pointer select-none transition-all"
               style="background: #1A1A1A; border: 1px solid #334155;">
            <div class="text-xl font-black font-mono mb-0.5 perm-letter" style="color: #F8FAFC;">r</div>
            <div class="text-[10px] font-semibold perm-name" style="color: #F8FAFC;">Read</div>
            <div class="text-[9px] mt-0.5 perm-value" style="color: #F8FAFC;">4</div>
          </div>
          <div id="card-ow" class="perm-card rounded-xl p-3 text-center cursor-pointer select-none transition-all"
               style="background: #1A1A1A; border: 1px solid #334155;">
            <div class="text-xl font-black font-mono mb-0.5 perm-letter" style="color: #F8FAFC;">w</div>
            <div class="text-[10px] font-semibold perm-name" style="color: #F8FAFC;">Write</div>
            <div class="text-[9px] mt-0.5 perm-value" style="color: #F8FAFC;">2</div>
          </div>
          <div id="card-ox" class="perm-card rounded-xl p-3 text-center cursor-pointer select-none transition-all"
               style="background: #1A1A1A; border: 1px solid #334155;">
            <div class="text-xl font-black font-mono mb-0.5 perm-letter" style="color: #F8FAFC;">x</div>
            <div class="text-[10px] font-semibold perm-name" style="color: #F8FAFC;">Execute</div>
            <div class="text-[9px] mt-0.5 perm-value" style="color: #F8FAFC;">1</div>
          </div>
        </div>
      </div>

      <!-- Group -->
      <div class="rounded-2xl p-5" style="background: var(--card); border: 1px solid var(--border);">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h2 class="text-base font-semibold" style="color: var(--fg);">Group</h2>
            <p class="text-xs" style="color: var(--fg3);">g</p>
          </div>
          <div class="text-center leading-none">
            <div id="digit-g" class="text-3xl font-black font-mono" style="color: #F8FAFC;">5</div>
            <div class="text-[9px] uppercase tracking-wider mt-1" style="color: var(--fg3);">octal</div>
          </div>
        </div>
        <div class="grid grid-cols-3 gap-2">
          <div id="card-gr" class="perm-card rounded-xl p-3 text-center cursor-pointer select-none transition-all"
               style="background: #1A1A1A; border: 1px solid #334155;">
            <div class="text-xl font-black font-mono mb-0.5 perm-letter" style="color: #F8FAFC;">r</div>
            <div class="text-[10px] font-semibold perm-name" style="color: #F8FAFC;">Read</div>
            <div class="text-[9px] mt-0.5 perm-value" style="color: #F8FAFC;">4</div>
          </div>
          <div id="card-gw" class="perm-card rounded-xl p-3 text-center cursor-pointer select-none transition-all"
               style="background: var(--card); border: 1px solid var(--border);">
            <div class="text-xl font-black font-mono mb-0.5 perm-letter" style="color: var(--fg3);">w</div>
            <div class="text-[10px] font-semibold perm-name" style="color: var(--fg3);">Write</div>
            <div class="text-[9px] mt-0.5 perm-value" style="color: var(--fg3);">2</div>
          </div>
          <div id="card-gx" class="perm-card rounded-xl p-3 text-center cursor-pointer select-none transition-all"
               style="background: #1A1A1A; border: 1px solid #334155;">
            <div class="text-xl font-black font-mono mb-0.5 perm-letter" style="color: #F8FAFC;">x</div>
            <div class="text-[10px] font-semibold perm-name" style="color: #F8FAFC;">Execute</div>
            <div class="text-[9px] mt-0.5 perm-value" style="color: #F8FAFC;">1</div>
          </div>
        </div>
      </div>

      <!-- Others -->
      <div class="rounded-2xl p-5" style="background: var(--card); border: 1px solid var(--border);">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h2 class="text-base font-semibold" style="color: var(--fg);">Others</h2>
            <p class="text-xs" style="color: var(--fg3);">o</p>
          </div>
          <div class="text-center leading-none">
            <div id="digit-t" class="text-3xl font-black font-mono" style="color: #F8FAFC;">5</div>
            <div class="text-[9px] uppercase tracking-wider mt-1" style="color: var(--fg3);">octal</div>
          </div>
        </div>
        <div class="grid grid-cols-3 gap-2">
          <div id="card-tr" class="perm-card rounded-xl p-3 text-center cursor-pointer select-none transition-all"
               style="background: #1A1A1A; border: 1px solid #334155;">
            <div class="text-xl font-black font-mono mb-0.5 perm-letter" style="color: #F8FAFC;">r</div>
            <div class="text-[10px] font-semibold perm-name" style="color: #F8FAFC;">Read</div>
            <div class="text-[9px] mt-0.5 perm-value" style="color: #F8FAFC;">4</div>
          </div>
          <div id="card-tw" class="perm-card rounded-xl p-3 text-center cursor-pointer select-none transition-all"
               style="background: var(--card); border: 1px solid var(--border);">
            <div class="text-xl font-black font-mono mb-0.5 perm-letter" style="color: var(--fg3);">w</div>
            <div class="text-[10px] font-semibold perm-name" style="color: var(--fg3);">Write</div>
            <div class="text-[9px] mt-0.5 perm-value" style="color: var(--fg3);">2</div>
          </div>
          <div id="card-tx" class="perm-card rounded-xl p-3 text-center cursor-pointer select-none transition-all"
               style="background: #1A1A1A; border: 1px solid #334155;">
            <div class="text-xl font-black font-mono mb-0.5 perm-letter" style="color: #F8FAFC;">x</div>
            <div class="text-[10px] font-semibold perm-name" style="color: #F8FAFC;">Execute</div>
            <div class="text-[9px] mt-0.5 perm-value" style="color: #F8FAFC;">1</div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── PERMISSION MATRIX ─────────────────────────────────────────────────── -->
  <section class="pb-16 reveal">
    <div class="rounded-2xl overflow-hidden" style="background: var(--card); border: 1px solid var(--border);">
      <div class="px-5 py-3.5" style="border-bottom: 1px solid var(--border);">
        <p class="text-xs font-semibold uppercase tracking-wider" style="color: var(--fg3);">Permission Matrix</p>
      </div>
      <div class="p-5 overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr>
              <th class="text-left text-[10px] font-semibold uppercase tracking-wider pb-3 pr-6" style="color: var(--fg3);">Permission</th>
              <th class="text-left text-[10px] font-semibold uppercase tracking-wider pb-3 pr-6" style="color: var(--fg3);">What it allows</th>
              <th class="text-center text-[10px] font-semibold uppercase tracking-wider pb-3 px-4" style="color: var(--fg3);">Owner</th>
              <th class="text-center text-[10px] font-semibold uppercase tracking-wider pb-3 px-4" style="color: var(--fg3);">Group</th>
              <th class="text-center text-[10px] font-semibold uppercase tracking-wider pb-3 px-4" style="color: var(--fg3);">Others</th>
            </tr>
          </thead>
          <tbody class="divide-y" style="border-color: var(--border);">
            <tr>
              <td class="py-3 pr-6 text-sm font-semibold" style="color: var(--fg); font-family: 'Fira Code', monospace;">r</td>
              <td class="py-3 pr-6 text-sm" style="color: var(--fg2);">View file or directory contents</td>
              <td class="py-3 px-4 text-center"><span id="mat-or" class="text-sm font-bold font-mono" style="color: #F8FAFC;">r</span></td>
              <td class="py-3 px-4 text-center"><span id="mat-gr" class="text-sm font-bold font-mono" style="color: #F8FAFC;">r</span></td>
              <td class="py-3 px-4 text-center"><span id="mat-tr" class="text-sm font-bold font-mono" style="color: #F8FAFC;">r</span></td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-sm font-semibold" style="color: var(--fg); font-family: 'Fira Code', monospace;">w</td>
              <td class="py-3 pr-6 text-sm" style="color: var(--fg2);">Create, edit or delete the file</td>
              <td class="py-3 px-4 text-center"><span id="mat-ow" class="text-sm font-bold font-mono" style="color: #F8FAFC;">w</span></td>
              <td class="py-3 px-4 text-center"><span id="mat-gw" class="text-sm font-bold font-mono" style="color: var(--fg3);">-</span></td>
              <td class="py-3 px-4 text-center"><span id="mat-tw" class="text-sm font-bold font-mono" style="color: var(--fg3);">-</span></td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-sm font-semibold" style="color: var(--fg); font-family: 'Fira Code', monospace;">x</td>
              <td class="py-3 pr-6 text-sm" style="color: var(--fg2);">Run as program or enter directory</td>
              <td class="py-3 px-4 text-center"><span id="mat-ox" class="text-sm font-bold font-mono" style="color: #F8FAFC;">x</span></td>
              <td class="py-3 px-4 text-center"><span id="mat-gx" class="text-sm font-bold font-mono" style="color: #F8FAFC;">x</span></td>
              <td class="py-3 px-4 text-center"><span id="mat-tx" class="text-sm font-bold font-mono" style="color: #F8FAFC;">x</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────────────────── -->
  <section class="pb-16 max-w-3xl mx-auto reveal">
    <h2 class="text-xl font-bold mb-8 text-center" style="color: var(--fg);">Frequently Asked Questions</h2>
    <div class="space-y-2">

      <div class="faq-item rounded-xl overflow-hidden" style="border: 1px solid var(--border);">
        <button class="faq-q w-full flex items-center justify-between gap-4 px-5 py-4 text-left text-sm font-medium"
                style="background: var(--card); color: var(--fg);">
          What does chmod 644 mean?
          <svg class="faq-chevron w-4 h-4 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="faq-a hidden px-5 pb-5 pt-2 text-sm leading-relaxed" style="background: var(--card); color: var(--fg2);">
          chmod 644 gives the owner read and write permissions while group members and everyone else can only read the file. In symbolic notation this is rw-r--r--. This is the standard permission for regular files like configuration files, HTML files, and documents that should be readable by everyone but only editable by the owner. It is the most commonly used permission set for web server files.
        </div>
      </div>

      <div class="faq-item rounded-xl overflow-hidden" style="border: 1px solid var(--border);">
        <button class="faq-q w-full flex items-center justify-between gap-4 px-5 py-4 text-left text-sm font-medium"
                style="background: var(--card); color: var(--fg);">
          What does chmod 755 mean?
          <svg class="faq-chevron w-4 h-4 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="faq-a hidden px-5 pb-5 pt-2 text-sm leading-relaxed" style="background: var(--card); color: var(--fg2);">
          chmod 755 gives the owner full read, write and execute permissions while group members and everyone else can read and execute the file but not write to it. In symbolic notation this is rwxr-xr-x. This is the standard permission for executable files and directories that should be publicly accessible but only modifiable by the owner. Web server directories typically use 755.
        </div>
      </div>

      <div class="faq-item rounded-xl overflow-hidden" style="border: 1px solid var(--border);">
        <button class="faq-q w-full flex items-center justify-between gap-4 px-5 py-4 text-left text-sm font-medium"
                style="background: var(--card); color: var(--fg);">
          How do you calculate chmod permissions?
          <svg class="faq-chevron w-4 h-4 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="faq-a hidden px-5 pb-5 pt-2 text-sm leading-relaxed" style="background: var(--card); color: var(--fg2);">
          Each permission digit represents three binary bits for read, write and execute. Read is worth 4, write is worth 2, and execute is worth 1. You add these values together for each group. So 7 means all three permissions, 6 means read and write, 5 means read and execute, and 4 means read only. A chmod calculator makes this instant by letting you tick checkboxes and showing the number automatically.
        </div>
      </div>

      <div class="faq-item rounded-xl overflow-hidden" style="border: 1px solid var(--border);">
        <button class="faq-q w-full flex items-center justify-between gap-4 px-5 py-4 text-left text-sm font-medium"
                style="background: var(--card); color: var(--fg);">
          What does chmod mean?
          <svg class="faq-chevron w-4 h-4 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="faq-a hidden px-5 pb-5 pt-2 text-sm leading-relaxed" style="background: var(--card); color: var(--fg2);">
          chmod stands for change mode. It is a Linux and Unix command used to change the access permissions of files and directories. Every file on a Linux system has permissions controlling who can read it, write to it, or execute it. You specify permissions either as an octal number like 755 or as symbolic notation like rwxr-xr-x.
        </div>
      </div>

      <div class="faq-item rounded-xl overflow-hidden" style="border: 1px solid var(--border);">
        <button class="faq-q w-full flex items-center justify-between gap-4 px-5 py-4 text-left text-sm font-medium"
                style="background: var(--card); color: var(--fg);">
          What is the execute permission used for?
          <svg class="faq-chevron w-4 h-4 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="faq-a hidden px-5 pb-5 pt-2 text-sm leading-relaxed" style="background: var(--card); color: var(--fg2);">
          The execute permission on a file means the system is allowed to run it as a program or script. On a directory, execute permission means the user is allowed to enter the directory and access its contents. Without execute permission on a directory you cannot cd into it even if you can see it listed with ls.
        </div>
      </div>

      <div class="faq-item rounded-xl overflow-hidden" style="border: 1px solid var(--border);">
        <button class="faq-q w-full flex items-center justify-between gap-4 px-5 py-4 text-left text-sm font-medium"
                style="background: var(--card); color: var(--fg);">
          Is chmod 777 safe to use?
          <svg class="faq-chevron w-4 h-4 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="faq-a hidden px-5 pb-5 pt-2 text-sm leading-relaxed" style="background: var(--card); color: var(--fg2);">
          chmod 777 gives every user on the system full read, write and execute permissions. This is almost never appropriate on a production server because it allows any user or process to modify or execute the file. It is occasionally useful for temporary debugging but should never be left on sensitive files or directories in a live environment.
        </div>
      </div>

    </div>
  </section>

  <!-- ── SEO CONTENT ───────────────────────────────────────────────────────── -->
  <section class="pb-20">
    <div class="grid sm:grid-cols-2 gap-6">

      <div class="reveal rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);">
        <h2 class="text-base font-semibold mb-3" style="color: var(--fg);">What are Linux File Permissions?</h2>
        <p class="text-sm leading-relaxed" style="color: var(--fg2);">
          Every file and directory on a Linux system has three sets of permissions attached to it. The first applies to the owner, the second to a group, and the third to everyone else on the system. Within each set there are three permission types: read lets the contents be viewed, write lets changes be made, and execute lets the file be run as a program. Getting permissions right is a basic requirement for securing any Linux server. An incorrectly permissioned file can expose configuration data, allow unauthorized writes, or let untrusted code run. You can view the current permissions on any file by running ls -la in your terminal.
        </p>
      </div>

      <div class="reveal rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);">
        <h2 class="text-base font-semibold mb-3" style="color: var(--fg);">How to Use chmod</h2>
        <p class="text-sm leading-relaxed" style="color: var(--fg2);">
          The basic syntax is chmod followed by the permission value and then the filename. You can express permissions as a three digit octal number like 755 or using symbolic notation like u+x to add execute permission for the owner only. To apply the same permissions to every file inside a directory recursively, add the -R flag. On a web server you would typically run chmod 644 on all HTML and config files and chmod 755 on all directories so the web server process can read files and navigate directories without being able to write to them.
        </p>
      </div>

      <div class="reveal rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);">
        <h2 class="text-base font-semibold mb-3" style="color: var(--fg);">Understanding Octal Permission Notation</h2>
        <p class="text-sm leading-relaxed" style="color: var(--fg2);">
          Each octal digit maps directly to a group of three permissions. Read is worth 4, write is worth 2, and execute is worth 1. You add those values for whichever permissions you want. Full permissions is 4 plus 2 plus 1 which equals 7. Read and write with no execute is 4 plus 2 which equals 6. Read only is just 4. No permissions is 0. So 755 means the owner has 7 for full access, and both group and others have 5 for read plus execute. Using a chmod calculator removes the mental arithmetic entirely and shows you the symbolic notation and the ready-to-run command at the same time.
        </p>
      </div>

      <div class="reveal rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);">
        <h2 class="text-base font-semibold mb-3" style="color: var(--fg);">Common chmod Examples for Web Servers</h2>
        <p class="text-sm leading-relaxed" style="color: var(--fg2);">
          Web servers like nginx and Apache need to read your files but should never write to them during normal operation. The standard setup is 644 on all files and 755 on all directories. Files with 644 let the server process read them while blocking writes. Directories with 755 let the server navigate into them. Setting files to 777 gives the server process write access, which is a serious security exposure because a compromised script or malicious upload could overwrite any reachable file. Setting up a new server? Use our <a href="/gitignore-generator" style="color: var(--accent); text-decoration: underline;">gitignore generator</a> to create a gitignore file for your project, and check out our <a href="/docker-compose-converter" style="color: var(--accent); text-decoration: underline;">Docker run to Compose converter</a> if you are containerising that server.
        </p>
      </div>

    </div>
  </section>

</div>
</div>

</Layout>

<script is:inline>
(function () {

  // ── State (initial: 755) ──────────────────────────────────────────────────
  var state = {
    or: true,  ow: true,  ox: true,
    gr: true,  gw: false, gx: true,
    tr: true,  tw: false, tx: true
  };

  var KEYS    = ['or','ow','ox','gr','gw','gx','tr','tw','tx'];
  var LETTERS = { or:'r', ow:'w', ox:'x', gr:'r', gw:'w', gx:'x', tr:'r', tw:'w', tx:'x' };

  // ── Helpers ───────────────────────────────────────────────────────────────
  function digitOf(r, w, x) { return (r ? 4 : 0) + (w ? 2 : 0) + (x ? 1 : 0); }

  function calcOctal() {
    return '' + digitOf(state.or, state.ow, state.ox)
              + digitOf(state.gr, state.gw, state.gx)
              + digitOf(state.tr, state.tw, state.tx);
  }

  function calcSymbolic() {
    return (state.or?'r':'-') + (state.ow?'w':'-') + (state.ox?'x':'-')
         + (state.gr?'r':'-') + (state.gw?'w':'-') + (state.gx?'x':'-')
         + (state.tr?'r':'-') + (state.tw?'w':'-') + (state.tx?'x':'-');
  }

  function digitColor(n) {
    if (n >= 7) return '#F8FAFC';
    if (n >= 5) return '#F8FAFC';
    if (n >= 1) return '#F8FAFC';
    return 'var(--fg3)';
  }

  // ── Card visual update ────────────────────────────────────────────────────
  function applyCard(key, active) {
    var card = document.getElementById('card-' + key);
    if (!card) return;
    if (active) {
      card.style.background   = '#1A1A1A';
      card.style.borderColor  = 'rgba(248,250,252,0.12)';
      card.querySelector('.perm-letter').style.color = '#F8FAFC';
      card.querySelector('.perm-name').style.color   = '#F8FAFC';
      card.querySelector('.perm-value').style.color  = '#F8FAFC';
    } else {
      card.style.background   = 'var(--card)';
      card.style.borderColor  = 'var(--border)';
      card.querySelector('.perm-letter').style.color = 'var(--fg3)';
      card.querySelector('.perm-name').style.color   = 'var(--fg3)';
      card.querySelector('.perm-value').style.color  = 'var(--fg3)';
    }
  }

  // ── Matrix cell update ────────────────────────────────────────────────────
  function applyMatrix(key, active) {
    var el = document.getElementById('mat-' + key);
    if (!el) return;
    el.textContent    = active ? LETTERS[key] : '-';
    el.style.color    = active ? '#F8FAFC' : 'var(--fg3)';
    el.style.fontWeight = active ? '700' : '400';
  }

  // ── Full render ───────────────────────────────────────────────────────────
  function updateAll(skipOctal, skipSymbolic) {
    var oct = calcOctal();
    var sym = calcSymbolic();
    var fn  = (document.getElementById('filenameInput').value || '').trim() || 'filename';

    KEYS.forEach(function (k) { applyCard(k, state[k]); applyMatrix(k, state[k]); });

    var dO = digitOf(state.or, state.ow, state.ox);
    var dG = digitOf(state.gr, state.gw, state.gx);
    var dT = digitOf(state.tr, state.tw, state.tx);
    var elO = document.getElementById('digit-o');
    var elG = document.getElementById('digit-g');
    var elT = document.getElementById('digit-t');
    if (elO) { elO.textContent = dO; elO.style.color = digitColor(dO); }
    if (elG) { elG.textContent = dG; elG.style.color = digitColor(dG); }
    if (elT) { elT.textContent = dT; elT.style.color = digitColor(dT); }

    var octalEl = document.getElementById('octalInput');
    if (octalEl && !skipOctal && document.activeElement !== octalEl) octalEl.value = oct;

    var symEl = document.getElementById('symbolicInput');
    if (symEl && !skipSymbolic && document.activeElement !== symEl) symEl.value = sym;

    var cmdEl = document.getElementById('chmodCmd');
    if (cmdEl) cmdEl.textContent = 'chmod ' + oct + ' ' + fn;
  }

  // ── Parsers ───────────────────────────────────────────────────────────────
  function setFromOctal(str) {
    str = str.trim();
    if (str.length !== 3) return false;
    var d = [parseInt(str[0], 10), parseInt(str[1], 10), parseInt(str[2], 10)];
    for (var i = 0; i < 3; i++) { if (isNaN(d[i]) || d[i] < 0 || d[i] > 7) return false; }
    state.or = !!(d[0]&4); state.ow = !!(d[0]&2); state.ox = !!(d[0]&1);
    state.gr = !!(d[1]&4); state.gw = !!(d[1]&2); state.gx = !!(d[1]&1);
    state.tr = !!(d[2]&4); state.tw = !!(d[2]&2); state.tx = !!(d[2]&1);
    return true;
  }

  function setFromSymbolic(str) {
    str = str.trim().toLowerCase();
    if (str.length !== 9) return false;
    state.or = str[0]==='r'; state.ow = str[1]==='w'; state.ox = str[2]==='x';
    state.gr = str[3]==='r'; state.gw = str[4]==='w'; state.gx = str[5]==='x';
    state.tr = str[6]==='r'; state.tw = str[7]==='w'; state.tx = str[8]==='x';
    return true;
  }

  // ── Permission card clicks ────────────────────────────────────────────────
  KEYS.forEach(function (key) {
    var card = document.getElementById('card-' + key);
    if (!card) return;
    card.addEventListener('click', function () {
      state[key] = !state[key];
      updateAll(false, false);
    });
    card.addEventListener('mouseover', function () {
      if (!state[key]) {
        card.style.background  = 'rgba(16,185,129,0.05)';
        card.style.borderColor = '#334155';
      }
    });
    card.addEventListener('mouseout', function () {
      if (!state[key]) {
        card.style.background  = 'var(--card)';
        card.style.borderColor = 'var(--border)';
      }
    });
  });

  // ── Octal input ───────────────────────────────────────────────────────────
  var octalInput = document.getElementById('octalInput');
  if (octalInput) {
    octalInput.addEventListener('input', function () {
      var val = this.value.replace(/[^0-7]/g, '');
      if (val !== this.value) this.value = val;
      if (val.length === 3 && setFromOctal(val)) updateAll(true, false);
    });
    octalInput.addEventListener('focus', function () {
      this.style.borderColor = '#F8FAFC';
      this.style.boxShadow   = '0 0 0 3px rgba(100,116,139,0.2)';
    });
    octalInput.addEventListener('blur', function () {
      this.style.borderColor = 'var(--border)';
      this.style.boxShadow   = 'none';
      if (this.value.length !== 3) this.value = calcOctal();
    });
  }

  // ── Symbolic input ────────────────────────────────────────────────────────
  var symbolicInput = document.getElementById('symbolicInput');
  if (symbolicInput) {
    symbolicInput.addEventListener('input', function () {
      if (this.value.length === 9 && setFromSymbolic(this.value)) updateAll(false, true);
    });
    symbolicInput.addEventListener('focus', function () {
      this.style.borderColor = '#F8FAFC';
      this.style.boxShadow   = '0 0 0 3px rgba(100,116,139,0.2)';
    });
    symbolicInput.addEventListener('blur', function () {
      this.style.borderColor = 'var(--border)';
      this.style.boxShadow   = 'none';
      if (this.value.length !== 9) this.value = calcSymbolic();
    });
  }

  // ── Filename input ────────────────────────────────────────────────────────
  var filenameInput = document.getElementById('filenameInput');
  if (filenameInput) {
    filenameInput.addEventListener('input', function () { updateAll(false, false); });
    filenameInput.addEventListener('focus', function () {
      this.style.borderColor = '#F8FAFC';
      this.style.boxShadow   = '0 0 0 3px rgba(100,116,139,0.2)';
    });
    filenameInput.addEventListener('blur', function () {
      this.style.borderColor = 'var(--border)';
      this.style.boxShadow   = 'none';
    });
  }

  // ── Preset buttons ────────────────────────────────────────────────────────
  document.querySelectorAll('.preset-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (setFromOctal(this.getAttribute('data-octal'))) updateAll(false, false);
    });
  });

  // ── Copy button ───────────────────────────────────────────────────────────
  var copyBtn     = document.getElementById('copyBtn');
  var copyBtnText = document.getElementById('copyBtnText');
  if (copyBtn && copyBtnText) {
    copyBtn.addEventListener('click', function () {
      var text = document.getElementById('chmodCmd').textContent.trim();
      function flash() {
        copyBtnText.textContent    = 'Copied!';
        copyBtn.style.background   = 'rgba(248,250,252,0.12)';
        setTimeout(function () {
          copyBtnText.textContent  = 'Copy';
          copyBtn.style.background = 'rgba(248,250,252,0.06)';
        }, 2000);
      }
      if (navigator.clipboard) {
        navigator.clipboard.writeText(text).then(flash).catch(function () { fallback(text); flash(); });
      } else { fallback(text); flash(); }
    });
  }

  function fallback(text) {
    var ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0';
    document.body.appendChild(ta);
    ta.select();
    try { document.execCommand('copy'); } catch (e) {}
    document.body.removeChild(ta);
  }

  // ── FAQ accordion ─────────────────────────────────────────────────────────
  document.querySelectorAll('.faq-q').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = btn.closest('.faq-item');
      var ans  = item.querySelector('.faq-a');
      var chev = btn.querySelector('.faq-chevron');
      var open = !ans.classList.contains('hidden');
      ans.classList.toggle('hidden', open);
      if (chev) chev.style.transform = open ? '' : 'rotate(180deg)';
    });
  });

  // ── Init ──────────────────────────────────────────────────────────────────
  updateAll(false, false);

})();
</script>

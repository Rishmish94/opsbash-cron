  .seo-aws {
    font-family: 'Fira Code', monospace;
    color: var(--fg3);
  }
</style>

<script>
// ─── CRON ENGINE ────────────────────────────────────────────────────────────

function expandField(field, min, max) {
  if (field === '*' || field === '?') return null;
  const values = new Set();
  for (const part of field.split(',')) {
    if (part.includes('/')) {
      const [range, step] = part.split('/');
      const s = Math.max(1, parseInt(step));
      const [lo, hi] = range === '*' ? [min, max] : range.split('-').map(Number);
      for (let i = lo; i <= (hi ?? lo); i += s) values.add(i);
    } else if (part.includes('-')) {
      const [lo, hi] = part.split('-').map(Number);
      for (let i = lo; i <= hi; i++) values.add(i);
    } else {
      const n = parseInt(part);
      values.add(n === 7 ? 0 : n); // normalize Sun 7→0
    }
  }
  return [...values].sort((a, b) => a - b);
}

function isValidCron(expr) {
  const parts = expr.trim().split(/\s+/);
  if (parts.length < 5 || parts.length > 6) return false;
  const ranges = [[0,59],[0,23],[1,31],[1,12],[0,7]];
  for (let i = 0; i < 5; i++) {
    const p = parts[i];
    if (p === '*' || p === '?') continue;
    for (const t of p.split(',')) {
      const [rangePart, step] = t.split('/');
      if (step !== undefined && (isNaN(parseInt(step)) || parseInt(step) < 1)) return false;
      const dashParts = rangePart === '*' ? [] : rangePart.split('-');
      const [mn, mx] = ranges[i];
      for (const d of dashParts) {
        const n = parseInt(d);
        if (isNaN(n) || n < mn || n > mx) return false;
      }
    }
  }
  return true;
}

// Smart next-run calculator
function getNextRuns(expr, count = 10) {
  const parts = expr.trim().split(/\s+/);
  const [mF, hF, domF, monF, dowF] = parts;

  const allowedMinutes  = expandField(mF,   0, 59);
  const allowedHours    = expandField(hF,   0, 23);
  const allowedDoms     = expandField(domF, 1, 31);
  const allowedMonths   = expandField(monF, 1, 12);
  const allowedWeekdays = expandField(dowF, 0,  6);

  const results = [];
  const d = new Date();
  d.setSeconds(0, 0);
  d.setMinutes(d.getMinutes() + 1);

  const limit = new Date(d.getTime() + 50 * 365 * 24 * 60 * 60 * 1000);

  while (results.length < count && d < limit) {
    const mon = d.getMonth() + 1;
    if (allowedMonths && !allowedMonths.includes(mon)) {
      d.setMonth(d.getMonth() + 1, 1);
      d.setHours(0, 0, 0, 0);
      continue;
    }
    const dom = d.getDate();
    const dow = d.getDay();
    const domOk = !allowedDoms || allowedDoms.includes(dom);
    const dowOk = !allowedWeekdays || allowedWeekdays.includes(dow);
    const dayOk = (allowedDoms && allowedWeekdays) ? (domOk || dowOk) : (domOk && dowOk);
    if (!dayOk) {
      d.setDate(d.getDate() + 1);
      d.setHours(0, 0, 0, 0);
      continue;
    }
    const hr = d.getHours();
    if (allowedHours && !allowedHours.includes(hr)) {
      const nextHr = allowedHours.find(h => h > hr);
      if (nextHr !== undefined) {
        d.setHours(nextHr, 0, 0, 0);
      } else {
        d.setDate(d.getDate() + 1);
        d.setHours(allowedHours[0], 0, 0, 0);
      }
      continue;
    }
    const mn = d.getMinutes();
    if (allowedMinutes && !allowedMinutes.includes(mn)) {
      const nextMin = allowedMinutes.find(m => m > mn);
      if (nextMin !== undefined) {
        d.setMinutes(nextMin, 0, 0);
      } else {
        d.setHours(d.getHours() + 1, allowedMinutes[0], 0, 0);
      }
      continue;
    }
    results.push(new Date(d));
    d.setMinutes(d.getMinutes() + 1, 0, 0);
  }
  return results;
}

// ─── EXPLANATION ENGINE ─────────────────────────────────────────────────────

function explainField(field, unit, names) {
  if (field === '*' || field === '?') return `every ${unit}`;
  if (field.startsWith('*/')) return `every ${field.slice(2)} ${unit}s`;
  if (field.includes('-') && field.includes('/')) {
    const [range, step] = field.split('/');
    const [a, b] = range.split('-');
    const na = names ? (names[parseInt(a)] ?? a) : a;
    const nb = names ? (names[parseInt(b)] ?? b) : b;
    return `every ${step} ${unit}s from ${na} to ${nb}`;
  }
  if (field.includes('-')) {
    const [a, b] = field.split('-');
    const na = names ? (names[parseInt(a)] ?? a) : a;
    const nb = names ? (names[parseInt(b)] ?? b) : b;
    return `${na}–${nb}`;
  }
  if (field.includes(',')) {
    const vals = field.split(',').map(v => names ? (names[parseInt(v)] ?? v) : v);
    const last = vals.pop();
    return vals.length ? `${vals.join(', ')} and ${last}` : last;
  }
  if (names) return names[parseInt(field)] ?? field;
  return field;
}

function buildExplanation(expr) {
  const parts = expr.trim().split(/\s+/);
  const [mF, hF, domF, monF, dowF] = parts;

  if (mF === '*' && hF === '*' && domF === '*' && monF === '*' && (dowF === '*' || dowF === undefined)) {
    return 'Runs every minute, all day, every day.';
  }

  const monthNames = ['','Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const dowNames   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

  const dom     = explainField(domF, 'day',     null);
  const month   = explainField(monF, 'month',   monthNames);
  const weekday = explainField(dowF, 'weekday', dowNames);

  let parts2 = [];
  const mIsStep = mF.startsWith('*/');
  const hIsStep = hF.startsWith('*/');

  if (mF === '0' && hF !== '*' && !hIsStep && !hF.includes(',')) {
    const n = parseInt(hF);
    const ampm = n < 12 ? 'AM' : 'PM';
    const h = n % 12 || 12;
    if (hF.includes('-')) {
      parts2.push(`at :00 during ${explainField(hF, 'hour', null)}`);
    } else {
      parts2.push(`at ${h}:00 ${ampm}`);
    }
  } else if (!mIsStep && !hIsStep && mF !== '*' && hF !== '*' && !mF.includes('/') && !hF.includes('/') && !mF.includes(',') && !hF.includes(',')) {
    const mn = mF.padStart(2, '0');
    const n = parseInt(hF);
    const ampm = n < 12 ? 'AM' : 'PM';
    const h = n % 12 || 12;
    parts2.push(`at ${h}:${mn} ${ampm}`);
  } else {
    if (mF !== '*' && !mIsStep) parts2.push(`at minute ${mF}`);
    if (hF !== '*' && !hIsStep) parts2.push(`during hour ${hF}`);
  }

  const domWild = domF === '*' || domF === '?';
  const dowWild = dowF === '*' || dowF === '?' || dowF === undefined;
  if (!domWild && dowWild)  parts2.push(`on the ${dom}`);
  else if (domWild && !dowWild) parts2.push(`on ${weekday}`);
  else if (!domWild && !dowWild) parts2.push(`on the ${dom} or on ${weekday}`);

  if (monF !== '*' && monF !== '?') parts2.push(`in ${month}`);

  let prefix;
  if (mIsStep && (hF === '*' || hIsStep)) {
    prefix = `Runs every ${mF.slice(2)} minutes`;
  } else if (hIsStep) {
    const minStr = mF === '0' ? ' on the hour' : mF === '*' ? '' : ` at minute ${mF}`;
    prefix = `Runs every ${hF.slice(2)} hours${minStr}`;
  } else if (parts2.length === 0) {
    prefix = 'Runs every minute';
  } else {
    prefix = 'Runs';
  }

  return prefix + (parts2.length ? ' ' + parts2.join(', ') : '') + '.';
}

// ─── STAT CARD HELPERS ───────────────────────────────────────────────────────

function getRunsPerDay(expr) {
  const parts = expr.trim().split(/\s+/);
  const [mF, hF] = parts;
  const mins = expandField(mF, 0, 59) || Array.from({length: 60}, (_, i) => i);
  const hrs  = expandField(hF, 0, 23) || Array.from({length: 24}, (_, i) => i);
  return mins.length * hrs.length;
}

function formatTimeUntil(date) {
  const diff = Math.max(0, date - Date.now());
  const s = Math.floor(diff / 1000);
  const m = Math.floor(s / 60);
  const h = Math.floor(m / 60);
  if (h > 0) return `in ${h}h ${m % 60}m`;
  if (m > 0) return `in ${m}m ${s % 60}s`;
  return `in ${s}s`;
}

// ─── DROPDOWN OPTIONS ────────────────────────────────────────────────────────

function ord(n) {
  const s = ['th','st','nd','rd'], v = n % 100;
  return s[(v - 20) % 10] || s[v] || s[0];
}

function makeOptions(sel, items) {
  sel.innerHTML = '';
  items.forEach(([val, label]) => {
    const o = document.createElement('option');
    o.value = val; o.textContent = label;
    sel.appendChild(o);
  });
}

const minuteOpts = () => {
  const o = [['*','Every minute'],['*/2','Every 2 min'],['*/5','Every 5 min'],['*/10','Every 10 min'],['*/15','Every 15 min'],['*/30','Every 30 min']];
  for (let i = 0; i <= 59; i++) o.push([String(i), `:${String(i).padStart(2,'0')}`]);
  return o;
};

const hourOpts = () => {
  const o = [['*','Every hour'],['*/2','Every 2 hrs'],['*/3','Every 3 hrs'],['*/4','Every 4 hrs'],['*/6','Every 6 hrs'],['*/8','Every 8 hrs'],['*/12','Every 12 hrs']];
  for (let i = 0; i <= 23; i++) {
    const a = i < 12 ? 'AM' : 'PM', h = i % 12 || 12;
    o.push([String(i), `${h} ${a}`]);
  }
  return o;
};

const dayOpts = () => {
  const o = [['*','Every day']];
  for (let i = 1; i <= 31; i++) o.push([String(i), `${i}${ord(i)}`]);
  return o;
};

const monthOpts = () => {
  const names = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const o = [['*','Every month']];
  names.forEach((n, i) => o.push([String(i + 1), n]));
  return o;
};

const weekdayOpts = () => [
  ['*',   'Every day'],
  ['1-5', 'Weekdays'],
  ['0', 'Sunday'], ['1', 'Monday'], ['2', 'Tuesday'], ['3', 'Wednesday'],
  ['4', 'Thursday'], ['5', 'Friday'], ['6', 'Saturday'],
];

const yearOpts = () => {
  const o = [['*','Every year']];
  const y = new Date().getFullYear();
  for (let i = y; i <= y + 5; i++) o.push([String(i), String(i)]);
  return o;
};

// ─── PLATFORM DEFINITIONS ───────────────────────────────────────────────────

const PLATFORMS = {
  linux: {
    hint: 'Standard 5-field cron syntax used in crontab and most Unix schedulers. Fields: minute hour day-of-month month day-of-week.',
    transform: e => e,
    showCode: false,
  },
  aws: {
    hint: 'AWS EventBridge / CloudWatch uses a 6-field format that adds a year field at the end. Use ? in day-of-month OR day-of-week (not both). Weekdays are 1–7 (Sunday=1). All times are UTC.',
    transform: expr => {
      const p = expr.trim().split(/\s+/);
      let [m, h, dom, mon, dow] = p;
      if (dom === '*' && dow !== '*') dom = '?';
      else if (dow === '*' && dom !== '*') dow = '?';
      else if (dom === '*' && dow === '*') dow = '?';
      if (dow !== '*' && dow !== '?') {
        dow = dow.replace(/\b(\d)\b/g, (_, n) => String(parseInt(n) + 1));
      }
      return `cron(${m} ${h} ${dom} ${mon} ${dow} *)`;
    },
    showCode: true,
  },
  github: {
    hint: 'GitHub Actions uses standard 5-field cron in the schedule trigger. All times are UTC. GitHub enforces a minimum interval of 5 minutes.',
    transform: expr => `on:\n  schedule:\n    - cron: '${expr}'`,
    showCode: true,
  },
  k8s: {
    hint: 'Kubernetes CronJob spec uses standard 5-field cron syntax. Supports @hourly, @daily, @weekly, @monthly, @yearly shorthand aliases.',
    transform: expr =>
      `apiVersion: batch/v1\nkind: CronJob\nmetadata:\n  name: my-cronjob\nspec:\n  schedule: "${expr}"\n  jobTemplate:\n    spec:\n      template:\n        spec:\n          containers:\n          - name: job\n            image: busybox\n          restartPolicy: OnFailure`,
    showCode: true,
  },
};

// ─── STATE ───────────────────────────────────────────────────────────────────

let currentPlatform  = 'linux';
let currentExpr      = '* * * * *';
let syncingDropdowns = false;

// ─── DOM REFS ────────────────────────────────────────────────────────────────

const cronInput       = document.getElementById('cronInput');
const cronError       = document.getElementById('cronError');
const explanation     = document.getElementById('explanation');
const fieldBreakdown  = document.getElementById('fieldBreakdown');
const nextRunsList    = document.getElementById('nextRuns');
const nextRunsEmpty   = document.getElementById('nextRunsEmpty');
const tzLabel         = document.getElementById('tzLabel');
const platformHint    = document.getElementById('platformHint');
const platformOutput  = document.getElementById('platformOutput');
const platformCode    = document.getElementById('platformCode');
const copyBtn         = document.getElementById('copyBtn');
const copyLabel       = document.getElementById('copyLabel');
const copyPlatformBtn = document.getElementById('copyPlatformBtn');
const selMinute  = document.getElementById('selMinute');
const selHour    = document.getElementById('selHour');
const selDay     = document.getElementById('selDay');
const selMonth   = document.getElementById('selMonth');
const selWeekday = document.getElementById('selWeekday');
const selYear    = document.getElementById('selYear');
const weekdayCol = document.getElementById('weekdayCol');
const yearCol    = document.getElementById('yearCol');
const statExpr      = document.getElementById('statExpr');
const statNextRun   = document.getElementById('statNextRun');
const statRunsPerDay = document.getElementById('statRunsPerDay');

// ─── INIT ────────────────────────────────────────────────────────────────────

makeOptions(selMinute,  minuteOpts());
makeOptions(selHour,    hourOpts());
makeOptions(selDay,     dayOpts());
makeOptions(selMonth,   monthOpts());
makeOptions(selWeekday, weekdayOpts());
makeOptions(selYear,    yearOpts());

tzLabel.textContent = Intl.DateTimeFormat().resolvedOptions().timeZone;

// ─── UPDATE ──────────────────────────────────────────────────────────────────

function updateUI(expr) {
  currentExpr = expr;
  cronInput.value = expr;

  // Stat: current expression
  if (statExpr) statExpr.textContent = expr;

  const valid = isValidCron(expr);

  if (!valid && expr.trim() !== '') {
    cronError.textContent = 'Invalid cron expression — check field values and ranges.';
    cronError.classList.remove('hidden');
    explanation.textContent = '—';
    nextRunsList.innerHTML = '';
    nextRunsEmpty.classList.add('hidden');
    if (statNextRun)    statNextRun.textContent = '—';
    if (statRunsPerDay) statRunsPerDay.textContent = '—';
    return;
  }
  cronError.classList.add('hidden');
  if (!expr.trim()) return;

  // Plain English
  explanation.textContent = buildExplanation(expr);

  // Field breakdown chips
  const exprParts = expr.trim().split(/\s+/);
  const labels = ['Min', 'Hour', 'Day', 'Mon', 'Wday'];
  fieldBreakdown.innerHTML = exprParts.slice(0, 5).map((p, i) => `
    <div class="flex flex-col items-center gap-0.5 text-center">
      <span class="field-chip-value">${p}</span>
      <span class="field-chip-label">${labels[i]}</span>
    </div>`).join('');

  // Next 10 runs
  const runs = getNextRuns(expr, 10);
  if (runs.length === 0) {
    nextRunsList.innerHTML = '';
    nextRunsEmpty.classList.remove('hidden');
    if (statNextRun) statNextRun.textContent = '—';
  } else {
    nextRunsEmpty.classList.add('hidden');
    const fmt = new Intl.DateTimeFormat(undefined, {
      weekday: 'short', month: 'short', day: 'numeric',
      hour: '2-digit', minute: '2-digit', hour12: true,
    });
    nextRunsList.innerHTML = runs.map((d, i) => `
      <li style="display:flex;align-items:center;gap:12px;padding:7px 0;font-size:12px;">
        <span style="width:22px;height:22px;border-radius:50%;background:#0f2415;color:#10b981;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;font-family:'Fira Code',monospace;">${i + 1}</span>
        <span style="font-family:'Fira Code',monospace;color:var(--fg2);">${fmt.format(d)}</span>
      </li>`).join('');

    // Stat: next run countdown
    if (statNextRun) statNextRun.textContent = formatTimeUntil(runs[0]);
  }

  // Stat: runs per day
  if (statRunsPerDay) {
    const rpd = getRunsPerDay(expr);
    statRunsPerDay.textContent = rpd.toLocaleString();
  }

  // Platform
  const plat = PLATFORMS[currentPlatform];
  platformHint.textContent = plat.hint;
  if (plat.showCode) {
    platformOutput.classList.remove('hidden');
    platformCode.textContent = plat.transform(expr);
  } else {
    platformOutput.classList.add('hidden');
  }

  syncDropdowns(expr);
}

function syncDropdowns(expr) {
  if (syncingDropdowns) return;
  syncingDropdowns = true;
  const [mF = '*', hF = '*', domF = '*', monF = '*', dowF = '*'] = expr.trim().split(/\s+/);
  const trySet = (sel, val) => {
    if (![...sel.options].some(o => { if (o.value === val) { sel.value = val; return true; } })) {
      sel.value = sel.options[0].value;
    }
  };
  trySet(selMinute, mF); trySet(selHour, hF); trySet(selDay, domF);
  trySet(selMonth, monF); trySet(selWeekday, dowF);
  syncingDropdowns = false;
}

function exprFromDropdowns() {
  return [selMinute.value, selHour.value, selDay.value, selMonth.value, selWeekday.value].join(' ');
}

// ─── EVENT HANDLERS ──────────────────────────────────────────────────────────

[selMinute, selHour, selDay, selMonth, selWeekday].forEach(sel =>
  sel.addEventListener('change', () => { if (!syncingDropdowns) updateUI(exprFromDropdowns()); })
);

cronInput.addEventListener('input', () => {
  const v = cronInput.value.trim();
  if (v) updateUI(v);
});

document.querySelectorAll('[data-preset]').forEach(btn =>
  btn.addEventListener('click', () => updateUI(btn.dataset.preset))
);

document.querySelectorAll('.platform-tab').forEach(tab =>
  tab.addEventListener('click', () => {
    document.querySelectorAll('.platform-tab').forEach(t => t.classList.remove('active-tab'));
    tab.classList.add('active-tab');
    currentPlatform = tab.dataset.platform;
    const isAws = currentPlatform === 'aws';
    weekdayCol.classList.toggle('hidden', isAws);
    yearCol.classList.toggle('hidden', !isAws);
    updateUI(currentExpr);
  })
);

copyBtn.addEventListener('click', () => {
  navigator.clipboard.writeText(currentExpr).then(() => {
    copyLabel.textContent = 'Copied!';
    copyBtn.style.background = 'linear-gradient(135deg, #16a34a, #15803d)';
    setTimeout(() => {
      copyLabel.textContent = 'Copy';
      copyBtn.style.background = 'linear-gradient(135deg, #10b981, #059669)';
    }, 2000);
  });
});

copyPlatformBtn.addEventListener('click', () => {
  navigator.clipboard.writeText(platformCode.textContent).then(() => {
    copyPlatformBtn.textContent = 'Copied!';
    setTimeout(() => { copyPlatformBtn.textContent = 'Copy'; }, 2000);
  });
});

// ─── FAQ ACCORDION ───────────────────────────────────────────────────────────

document.querySelectorAll('.faq-trigger').forEach(btn => {
  btn.addEventListener('click', () => {
    const item    = btn.closest('.faq-item');
    const content = item.querySelector('.faq-content');
    const chevron = btn.querySelector('.faq-chevron');
    const isOpen  = !content.classList.contains('hidden');
    content.classList.toggle('hidden', isOpen);
    chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
  });
});

// ─── BOOT ─────────────────────────────────────────────────────────────────────
updateUI('* * * * *');
</script>

</Layout>

---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a cron job?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A cron job is a scheduled task on Unix-like systems managed by the cron daemon. It runs a command or script automatically at a defined time interval — for example, daily, hourly, or every 5 minutes. Each job is defined by a cron expression (5 or 6 space-separated fields) in a file called the crontab. Cron jobs are widely used for backups, log rotation, report generation, and any recurring automation task."
      }
    },
    {
      "@type": "Question",
      "name": "How do I generate a cron expression for every 5 minutes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Use the step syntax: */5 * * * *. The */5 in the minute field means every 5th minute — at :00, :05, :10, :15 … :55. You can generate this automatically by selecting 'Every 5 min' from the Minute dropdown in this cron expression generator, or by clicking the 'Every 5 minutes' preset button."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between AWS cron and Linux cron syntax?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AWS EventBridge cron uses 6 fields (adds a year field at the end) vs the standard 5-field Linux crontab format. AWS also requires a ? wildcard in either the day-of-month or day-of-week field — you cannot specify both. AWS weekdays are 1–7 (Sunday=1) while Linux uses 0–6 (Sunday=0). All AWS cron times run in UTC. Use the AWS CloudWatch tab in this generator to convert any Linux expression automatically."
      }
    },
    {
      "@type": "Question",
      "name": "How do I create a Kubernetes cron job schedule?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kubernetes CronJobs use standard 5-field cron syntax in the spec.schedule field of a CronJob manifest. For example, schedule: '0 9 * * 1-5' runs a job at 9 AM on weekdays. Use the Kubernetes tab in this cron expression generator to get a ready-to-use CronJob YAML manifest with your schedule pre-filled."
      }
    },
    {
      "@type": "Question",
      "name": "What does */5 mean in a cron expression?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The */n syntax means every nth unit starting from the minimum value of that field. */5 in the minute field expands to 0,5,10,15,20,25,30,35,40,45,50,55 — running the job every 5 minutes. You can use step values in any field: */2 in the hour field means every 2 hours, and */15 in the minute field means every 15 minutes."
      }
    },
    {
      "@type": "Question",
      "name": "How do I run a cron job every weekday at 9am?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Use the expression: 0 9 * * 1-5. The 0 in the minute field means at :00, 9 means 9 AM, and 1-5 in the day-of-week field means Monday through Friday. On AWS EventBridge the equivalent is cron(0 9 ? * MON-FRI *). Click the 'Weekdays 9–5' preset in this generator to start from a similar template, then adjust as needed."
      }
    }
  ]
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to generate a cron expression",
  "description": "Step by step guide to creating a cron expression for Linux, AWS, GitHub Actions or Kubernetes",
  "step": [
    {
      "@type": "HowToStep",
      "name": "Choose your platform",
      "text": "Select your target platform from Linux/Unix, AWS EventBridge, GitHub Actions or Kubernetes tabs"
    },
    {
      "@type": "HowToStep",
      "name": "Set the schedule using dropdowns",
      "text": "Use the visual builder dropdowns to select minute, hour, day, month and weekday values"
    },
    {
      "@type": "HowToStep",
      "name": "Read the plain English explanation",
      "text": "The tool instantly shows what your cron expression means in plain English"
    },
    {
      "@type": "HowToStep",
      "name": "Check the next run times",
      "text": "Verify your schedule is correct by checking the next 10 run times shown in your local timezone"
    },
    {
      "@type": "HowToStep",
      "name": "Copy the expression",
      "text": "Click the Copy button to copy the expression to your clipboard ready to use"
    }
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Cron Expression Generator",
  "url": "https://opsbash.com/cron-builder",
  "description": "Generate and validate cron expressions visually. Supports Linux, AWS CloudWatch, GitHub Actions and Kubernetes.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<Layout
  title="Cron Expression Generator — Free Online Cron Builder | opsbash.com"
  description="Generate and validate cron expressions visually. Supports Linux, AWS CloudWatch, GitHub Actions and Kubernetes. Instantly see next run times in your timezone."
  canonicalURL="https://opsbash.com/cron-builder"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

<!-- ── PAGE CONTENT ───────────────────────────────────────────────────────────── -->
<div style="background: var(--bg);">
<div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">

  <!-- HERO -->
  <section class="pt-8 pb-5">
    <div class="inline-flex items-center gap-2 text-xs font-medium px-3 py-1.5 rounded-full mb-4"
         style="background: rgba(16,185,129,0.1); color: #34d399; border: 1px solid rgba(16,185,129,0.2);">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
      Free Cron Expression Generator
    </div>
    <h1 class="text-3xl sm:text-4xl font-bold mb-3 tracking-tight hero-gradient">
      Free Cron Expression Generator
    </h1>
    <p class="text-base max-w-xl" style="color: var(--fg2);">
      Generate, validate, and understand cron expressions with a visual editor. Supports Linux crontab, AWS CloudWatch, GitHub Actions, and Kubernetes formats.
    </p>
  </section>

  <!-- PRESETS -->
  <div class="mb-6">
    <p class="text-xs font-medium uppercase tracking-wider mb-3" style="color: var(--fg3);">Common Presets</p>
    <div class="flex flex-wrap gap-2">
      <button data-preset="* * * * *"      class="preset-btn">Every minute</button>
      <button data-preset="0 * * * *"      class="preset-btn">Every hour</button>
      <button data-preset="0 0 * * *"      class="preset-btn">Daily at midnight</button>
      <button data-preset="0 9 * * *"      class="preset-btn">Daily at 9 AM</button>
      <button data-preset="0 0 * * 0"      class="preset-btn">Every Sunday</button>
      <button data-preset="0 0 * * 1"      class="preset-btn">Every Monday</button>
      <button data-preset="0 0 1 * *"      class="preset-btn">1st of month</button>
      <button data-preset="*/5 * * * *"    class="preset-btn">Every 5 minutes</button>
      <button data-preset="*/15 * * * *"   class="preset-btn">Every 15 minutes</button>
      <button data-preset="*/30 * * * *"   class="preset-btn">Every 30 minutes</button>
      <button data-preset="0 9-17 * * 1-5" class="preset-btn">Weekdays 9–5</button>
      <button data-preset="0 0 1 1 *"      class="preset-btn">New Year's midnight</button>
    </div>
  </div>

  <!-- 2-COLUMN LAYOUT: builder (60%) + results (40%) -->
  <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,3fr)_minmax(0,2fr)] gap-6 mb-6">

    <!-- LEFT: BUILDER CARD with window chrome -->
    <div>
      <!-- Window chrome -->
      <div class="flex items-center gap-1.5 px-4 py-3 rounded-t-[14px]"
           style="background: #0a1a0f; border: 1px solid var(--border); border-bottom: 1px solid rgba(255,255,255,0.06);">
        <div class="w-3 h-3 rounded-full" style="background: #ff5f57;"></div>
        <div class="w-3 h-3 rounded-full" style="background: #febc2e;"></div>
        <div class="w-3 h-3 rounded-full" style="background: #28c840;"></div>
        <span class="ml-3 text-xs font-mono" style="color: var(--fg3);">cron-builder.sh</span>
      </div>
      <!-- Builder card -->
      <div class="overflow-hidden" style="background: var(--card); border: 1px solid var(--border); border-top: none; border-radius: 0 0 14px 14px;">

        <!-- PLATFORM TABS -->
        <div class="flex overflow-x-auto tabs-scroll" style="border-bottom: 1px solid var(--border); background: var(--bg);">
          <button data-platform="linux"  class="platform-tab active-tab">Linux / Unix</button>
          <button data-platform="aws"    class="platform-tab">AWS CloudWatch</button>
          <button data-platform="github" class="platform-tab">GitHub Actions</button>
          <button data-platform="k8s"    class="platform-tab">Kubernetes</button>
        </div>

        <div class="p-4 sm:p-5">

          <!-- Platform hint -->
          <div id="platformHint" class="mb-5 p-3 rounded-lg text-xs leading-relaxed"
               style="background: rgba(16,185,129,0.05); border: 1px solid rgba(16,185,129,0.12); color: var(--fg2);"></div>

          <!-- VISUAL DROPDOWNS -->
          <div class="mb-5">
            <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--fg3);">Visual Builder</p>
            <div class="flex flex-col sm:flex-row sm:flex-wrap gap-2.5" id="dropdownGrid">
              <div class="flex flex-col gap-1.5 w-full sm:flex-1 sm:min-w-[90px]">
                <label class="text-xs font-medium" style="color: var(--fg2);">Minute</label>
                <select id="selMinute" class="cron-select"></select>
              </div>
              <div class="flex flex-col gap-1.5 w-full sm:flex-1 sm:min-w-[90px]">
                <label class="text-xs font-medium" style="color: var(--fg2);">Hour</label>
                <select id="selHour" class="cron-select"></select>
              </div>
              <div class="flex flex-col gap-1.5 w-full sm:flex-1 sm:min-w-[80px]">
                <label class="text-xs font-medium" style="color: var(--fg2);">Day</label>
                <select id="selDay" class="cron-select"></select>
              </div>
              <div class="flex flex-col gap-1.5 w-full sm:flex-1 sm:min-w-[90px]">
                <label class="text-xs font-medium" style="color: var(--fg2);">Month</label>
                <select id="selMonth" class="cron-select"></select>
              </div>
              <div class="flex flex-col gap-1.5 w-full sm:flex-1 sm:min-w-[90px]" id="weekdayCol">
                <label class="text-xs font-medium" style="color: var(--fg2);">Weekday</label>
                <select id="selWeekday" class="cron-select"></select>
              </div>
              <div class="flex flex-col gap-1.5 w-full sm:flex-1 sm:min-w-[90px] hidden" id="yearCol">
                <label class="text-xs font-medium" style="color: var(--fg2);">Year</label>
                <select id="selYear" class="cron-select"></select>
              </div>
            </div>
          </div>

          <!-- EXPRESSION INPUT -->
          <div class="mb-4">
            <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--fg3);">Expression</p>
            <div class="flex gap-2">
              <input id="cronInput" type="text" spellcheck="false"
                class="flex-1 min-w-0 rounded-xl px-4 py-2.5 transition-all focus:outline-none"
                style="font-family: 'Fira Code', 'Cascadia Code', monospace; font-size: 18px; letter-spacing: 0.1em; color: #34d399; background: var(--bg); border: 1px solid #10b981; box-shadow: 0 0 0 3px rgba(16,185,129,0.12), 0 0 20px rgba(16,185,129,0.08);"
                placeholder="* * * * *" />
              <button id="copyBtn"
                class="shrink-0 h-10 px-4 text-white text-sm font-bold rounded-xl flex items-center gap-2 transition-all whitespace-nowrap copy-btn-gradient">
                <svg id="copyIcon" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                </svg>
                <span id="copyLabel">Copy</span>
              </button>
            </div>
            <p id="cronError" class="mt-2 text-xs text-red-500 hidden"></p>
          </div>

          <!-- PLATFORM CODE OUTPUT -->
          <div id="platformOutput" class="hidden">
            <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--fg3);">Platform Format</p>
            <div class="relative">
              <pre id="platformCode" class="font-mono text-xs rounded-xl p-4 overflow-x-auto leading-relaxed whitespace-pre-wrap break-all"
                   style="background: #0a1a0f; color: #4ade80;"></pre>
              <button id="copyPlatformBtn"
                class="absolute top-2 right-2 text-xs px-2.5 py-1 rounded-lg transition-colors"
                style="background: #0f2415; color: var(--fg2);">Copy</button>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- RIGHT COLUMN: stat cards + plain English + next runs + field reference -->
    <div class="space-y-4">

      <!-- STAT CARDS -->
      <div class="grid grid-cols-3 gap-2">
        <div class="stat-card">
          <div class="stat-label">Expression</div>
          <div id="statExpr" class="stat-value" style="color: #34d399; font-family: 'Fira Code', 'Cascadia Code', monospace; font-size: 11px; letter-spacing: 0.05em; word-break: break-all;">* * * * *</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Next Run</div>
          <div id="statNextRun" class="stat-value" style="color: #34d399; font-size: 12px;">—</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Per Day</div>
          <div id="statRunsPerDay" class="stat-value" style="color: #34d399;">1,440</div>
        </div>
      </div>

      <!-- PLAIN ENGLISH -->
      <div class="rounded-[14px]" style="background: var(--card); border: 1px solid var(--border);">
        <div class="px-5 pt-4 pb-3" style="border-bottom: 1px solid var(--border);">
          <h2 class="text-xs font-semibold uppercase tracking-wider" style="color: var(--fg2);">Plain English</h2>
        </div>
        <div class="p-5">
          <p id="explanation" class="text-sm leading-relaxed font-medium min-h-[20px]" style="color: var(--fg);"></p>
          <div id="fieldBreakdown" class="mt-4 flex gap-2 flex-wrap"></div>
        </div>
      </div>

      <!-- NEXT 10 RUNS -->
      <div class="rounded-[14px]" style="background: var(--card); border: 1px solid var(--border);">
        <div class="px-5 pt-4 pb-3 flex items-center justify-between" style="border-bottom: 1px solid var(--border);">
          <h2 class="text-xs font-semibold uppercase tracking-wider" style="color: var(--fg2);">Next 10 Runs</h2>
          <span id="tzLabel" class="text-xs font-mono truncate max-w-[140px]" style="color: var(--fg3);"></span>
        </div>
        <div class="px-5 py-3">
          <ol id="nextRuns" class="divide-y" style="border-color: var(--border);"></ol>
          <p id="nextRunsEmpty" class="hidden text-xs italic py-2" style="color: var(--fg3);">No upcoming runs found in the next 50 years.</p>
        </div>
      </div>

      <!-- FIELD REFERENCE -->
      <div class="rounded-[14px]" style="background: var(--card); border: 1px solid var(--border);">
        <div class="px-5 pt-4 pb-3" style="border-bottom: 1px solid var(--border);">
          <h2 class="text-xs font-semibold uppercase tracking-wider" style="color: var(--fg2);">Field Reference</h2>
        </div>
        <div class="p-5">
          <div class="space-y-2 mb-4">
            <div class="flex items-center gap-3 text-xs">
              <code class="ref-code">*</code>
              <span style="color: var(--fg2);">Any / every value</span>
            </div>
            <div class="flex items-center gap-3 text-xs">
              <code class="ref-code">*/n</code>
              <span style="color: var(--fg2);">Every nth unit</span>
            </div>
            <div class="flex items-center gap-3 text-xs">
              <code class="ref-code">a-b</code>
              <span style="color: var(--fg2);">Range from a to b</span>
            </div>
            <div class="flex items-center gap-3 text-xs">
              <code class="ref-code">a,b,c</code>
              <span style="color: var(--fg2);">Specific values list</span>
            </div>
            <div class="flex items-center gap-3 text-xs">
              <code class="ref-code">a-b/n</code>
              <span style="color: var(--fg2);">Range with step</span>
            </div>
          </div>
          <div class="pt-3" style="border-top: 1px solid var(--border);">
            <table class="w-full text-xs" style="color: var(--fg2);">
              <thead>
                <tr style="color: var(--fg3);" class="text-left">
                  <th class="pb-2 font-medium">Field</th>
                  <th class="pb-2 font-medium">Range</th>
                </tr>
              </thead>
              <tbody>
                <tr><td class="py-0.5 font-mono" style="color: #34d399;">Minute</td><td>0–59</td></tr>
                <tr><td class="py-0.5 font-mono" style="color: #34d399;">Hour</td><td>0–23</td></tr>
                <tr><td class="py-0.5 font-mono" style="color: #34d399;">Day</td><td>1–31</td></tr>
                <tr><td class="py-0.5 font-mono" style="color: #34d399;">Month</td><td>1–12</td></tr>
                <tr><td class="py-0.5 font-mono" style="color: #34d399;">Weekday</td><td>0–7 (0,7=Sun)</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div><!-- /right column -->

  </div><!-- /2-column grid -->

  <!-- FAQ (full width) -->
  <div class="mb-0">
    <div class="overflow-hidden rounded-[14px]" style="background: var(--card); border: 1px solid var(--border);">
      <div class="p-5" style="border-bottom: 1px solid var(--border); background: var(--bg);">
        <h2 class="text-base font-semibold" style="color: var(--fg);">Frequently Asked Questions</h2>
      </div>

      <div class="faq-item">
        <p class="direct-answer">A cron job is a scheduled task on Unix/Linux systems that runs automatically at defined time intervals, managed by the cron daemon. It uses a 5-field cron expression to define when to run a command.</p>
        <button class="faq-trigger w-full flex items-center justify-between p-5 text-left gap-3">
          <span class="text-sm font-medium" style="color: var(--fg);">What is a cron job?</span>
          <svg class="faq-chevron w-4 h-4 shrink-0 transition-transform duration-200" style="color: var(--fg3);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="faq-content hidden px-5 pb-5 text-sm leading-relaxed" style="color: var(--fg2);">
          A <strong style="color: var(--fg);">cron job</strong> is a scheduled task on Unix-like systems managed by the <em>cron</em> daemon. It automatically runs a command or script at a defined time interval — hourly, daily, weekly, or any custom schedule. Each cron job is defined by a <strong style="color: var(--fg);">cron expression</strong>: 5 (or 6) space-separated fields representing minute, hour, day-of-month, month, and day-of-week. Jobs are stored in a file called the <code class="ic">crontab</code> (cron table). Common uses include database backups, log rotation, cache warming, and sending scheduled reports.
        </div>
      </div>

      <div class="faq-item">
        <p class="direct-answer">Use <code class="ic">*/5 * * * *</code> — the <code class="ic">*/5</code> in the minute field means every 5th minute, running at :00, :05, :10 … :55. Click the "Every 5 minutes" preset button above to generate it automatically.</p>
        <button class="faq-trigger w-full flex items-center justify-between p-5 text-left gap-3">
          <span class="text-sm font-medium" style="color: var(--fg);">How do I generate a cron expression for every 5 minutes?</span>
          <svg class="faq-chevron w-4 h-4 shrink-0 transition-transform duration-200" style="color: var(--fg3);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="faq-content hidden px-5 pb-5 text-sm leading-relaxed" style="color: var(--fg2);">
          Use the step syntax: <code class="ic">*/5 * * * *</code>. The <code class="ic">*/5</code> in the minute field means "every 5th minute" — at :00, :05, :10, :15 … :55. To generate this automatically, select <strong style="color: var(--fg);">Every 5 min</strong> from the Minute dropdown above, or click the <strong style="color: var(--fg);">Every 5 minutes</strong> preset button. The same step syntax works in any field: <code class="ic">*/2</code> means every 2 units, <code class="ic">*/15</code> means every 15 units.
        </div>
      </div>

      <div class="faq-item">
        <p class="direct-answer">AWS EventBridge cron uses 6 fields (adds a year field) vs 5-field Linux crontab, and requires <code class="ic">?</code> in either day-of-month or day-of-week. All AWS schedules run in UTC; Linux crontab uses local system time.</p>
        <button class="faq-trigger w-full flex items-center justify-between p-5 text-left gap-3">
          <span class="text-sm font-medium" style="color: var(--fg);">What is the difference between AWS cron and Linux cron syntax?</span>
          <svg class="faq-chevron w-4 h-4 shrink-0 transition-transform duration-200" style="color: var(--fg3);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="faq-content hidden px-5 pb-5 text-sm leading-relaxed space-y-2" style="color: var(--fg2);">
          <p>AWS EventBridge / CloudWatch uses a <strong style="color: var(--fg);">6-field format</strong> that appends a <em>year</em> field: <code class="ic">minute hour day month weekday year</code>. Key differences from Linux crontab:</p>
          <ul class="list-disc list-inside space-y-1 ml-2">
            <li>AWS requires <code class="ic">?</code> in either day-of-month <em>or</em> day-of-week — you cannot set a specific value in both.</li>
            <li>AWS weekdays are <strong>1–7</strong> (Sunday = 1); Linux uses <strong>0–6</strong> (Sunday = 0 or 7).</li>
            <li>AWS does not support <code class="ic">@daily</code>, <code class="ic">@hourly</code>, or other shorthand aliases.</li>
            <li>All AWS cron schedules run in <strong>UTC</strong>.</li>
          </ul>
          <p>Use the <strong style="color: var(--fg);">AWS CloudWatch</strong> tab in this generator to convert any Linux expression automatically.</p>
        </div>
      </div>

      <div class="faq-item">
        <p class="direct-answer">Kubernetes CronJobs use standard 5-field cron syntax in the <code class="ic">spec.schedule</code> field. For example, <code class="ic">schedule: "0 9 * * 1-5"</code> runs a job at 9 AM on weekdays.</p>
        <button class="faq-trigger w-full flex items-center justify-between p-5 text-left gap-3">
          <span class="text-sm font-medium" style="color: var(--fg);">How do I create a Kubernetes cron job schedule?</span>
          <svg class="faq-chevron w-4 h-4 shrink-0 transition-transform duration-200" style="color: var(--fg3);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="faq-content hidden px-5 pb-5 text-sm leading-relaxed" style="color: var(--fg2);">
          Kubernetes CronJobs use standard 5-field cron syntax in the <code class="ic">spec.schedule</code> field of a CronJob manifest. For example, <code class="ic">schedule: "0 9 * * 1-5"</code> runs a job at 9 AM on weekdays. Kubernetes also supports the shorthand aliases <code class="ic">@hourly</code>, <code class="ic">@daily</code>, <code class="ic">@weekly</code>, and <code class="ic">@monthly</code>. Use the <strong style="color: var(--fg);">Kubernetes</strong> tab in this cron job generator to get a complete, ready-to-apply CronJob YAML manifest with your schedule pre-filled.
        </div>
      </div>

      <div class="faq-item">
        <p class="direct-answer"><code class="ic">*/5</code> means "every 5th unit from the minimum value." In the minute field it expands to 0, 5, 10, 15 … 55 — running the job every 5 minutes. The same step syntax works in any cron field.</p>
        <button class="faq-trigger w-full flex items-center justify-between p-5 text-left gap-3">
          <span class="text-sm font-medium" style="color: var(--fg);">What does */5 mean in a cron expression?</span>
          <svg class="faq-chevron w-4 h-4 shrink-0 transition-transform duration-200" style="color: var(--fg3);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="faq-content hidden px-5 pb-5 text-sm leading-relaxed" style="color: var(--fg2);">
          The <code class="ic">*/n</code> syntax means "every nth unit starting from the field minimum." The <code class="ic">*</code> expands to the full range and <code class="ic">/n</code> is the step interval. So <code class="ic">*/5</code> in the minute field expands to <code class="ic">0,5,10,15,20,25,30,35,40,45,50,55</code>. You can also step over a range: <code class="ic">8-18/2</code> in the hour field means every 2 hours from 8 AM to 6 PM. This generator supports all step syntax in every field.
        </div>
      </div>

      <div class="faq-item" style="border-bottom: none;">
        <p class="direct-answer">Use the expression <code class="ic">0 9 * * 1-5</code> — <code class="ic">0</code> sets the minute to :00, <code class="ic">9</code> sets the hour to 9 AM, and <code class="ic">1-5</code> means Monday through Friday.</p>
        <button class="faq-trigger w-full flex items-center justify-between p-5 text-left gap-3">
          <span class="text-sm font-medium" style="color: var(--fg);">How do I run a cron job every weekday at 9 AM?</span>
          <svg class="faq-chevron w-4 h-4 shrink-0 transition-transform duration-200" style="color: var(--fg3);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="faq-content hidden px-5 pb-5 text-sm leading-relaxed" style="color: var(--fg2);">
          Use the expression <code class="ic">0 9 * * 1-5</code>. The <code class="ic">0</code> sets the minute to :00, <code class="ic">9</code> sets the hour to 9 AM, and <code class="ic">1-5</code> in the day-of-week field means Monday through Friday. On AWS EventBridge the equivalent is <code class="ic">cron(0 9 ? * MON-FRI *)</code>. Click the <strong style="color: var(--fg);">Weekdays 9–5</strong> preset in this generator as a starting point, then adjust the hour dropdown to narrow it to exactly 9 AM.
        </div>
      </div>


---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a cron job?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A cron job is a scheduled task on Unix-like systems managed by the cron daemon. It runs a command or script automatically at a defined time interval — for example, daily, hourly, or every 5 minutes. Each job is defined by a cron expression (5 or 6 space-separated fields) in a file called the crontab. Cron jobs are widely used for backups, log rotation, report generation, and any recurring automation task."
      }
    },
    {
      "@type": "Question",
      "name": "How do I generate a cron expression for every 5 minutes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Use the step syntax: */5 * * * *. The */5 in the minute field means every 5th minute — at :00, :05, :10, :15 … :55. You can generate this automatically by selecting 'Every 5 min' from the Minute dropdown in this cron expression generator, or by clicking the 'Every 5 minutes' preset button."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between AWS cron and Linux cron syntax?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AWS EventBridge cron uses 6 fields (adds a year field at the end) vs the standard 5-field Linux crontab format. AWS also requires a ? wildcard in either the day-of-month or day-of-week field — you cannot specify both. AWS weekdays are 1–7 (Sunday=1) while Linux uses 0–6 (Sunday=0). All AWS cron times run in UTC. Use the AWS CloudWatch tab in this generator to convert any Linux expression automatically."
      }
    },
    {
      "@type": "Question",
      "name": "How do I create a Kubernetes cron job schedule?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kubernetes CronJobs use standard 5-field cron syntax in the spec.schedule field of a CronJob manifest. For example, schedule: '0 9 * * 1-5' runs a job at 9 AM on weekdays. Use the Kubernetes tab in this cron expression generator to get a ready-to-use CronJob YAML manifest with your schedule pre-filled."
      }
    },
    {
      "@type": "Question",
      "name": "What does */5 mean in a cron expression?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The */n syntax means every nth unit starting from the minimum value of that field. */5 in the minute field expands to 0,5,10,15,20,25,30,35,40,45,50,55 — running the job every 5 minutes. You can use step values in any field: */2 in the hour field means every 2 hours, and */15 in the minute field means every 15 minutes."
      }
    },
    {
      "@type": "Question",
      "name": "How do I run a cron job every weekday at 9am?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Use the expression: 0 9 * * 1-5. The 0 in the minute field means at :00, 9 means 9 AM, and 1-5 in the day-of-week field means Monday through Friday. On AWS EventBridge the equivalent is cron(0 9 ? * MON-FRI *). Click the 'Weekdays 9–5' preset in this generator to start from a similar template, then adjust as needed."
      }
    }
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Cron Expression Generator",
  "url": "https://opsbash.com/cron-builder",
  "description": "Generate and validate cron expressions visually. Supports Linux, AWS CloudWatch, GitHub Actions and Kubernetes.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<Layout
  title="Cron Expression Generator — Free Online Cron Builder | opsbash.com"
  description="Generate and validate cron expressions visually. Supports Linux, AWS CloudWatch, GitHub Actions and Kubernetes. Instantly see next run times in your timezone."
  canonicalURL="https://opsbash.com/cron-builder"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />

<!-- HERO -->
<section class="max-w-6xl mx-auto px-4 pt-12 pb-6 text-center">
  <div class="inline-flex items-center gap-2 bg-indigo-50 dark:bg-indigo-950/50 text-indigo-600 dark:text-indigo-400 text-xs font-medium px-3 py-1.5 rounded-full mb-4 border border-indigo-100 dark:border-indigo-900">
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    Free Cron Expression Generator
  </div>
  <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-3 tracking-tight">
    Free Cron Expression Generator
  </h1>
  <p class="text-gray-500 dark:text-gray-400 text-base max-w-xl mx-auto">
    Generate, validate, and understand cron expressions with a visual editor. Supports Linux crontab, AWS CloudWatch, GitHub Actions, and Kubernetes formats.
  </p>
</section>

<!-- MAIN TOOL -->
<main class="w-full max-w-6xl mx-auto px-4 pb-16">

  <!-- PRESETS -->
  <div class="mb-6">
    <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Common Presets</p>
    <div class="flex flex-wrap gap-2">
      <button data-preset="* * * * *"      class="preset-btn">Every minute</button>
      <button data-preset="0 * * * *"      class="preset-btn">Every hour</button>
      <button data-preset="0 0 * * *"      class="preset-btn">Daily at midnight</button>
      <button data-preset="0 9 * * *"      class="preset-btn">Daily at 9 AM</button>
      <button data-preset="0 0 * * 0"      class="preset-btn">Every Sunday</button>
      <button data-preset="0 0 * * 1"      class="preset-btn">Every Monday</button>
      <button data-preset="0 0 1 * *"      class="preset-btn">1st of month</button>
      <button data-preset="*/5 * * * *"    class="preset-btn">Every 5 minutes</button>
      <button data-preset="*/15 * * * *"   class="preset-btn">Every 15 minutes</button>
      <button data-preset="*/30 * * * *"   class="preset-btn">Every 30 minutes</button>
      <button data-preset="0 9-17 * * 1-5" class="preset-btn">Weekdays 9–5</button>
      <button data-preset="0 0 1 1 *"      class="preset-btn">New Year's midnight</button>
    </div>
  </div>

  <!--
    Mobile order (HTML order): builder card → right-col items → FAQ
    Desktop order (CSS grid): builder card (col 1-3 row 1) | right col (col 4-5 rows 1-2)
                                FAQ (col 1-3 row 2)
  -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">

    <!-- BUILDER CARD — col 1-3 row 1 on desktop; first on mobile -->
    <div class="lg:col-span-3">

      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-sm overflow-hidden">

        <!-- PLATFORM TABS — horizontal scroll, scrollbar hidden -->
        <div class="border-b border-gray-200 dark:border-gray-800 flex overflow-x-auto tabs-scroll">
          <button data-platform="linux"  class="platform-tab active-tab">Linux / Unix</button>
          <button data-platform="aws"    class="platform-tab">AWS CloudWatch</button>
          <button data-platform="github" class="platform-tab">GitHub Actions</button>
          <button data-platform="k8s"    class="platform-tab">Kubernetes</button>
        </div>

        <div class="p-4 sm:p-5">
          <!-- Platform hint -->
          <div id="platformHint" class="mb-5 p-3 rounded-lg bg-gray-50 dark:bg-gray-800/50 text-xs text-gray-600 dark:text-gray-400 border border-gray-100 dark:border-gray-700/50 leading-relaxed"></div>

          <!-- VISUAL DROPDOWNS — single column on mobile, flex-wrap on sm+ -->
          <div class="mb-5">
            <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Visual Builder</p>
            <div class="flex flex-col sm:flex-row sm:flex-wrap gap-2.5" id="dropdownGrid">
              <div class="flex flex-col gap-1.5 w-full sm:flex-1 sm:min-w-[90px]">
                <label class="text-xs font-medium text-gray-600 dark:text-gray-400">Minute</label>
                <select id="selMinute" class="cron-select"></select>
              </div>
              <div class="flex flex-col gap-1.5 w-full sm:flex-1 sm:min-w-[90px]">
                <label class="text-xs font-medium text-gray-600 dark:text-gray-400">Hour</label>
                <select id="selHour" class="cron-select"></select>
              </div>
              <div class="flex flex-col gap-1.5 w-full sm:flex-1 sm:min-w-[80px]">
                <label class="text-xs font-medium text-gray-600 dark:text-gray-400">Day</label>
                <select id="selDay" class="cron-select"></select>
              </div>
              <div class="flex flex-col gap-1.5 w-full sm:flex-1 sm:min-w-[90px]">
                <label class="text-xs font-medium text-gray-600 dark:text-gray-400">Month</label>
                <select id="selMonth" class="cron-select"></select>
              </div>
              <div class="flex flex-col gap-1.5 w-full sm:flex-1 sm:min-w-[90px]" id="weekdayCol">
                <label class="text-xs font-medium text-gray-600 dark:text-gray-400">Weekday</label>
                <select id="selWeekday" class="cron-select"></select>
              </div>
              <div class="flex flex-col gap-1.5 w-full sm:flex-1 sm:min-w-[90px] hidden" id="yearCol">
                <label class="text-xs font-medium text-gray-600 dark:text-gray-400">Year</label>
                <select id="selYear" class="cron-select"></select>
              </div>
            </div>
          </div>

          <!-- EXPRESSION INPUT -->
          <div class="mb-4">
            <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Expression</p>
            <div class="flex gap-2">
              <input id="cronInput" type="text" spellcheck="false"
                class="flex-1 min-w-0 font-mono text-sm bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-2.5 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/40 focus:border-indigo-500 transition-all placeholder:text-gray-400 dark:placeholder:text-gray-600"
                placeholder="* * * * *" />
              <button id="copyBtn"
                class="shrink-0 h-10 px-4 bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white text-sm font-medium rounded-xl flex items-center gap-2 transition-colors whitespace-nowrap">
                <svg id="copyIcon" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                </svg>
                <span id="copyLabel">Copy</span>
              </button>
            </div>
            <p id="cronError" class="mt-2 text-xs text-red-500 dark:text-red-400 hidden"></p>
          </div>

          <!-- PLATFORM CODE OUTPUT -->
          <div id="platformOutput" class="hidden">
            <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">Platform Format</p>
            <div class="relative">
              <pre id="platformCode" class="font-mono text-xs bg-gray-950 text-green-400 rounded-xl p-4 overflow-x-auto leading-relaxed whitespace-pre-wrap break-all"></pre>
              <button id="copyPlatformBtn" class="absolute top-2 right-2 text-xs text-gray-400 hover:text-white bg-gray-800 hover:bg-gray-700 px-2.5 py-1 rounded-lg transition-colors">Copy</button>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- RIGHT COLUMN — col 4-5 rows 1-2 on desktop; second on mobile -->
    <div class="lg:col-span-2 lg:row-span-2 space-y-5">

      <!-- PLAIN ENGLISH -->
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-sm p-5">
        <h2 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Plain English</h2>
        <p id="explanation" class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed font-medium min-h-[20px]"></p>
        <div id="fieldBreakdown" class="mt-4 flex gap-2 flex-wrap"></div>
      </div>

      <!-- NEXT RUNS -->
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-sm p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Next 10 Runs</h2>
          <span id="tzLabel" class="text-xs text-gray-400 dark:text-gray-500 font-mono truncate max-w-[140px]"></span>
        </div>
        <ol id="nextRuns" class="space-y-2"></ol>
        <p id="nextRunsEmpty" class="hidden text-xs text-gray-400 dark:text-gray-500 italic">No upcoming runs found in the next 50 years.</p>
      </div>

      <!-- FIELD REFERENCE -->
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-sm p-5">
        <h2 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Field Reference</h2>
        <div class="space-y-2 mb-4">
          <div class="flex items-center gap-3 text-xs">
            <code class="w-14 shrink-0 font-mono text-indigo-600 dark:text-indigo-400 font-semibold bg-indigo-50 dark:bg-indigo-950/50 px-2 py-0.5 rounded text-center">*</code>
            <span class="text-gray-600 dark:text-gray-400">Any / every value</span>
          </div>
          <div class="flex items-center gap-3 text-xs">
            <code class="w-14 shrink-0 font-mono text-indigo-600 dark:text-indigo-400 font-semibold bg-indigo-50 dark:bg-indigo-950/50 px-2 py-0.5 rounded text-center">*/n</code>
            <span class="text-gray-600 dark:text-gray-400">Every nth unit</span>
          </div>
          <div class="flex items-center gap-3 text-xs">
            <code class="w-14 shrink-0 font-mono text-indigo-600 dark:text-indigo-400 font-semibold bg-indigo-50 dark:bg-indigo-950/50 px-2 py-0.5 rounded text-center">a-b</code>
            <span class="text-gray-600 dark:text-gray-400">Range from a to b</span>
          </div>
          <div class="flex items-center gap-3 text-xs">
            <code class="w-14 shrink-0 font-mono text-indigo-600 dark:text-indigo-400 font-semibold bg-indigo-50 dark:bg-indigo-950/50 px-2 py-0.5 rounded text-center">a,b,c</code>
            <span class="text-gray-600 dark:text-gray-400">Specific values list</span>
          </div>
          <div class="flex items-center gap-3 text-xs">
            <code class="w-14 shrink-0 font-mono text-indigo-600 dark:text-indigo-400 font-semibold bg-indigo-50 dark:bg-indigo-950/50 px-2 py-0.5 rounded text-center">a-b/n</code>
            <span class="text-gray-600 dark:text-gray-400">Range with step</span>
          </div>
        </div>
        <div class="border-t border-gray-100 dark:border-gray-800 pt-3">
          <table class="w-full text-xs text-gray-600 dark:text-gray-400">
            <thead><tr class="text-gray-400 dark:text-gray-500 text-left">
              <th class="pb-2 font-medium">Field</th>
              <th class="pb-2 font-medium">Range</th>
            </tr></thead>
            <tbody>
              <tr><td class="py-0.5 font-mono text-indigo-600 dark:text-indigo-400">Minute</td><td>0–59</td></tr>
              <tr><td class="py-0.5 font-mono text-indigo-600 dark:text-indigo-400">Hour</td><td>0–23</td></tr>
              <tr><td class="py-0.5 font-mono text-indigo-600 dark:text-indigo-400">Day</td><td>1–31</td></tr>
              <tr><td class="py-0.5 font-mono text-indigo-600 dark:text-indigo-400">Month</td><td>1–12</td></tr>
              <tr><td class="py-0.5 font-mono text-indigo-600 dark:text-indigo-400">Weekday</td><td>0–7 (0,7=Sun)</td></tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- FAQ — col 1-3 row 2 on desktop; last on mobile -->
    <div class="lg:col-span-3">

      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-sm">
        <div class="p-5 border-b border-gray-200 dark:border-gray-800">
          <h2 class="text-base font-semibold text-gray-900 dark:text-white">Frequently Asked Questions</h2>
        </div>
        <div class="divide-y divide-gray-100 dark:divide-gray-800">

          <div class="faq-item">
            <button class="faq-trigger w-full flex items-center justify-between p-5 text-left gap-3">
              <span class="text-sm font-medium text-gray-900 dark:text-white">What is a cron job?</span>
              <svg class="faq-chevron w-4 h-4 text-gray-400 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-content hidden px-5 pb-5 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              A <strong class="text-gray-800 dark:text-gray-200">cron job</strong> is a scheduled task on Unix-like systems managed by the <em>cron</em> daemon. It automatically runs a command or script at a defined time interval — hourly, daily, weekly, or any custom schedule. Each cron job is defined by a <strong class="text-gray-800 dark:text-gray-200">cron expression</strong>: 5 (or 6) space-separated fields representing minute, hour, day-of-month, month, and day-of-week. Jobs are stored in a file called the <code class="ic">crontab</code> (cron table). Common uses include database backups, log rotation, cache warming, and sending scheduled reports.
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-trigger w-full flex items-center justify-between p-5 text-left gap-3">
              <span class="text-sm font-medium text-gray-900 dark:text-white">How do I generate a cron expression for every 5 minutes?</span>
              <svg class="faq-chevron w-4 h-4 text-gray-400 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-content hidden px-5 pb-5 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Use the step syntax: <code class="ic">*/5 * * * *</code>. The <code class="ic">*/5</code> in the minute field means "every 5th minute" — at :00, :05, :10, :15 … :55. To generate this automatically, select <strong class="text-gray-800 dark:text-gray-200">Every 5 min</strong> from the Minute dropdown above, or click the <strong class="text-gray-800 dark:text-gray-200">Every 5 minutes</strong> preset button. The same step syntax works in any field: <code class="ic">*/2</code> means every 2 units, <code class="ic">*/15</code> means every 15 units.
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-trigger w-full flex items-center justify-between p-5 text-left gap-3">
              <span class="text-sm font-medium text-gray-900 dark:text-white">What is the difference between AWS cron and Linux cron syntax?</span>
              <svg class="faq-chevron w-4 h-4 text-gray-400 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-content hidden px-5 pb-5 text-sm text-gray-600 dark:text-gray-400 leading-relaxed space-y-2">
              <p>AWS EventBridge / CloudWatch uses a <strong class="text-gray-800 dark:text-gray-200">6-field format</strong> that appends a <em>year</em> field: <code class="ic">minute hour day month weekday year</code>. Key differences from Linux crontab:</p>
              <ul class="list-disc list-inside space-y-1 ml-2">
                <li>AWS requires <code class="ic">?</code> in either day-of-month <em>or</em> day-of-week — you cannot set a specific value in both.</li>
                <li>AWS weekdays are <strong>1–7</strong> (Sunday = 1); Linux uses <strong>0–6</strong> (Sunday = 0 or 7).</li>
                <li>AWS does not support <code class="ic">@daily</code>, <code class="ic">@hourly</code>, or other shorthand aliases.</li>
                <li>All AWS cron schedules run in <strong>UTC</strong>.</li>
              </ul>
              <p>Use the <strong class="text-gray-800 dark:text-gray-200">AWS CloudWatch</strong> tab in this generator to convert any Linux expression automatically.</p>
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-trigger w-full flex items-center justify-between p-5 text-left gap-3">
              <span class="text-sm font-medium text-gray-900 dark:text-white">How do I create a Kubernetes cron job schedule?</span>
              <svg class="faq-chevron w-4 h-4 text-gray-400 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-content hidden px-5 pb-5 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Kubernetes CronJobs use standard 5-field cron syntax in the <code class="ic">spec.schedule</code> field of a CronJob manifest. For example, <code class="ic">schedule: "0 9 * * 1-5"</code> runs a job at 9 AM on weekdays. Kubernetes also supports the shorthand aliases <code class="ic">@hourly</code>, <code class="ic">@daily</code>, <code class="ic">@weekly</code>, and <code class="ic">@monthly</code>. Use the <strong class="text-gray-800 dark:text-gray-200">Kubernetes</strong> tab in this cron job generator to get a complete, ready-to-apply CronJob YAML manifest with your schedule pre-filled.
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-trigger w-full flex items-center justify-between p-5 text-left gap-3">
              <span class="text-sm font-medium text-gray-900 dark:text-white">What does */5 mean in a cron expression?</span>
              <svg class="faq-chevron w-4 h-4 text-gray-400 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-content hidden px-5 pb-5 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              The <code class="ic">*/n</code> syntax means "every nth unit starting from the field minimum." The <code class="ic">*</code> expands to the full range and <code class="ic">/n</code> is the step interval. So <code class="ic">*/5</code> in the minute field expands to <code class="ic">0,5,10,15,20,25,30,35,40,45,50,55</code>. You can also step over a range: <code class="ic">8-18/2</code> in the hour field means every 2 hours from 8 AM to 6 PM. This generator supports all step syntax in every field.
            </div>
          </div>

          <div class="faq-item">
            <button class="faq-trigger w-full flex items-center justify-between p-5 text-left gap-3">
              <span class="text-sm font-medium text-gray-900 dark:text-white">How do I run a cron job every weekday at 9 AM?</span>
              <svg class="faq-chevron w-4 h-4 text-gray-400 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-content hidden px-5 pb-5 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Use the expression <code class="ic">0 9 * * 1-5</code>. The <code class="ic">0</code> sets the minute to :00, <code class="ic">9</code> sets the hour to 9 AM, and <code class="ic">1-5</code> in the day-of-week field means Monday through Friday. On AWS EventBridge the equivalent is <code class="ic">cron(0 9 ? * MON-FRI *)</code>. Click the <strong class="text-gray-800 dark:text-gray-200">Weekdays 9–5</strong> preset in this generator as a starting point, then adjust the hour dropdown to narrow it to exactly 9 AM.
            </div>
          </div>

        </div>
      </div>

    </div>

  </div>
</main>

<!-- SEO CONTENT -->
<section class="max-w-6xl mx-auto px-4 pb-20">
  <div class="border-t border-gray-100 dark:border-gray-800 pt-12">

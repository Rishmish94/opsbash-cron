---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is CIDR notation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "CIDR (Classless Inter-Domain Routing) notation is a compact way to express an IP address range. It consists of an IP address followed by a slash and a prefix length — for example, 192.168.1.0/24. The prefix length (0–32 for IPv4, 0–128 for IPv6) indicates how many leading bits in the address are the network portion. CIDR replaced the older class-based system and allows more flexible, efficient allocation of IP address space."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate a subnet mask from CIDR prefix?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To convert a CIDR prefix length to a subnet mask, set that many leading bits to 1 in a 32-bit number. For /24: 11111111.11111111.11111111.00000000 = 255.255.255.0. For /16: 255.255.0.0. For /8: 255.0.0.0. The number of host addresses equals 2 raised to the power of (32 minus the prefix), minus 2 for the network and broadcast addresses."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between IPv4 and IPv6 subnetting?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "IPv4 uses 32-bit addresses (e.g. 192.168.1.0/24) with prefix lengths from /0 to /32, and reserves both a network address and a broadcast address, reducing usable hosts by 2. IPv6 uses 128-bit addresses (e.g. 2001:db8::/32) with prefix lengths from /0 to /128. IPv6 has no broadcast address. The entire range is usable. IPv6 subnets are typically /64, giving each one 2^64 addresses."
      }
    },
    {
      "@type": "Question",
      "name": "How many hosts can a /24 subnet have?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A /24 subnet contains 256 total IP addresses (2^8 = 256). Two addresses are reserved: the network address (e.g. 192.168.1.0) and the broadcast address (e.g. 192.168.1.255). This leaves 254 usable host addresses. A /24 is the most common subnet size for home and small office networks."
      }
    },
    {
      "@type": "Question",
      "name": "How do I plan subnets for an AWS VPC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For an AWS VPC, start with a /16 CIDR block (e.g. 10.0.0.0/16) and split it into tiers: public subnets for load balancers and NAT gateways, private subnets for application servers and ECS tasks, and isolated database subnets for RDS, ElastiCache, and OpenSearch. For high availability, replicate each tier across at least two Availability Zones. Use the AWS VPC Subnet Planner on this page to generate ready-to-use subnet CIDRs for 2, 4, 6, or 8 subnets."
      }
    }
  ]
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to calculate a subnet using CIDR notation",
  "description": "Step by step guide to calculating subnet details from a CIDR block",
  "step": [
    {
      "@type": "HowToStep",
      "name": "Enter your IP and CIDR prefix",
      "text": "Type your IP address and prefix length in the input box, for example 192.168.1.0/24"
    },
    {
      "@type": "HowToStep",
      "name": "View subnet details instantly",
      "text": "The calculator instantly shows network address, broadcast address, subnet mask, and usable host range"
    },
    {
      "@type": "HowToStep",
      "name": "Check total and usable hosts",
      "text": "See the total number of addresses and usable host addresses in the stat cards"
    },
    {
      "@type": "HowToStep",
      "name": "Split your subnet if needed",
      "text": "Use the subnet splitter to divide your CIDR block into 2, 4 or 8 equal subnets"
    },
    {
      "@type": "HowToStep",
      "name": "Plan your AWS VPC",
      "text": "Use the AWS VPC planner to get optimal subnet recommendations for public, private and database tiers"
    }
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "CIDR Calculator — IPv4 & IPv6 Subnet Calculator",
  "url": "https://opsbash.com/cidr-calculator",
  "description": "Calculate subnet details, usable hosts, and split subnets instantly. Supports IPv4 and IPv6. Free online CIDR and subnet calculator for network engineers.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<Layout
  title="CIDR Calculator — IPv4 & IPv6 Subnet Calculator | OpsBash"
  description="Calculate subnet details, usable hosts, and split subnets instantly. Supports IPv4 and IPv6. Free online CIDR and subnet calculator for network engineers."
  canonicalURL="https://opsbash.com/cidr-calculator"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

<!-- ── PAGE CONTENT ───────────────────────────────────────────────────────────── -->
<div style="background: var(--bg);">
<div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">

  <!-- HERO -->
  <section class="pt-8 pb-5">
    <div class="inline-flex items-center gap-2 text-xs font-medium px-3 py-1.5 rounded-full mb-4"
         style="background: rgba(16,185,129,0.1); color: #34d399; border: 1px solid rgba(16,185,129,0.2);">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
      </svg>
      Free CIDR &amp; Subnet Calculator
    </div>
    <h1 class="text-3xl sm:text-4xl font-bold mb-3 tracking-tight hero-gradient">
      CIDR &amp; Subnet Calculator
    </h1>
    <p class="text-base max-w-xl" style="color: var(--fg2);">
      Calculate subnet details, usable hosts, and split CIDRs instantly. Supports both IPv4 and IPv6. No sign-up required, runs entirely in your browser.
    </p>
  </section>

  <!-- INPUT -->
  <section class="pb-5">
    <div class="rounded-[14px] p-5" style="background: var(--card); border: 1px solid var(--border);">
      <label class="text-xs font-semibold uppercase tracking-wider mb-2 block" style="color: var(--fg3);">IP / CIDR Notation</label>
      <div class="relative flex gap-3 items-center">
        <input id="cidrInput" type="text" spellcheck="false" autocomplete="off"
          class="flex-1 min-w-0 rounded-xl px-4 py-3 transition-all focus:outline-none"
          style="font-family:'Fira Code','Cascadia Code',monospace; font-size:16px; letter-spacing:0.05em; color:#34d399; background:var(--bg); border:1px solid #10b981; box-shadow:0 0 0 3px rgba(16,185,129,0.12), 0 0 20px rgba(16,185,129,0.08);"
          placeholder="192.168.1.0/24 or 2001:db8::/32" />
        <span id="ipvBadge" class="hidden shrink-0 text-[10px] font-bold px-2.5 py-1 rounded-full"
              style="background:rgba(16,185,129,0.15); color:#34d399;"></span>
      </div>
      <p id="cidrError" class="mt-2 text-xs text-red-500 hidden"></p>
    </div>
  </section>

  <!-- STAT CARDS -->
  <section class="pb-5">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="stat-card">
        <div class="stat-label">Total Hosts</div>
        <div id="statTotal" class="stat-value" style="color:#34d399; font-family:'Fira Code',monospace;">—</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Usable Hosts</div>
        <div id="statUsable" class="stat-value" style="color:#34d399; font-family:'Fira Code',monospace;">—</div>
      </div>
      <div class="stat-card">
        <div class="stat-label" id="statClassLabel">Network Class</div>
        <div id="statClass" class="stat-value" style="color:#34d399;">—</div>
      </div>
    </div>
  </section>

  <!-- SUBNET DETAILS + INFO PANEL -->
  <section class="pb-5" id="detailsSection">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">

      <!-- Details -->
      <div class="rounded-[14px] overflow-hidden" style="background:var(--card); border:1px solid var(--border);">
        <div class="px-5 pt-4 pb-3" style="border-bottom:1px solid var(--border); background:var(--bg);">
          <h2 class="text-xs font-semibold uppercase tracking-wider" style="color:var(--fg2);">Subnet Details</h2>
        </div>
        <div id="detailRows"></div>
      </div>

      <!-- Binary / Info -->
      <div class="rounded-[14px] overflow-hidden" style="background:var(--card); border:1px solid var(--border);">
        <div class="px-5 pt-4 pb-3" style="border-bottom:1px solid var(--border); background:var(--bg);">
          <h2 class="text-xs font-semibold uppercase tracking-wider" id="infoCardTitle" style="color:var(--fg2);">Binary Representation</h2>
        </div>
        <div id="infoCard" class="p-5"></div>
      </div>

    </div>
  </section>

  <!-- SUBNET SPLITTER -->
  <section class="pb-5">
    <div class="rounded-[14px] overflow-hidden" style="background:var(--card); border:1px solid var(--border);">
      <div class="px-5 pt-4 pb-3" style="border-bottom:1px solid var(--border); background:var(--bg);">
        <h2 class="text-sm font-semibold" style="color:var(--fg);">Visual Subnet Splitter</h2>
        <p class="text-xs mt-0.5" style="color:var(--fg2);">Split a CIDR block into 2, 4, or 8 equal subnets. Works for IPv4 and IPv6.</p>
      </div>
      <div class="p-5">
        <div class="flex flex-col sm:flex-row gap-3 mb-4">
          <input id="splitInput" type="text" spellcheck="false" autocomplete="off"
            class="flex-1 min-w-0 rounded-xl px-4 py-2.5 text-sm focus:outline-none transition-all"
            style="font-family:'Fira Code',monospace; background:var(--bg); border:1px solid var(--border); color:var(--fg);"
            placeholder="10.0.0.0/16" />
          <div class="flex gap-2 shrink-0">
            <button class="split-count-btn active-split-btn" data-count="2">÷ 2</button>
            <button class="split-count-btn" data-count="4">÷ 4</button>
            <button class="split-count-btn" data-count="8">÷ 8</button>
          </div>
        </div>
        <p id="splitError" class="text-xs text-red-500 mb-3 hidden"></p>
        <div id="splitResults"></div>
      </div>
    </div>
  </section>

  <!-- VPC PLANNER -->
  <section class="pb-5">
    <div class="rounded-[14px] overflow-hidden" style="background:var(--card); border:1px solid var(--border);">
      <div class="px-5 pt-4 pb-3" style="border-bottom:1px solid var(--border); background:var(--bg);">
        <h2 class="text-sm font-semibold" style="color:var(--fg);">AWS VPC Subnet Planner</h2>
        <p class="text-xs mt-0.5" style="color:var(--fg2);">Optimal subnet splits for public, private, and database tiers across Availability Zones.</p>
      </div>
      <div class="p-5">
        <div class="flex flex-col sm:flex-row gap-3 mb-4 flex-wrap">
          <input id="vpcInput" type="text" spellcheck="false" autocomplete="off"
            class="flex-1 min-w-0 rounded-xl px-4 py-2.5 text-sm focus:outline-none transition-all"
            style="font-family:'Fira Code',monospace; background:var(--bg); border:1px solid var(--border); color:var(--fg);"
            placeholder="10.0.0.0/16" />
          <div class="flex gap-2 flex-wrap shrink-0">
            <button class="vpc-count-btn active-vpc-btn" data-count="2">2 subnets</button>
            <button class="vpc-count-btn" data-count="4">4 subnets</button>
            <button class="vpc-count-btn" data-count="6">6 subnets</button>
            <button class="vpc-count-btn" data-count="8">8 subnets</button>
          </div>
        </div>
        <p id="vpcError" class="text-xs text-red-500 mb-3 hidden"></p>
        <div id="vpcResults"></div>
      </div>
    </div>
  </section>

  <!-- COMMON EXAMPLES -->
  <section class="pb-5">
    <div class="rounded-[14px] overflow-hidden" style="background:var(--card); border:1px solid var(--border);">
      <div class="px-5 pt-4 pb-3" style="border-bottom:1px solid var(--border); background:var(--bg);">
        <h2 class="text-sm font-semibold" style="color:var(--fg);">Common Examples</h2>
        <p class="text-xs mt-0.5" style="color:var(--fg2);">Click any example to load it into the calculator above.</p>
      </div>
      <div class="p-5">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          <button class="example-card" data-cidr="192.168.1.0/24">
            <code class="example-cidr">192.168.1.0/24</code>
            <span class="example-desc">Home network — 254 usable hosts</span>
          </button>
          <button class="example-card" data-cidr="10.0.0.0/8">
            <code class="example-cidr">10.0.0.0/8</code>
            <span class="example-desc">Private Class A — 16.7M hosts</span>
          </button>
          <button class="example-card" data-cidr="172.16.0.0/12">
            <code class="example-cidr">172.16.0.0/12</code>
            <span class="example-desc">Private Class B — 1M hosts</span>
          </button>
          <button class="example-card" data-cidr="10.0.0.0/16">
            <code class="example-cidr">10.0.0.0/16</code>
            <span class="example-desc">AWS VPC typical — 65,534 hosts</span>
          </button>
          <button class="example-card" data-cidr="192.168.0.0/16">
            <code class="example-cidr">192.168.0.0/16</code>
            <span class="example-desc">Private Class B small — 65,534 hosts</span>
          </button>
          <button class="example-card" data-cidr="2001:db8::/32">
            <code class="example-cidr">2001:db8::/32</code>
            <span class="example-desc">IPv6 documentation range</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- USABLE HOSTS LIST -->
  <section class="pb-5" id="hostsSection">
    <div class="rounded-[14px] overflow-hidden" style="background:var(--card); border:1px solid var(--border);">
      <div class="px-5 pt-4 pb-3 flex items-center justify-between flex-wrap gap-2"
           style="border-bottom:1px solid var(--border); background:var(--bg);">
        <h2 class="text-xs font-semibold uppercase tracking-wider" style="color:var(--fg2);">Usable Hosts</h2>
        <span id="hostCountNote" class="text-[11px]" style="color:var(--fg3);"></span>
      </div>
      <div class="p-5">
        <div id="hostsTable"></div>
        <div id="hostsPagination" class="flex gap-2 mt-4 flex-wrap"></div>
      </div>
    </div>
  </section>

  <!-- SECTION 1: What is CIDR Notation? -->
  <section class="pb-5" id="what-is-cidr">
    <div class="rounded-[14px] overflow-hidden" style="background: var(--card); border: 1px solid var(--border);">
      <div class="px-5 pt-4 pb-3" style="border-bottom: 1px solid var(--border); background: var(--bg);">
        <h2 class="text-sm font-semibold" style="color: var(--fg);">What is CIDR Notation?</h2>
      </div>
      <div class="p-5">
        <p class="seo-p">CIDR (Classless Inter-Domain Routing) notation represents an IP address and its network prefix length in the format IP/prefix, for example 192.168.1.0/24. The prefix number indicates how many bits are used for the network portion, with the remaining bits available for host addresses.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 2: How to Calculate Subnet Size -->
  <section class="pb-5" id="subnet-size-calculator">
    <div class="rounded-[14px] overflow-hidden" style="background: var(--card); border: 1px solid var(--border);">
      <div class="px-5 pt-4 pb-3" style="border-bottom: 1px solid var(--border); background: var(--bg);">
        <h2 class="text-sm font-semibold" style="color: var(--fg);">How to Calculate Subnet Size from CIDR</h2>
      </div>
      <div class="p-5">
        <p class="seo-p">The number of total addresses in a subnet equals 2 raised to the power of the host bits (32 minus the prefix for IPv4). For example, a /24 subnet has 2^8 = 256 total addresses and 254 usable hosts after subtracting the network and broadcast addresses.</p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr style="background: rgba(16,185,129,0.1); text-align: left;">
                <th class="seo-th">CIDR Prefix</th>
                <th class="seo-th">Total Addresses</th>
                <th class="seo-th">Usable Hosts</th>
                <th class="seo-th hidden sm:table-cell">Common Use</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:#34d399;">/8</td>
                <td class="seo-td" style="color:var(--fg2);">16,777,216</td>
                <td class="seo-td" style="color:var(--fg2);">16,777,214</td>
                <td class="seo-td hidden sm:table-cell" style="color:var(--fg3);">Large private network (Class A)</td>
              </tr>
              <tr>
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:#34d399;">/12</td>
                <td class="seo-td" style="color:var(--fg2);">1,048,576</td>
                <td class="seo-td" style="color:var(--fg2);">1,048,574</td>
                <td class="seo-td hidden sm:table-cell" style="color:var(--fg3);">Medium private network (Class B)</td>
              </tr>
              <tr>
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:#34d399;">/16</td>
                <td class="seo-td" style="color:var(--fg2);">65,536</td>
                <td class="seo-td" style="color:var(--fg2);">65,534</td>
                <td class="seo-td hidden sm:table-cell" style="color:var(--fg3);">AWS VPC typical size</td>
              </tr>
              <tr>
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:#34d399;">/20</td>
                <td class="seo-td" style="color:var(--fg2);">4,096</td>
                <td class="seo-td" style="color:var(--fg2);">4,094</td>
                <td class="seo-td hidden sm:table-cell" style="color:var(--fg3);">AWS subnet typical size</td>
              </tr>
              <tr>
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:#34d399;">/24</td>
                <td class="seo-td" style="color:var(--fg2);">256</td>
                <td class="seo-td" style="color:var(--fg2);">254</td>
                <td class="seo-td hidden sm:table-cell" style="color:var(--fg3);">Home and small office network</td>
              </tr>
              <tr>
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:#34d399;">/28</td>
                <td class="seo-td" style="color:var(--fg2);">16</td>
                <td class="seo-td" style="color:var(--fg2);">14</td>
                <td class="seo-td hidden sm:table-cell" style="color:var(--fg3);">Small AWS subnet</td>
              </tr>
              <tr>
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:#34d399;">/30</td>
                <td class="seo-td" style="color:var(--fg2);">4</td>
                <td class="seo-td" style="color:var(--fg2);">2</td>
                <td class="seo-td hidden sm:table-cell" style="color:var(--fg3);">Point-to-point links</td>
              </tr>
              <tr>
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:#34d399;">/32</td>
                <td class="seo-td" style="color:var(--fg2);">1</td>
                <td class="seo-td" style="color:var(--fg2);">0</td>
                <td class="seo-td hidden sm:table-cell" style="color:var(--fg3);">Single host route</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: RFC 1918 Private IP Ranges -->
  <section class="pb-5" id="rfc1918-private-ranges">
    <div class="rounded-[14px] overflow-hidden" style="background: var(--card); border: 1px solid var(--border);">
      <div class="px-5 pt-4 pb-3" style="border-bottom: 1px solid var(--border); background: var(--bg);">
        <h2 class="text-sm font-semibold" style="color: var(--fg);">RFC 1918 Private IP Address Ranges</h2>
      </div>
      <div class="p-5">
        <p class="seo-p">RFC 1918 defines three private IP address ranges that are not routable on the public internet. These ranges are used for internal networks, cloud VPCs, and home networks.</p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr style="background: rgba(16,185,129,0.1); text-align: left;">
                <th class="seo-th">Range</th>
                <th class="seo-th">Subnet Mask</th>
                <th class="seo-th">Total Hosts</th>
                <th class="seo-th hidden sm:table-cell">Common Use</th>
              </tr>
            </thead>
            <tbody>
              <tr class="rfc-row" data-cidr="10.0.0.0/8" style="cursor: pointer;">
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:#34d399;">10.0.0.0/8</td>
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:var(--fg2);">255.0.0.0</td>
                <td class="seo-td" style="color:var(--fg2);">16,777,214</td>
                <td class="seo-td hidden sm:table-cell" style="color:var(--fg3);">Large enterprise networks</td>
              </tr>
              <tr class="rfc-row" data-cidr="172.16.0.0/12" style="cursor: pointer;">
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:#34d399;">172.16.0.0/12</td>
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:var(--fg2);">255.240.0.0</td>
                <td class="seo-td" style="color:var(--fg2);">1,048,574</td>
                <td class="seo-td hidden sm:table-cell" style="color:var(--fg3);">Medium networks</td>
              </tr>
              <tr class="rfc-row" data-cidr="192.168.0.0/16" style="cursor: pointer;">
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:#34d399;">192.168.0.0/16</td>
                <td class="seo-td" style="font-family:'Fira Code',monospace; color:var(--fg2);">255.255.0.0</td>
                <td class="seo-td" style="color:var(--fg2);">65,534</td>
                <td class="seo-td hidden sm:table-cell" style="color:var(--fg3);">Home and small office</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="seo-p text-xs mt-3" style="color: var(--fg3);">Click any range to load it into the calculator above.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 4: AWS VPC Subnetting Guide -->
  <section class="pb-5" id="aws-vpc-subnetting">

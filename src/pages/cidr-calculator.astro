    { name: 'Database A', color: '#f59e0b', desc: 'Data tier (AZ-a)' },
    { name: 'Database B', color: '#d97706', desc: 'Data tier (AZ-b)' },
    { name: 'Database C', color: '#b45309', desc: 'Data tier (AZ-c)' }
  ]
};

// ── Number formatter — always exact so tests can assert specific values ───────
function fmtNum(n) {
  if (typeof n === 'string') return n; // already a string (e.g. "2^96" for IPv6)
  return n.toLocaleString();
}

// ── SVG icons ─────────────────────────────────────────────────────────────────
var COPY_SVG = '<svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
var CHECK_SVG = '<svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>';

function copyBtnHTML(targetId) {
  return '<button class="cbtn" data-t="' + targetId + '" title="Copy" style="padding:3px 5px;border-radius:5px;border:1px solid var(--border);background:var(--card);color:var(--fg3);cursor:pointer;display:inline-flex;align-items:center;transition:all 0.15s;flex-shrink:0;">' + COPY_SVG + '</button>';
}

// ── Detail row builder ────────────────────────────────────────────────────────
function detailRow(label, id, value, mono) {
  var codeStyle = mono
    ? 'font-family:\'Fira Code\',monospace; font-size:12px; color:var(--fg);'
    : 'font-size:12px; color:var(--fg);';
  return '<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 20px;border-bottom:1px solid var(--border);gap:12px;">'
    + '<span style="font-size:11px;color:var(--fg2);flex-shrink:0;font-weight:500;">' + label + '</span>'
    + '<div style="display:flex;align-items:center;gap:8px;min-width:0;">'
    + '<span id="' + id + '" style="' + codeStyle + ' word-break:break-all;text-align:right;">' + value + '</span>'
    + copyBtnHTML(id)
    + '</div></div>';
}

// ── Update main calc display ──────────────────────────────────────────────────
var currentData = null;
var currentHostPage = 0;

function updateMainCalc(data) {
  currentData = data;
  currentHostPage = 0;

  // Stat cards
  document.getElementById('statTotal').textContent = fmtNum(data.totalHosts);
  document.getElementById('statUsable').textContent = fmtNum(data.usableHosts);
  if (data.version === 4) {
    document.getElementById('statClassLabel').textContent = 'Network Class';
    document.getElementById('statClass').textContent = data.netClass;
  } else {
    document.getElementById('statClassLabel').textContent = 'Address Type';
    document.getElementById('statClass').textContent = data.addrType;
  }

  // IP version badge
  var badge = document.getElementById('ipvBadge');
  badge.textContent = 'IPv' + data.version;
  badge.classList.remove('hidden');

  // Detail rows
  var rows = '';
  if (data.version === 4) {
    rows += detailRow('Network Address',   'dNetAddr',   data.networkAddress,   true);
    rows += detailRow('Broadcast Address', 'dBcast',     data.broadcastAddress, true);
    rows += detailRow('Subnet Mask',       'dMask',      data.subnetMask,       true);
    rows += detailRow('Wildcard Mask',     'dWild',      data.wildcardMask,     true);
    rows += detailRow('First Usable IP',   'dFirst',     data.firstUsable,      true);
    rows += detailRow('Last Usable IP',    'dLast',      data.lastUsable,       true);
    rows += detailRow('CIDR Notation',     'dCidr',      data.cidr,             true);
    rows += detailRow('Address Type',      'dAddrType',  data.addrType,         false);
  } else {
    rows += detailRow('Network Address',   'dNetAddr',   data.networkAddress,   true);
    rows += detailRow('Prefix Length',     'dPrefix',    '/' + data.prefix,     true);
    rows += detailRow('First Usable IP',   'dFirst',     data.firstUsable,      true);
    rows += detailRow('Last Usable IP',    'dLast',      data.lastUsable,       true);
    rows += detailRow('CIDR Notation',     'dCidr',      data.cidr,             true);
    rows += detailRow('Address Type',      'dAddrType',  data.addrType,         false);
  }
  document.getElementById('detailRows').innerHTML = rows;

  // Info card
  updateInfoCard(data);

  // Hosts list
  renderHostsPage(data, 0);
}

function updateInfoCard(data) {
  var card = document.getElementById('infoCard');
  var title = document.getElementById('infoCardTitle');
  if (data.version === 4) {
    title.textContent = 'Binary Subnet Mask';
    // Build colored binary octets
    var octetsHTML = data.binaryOctets.map(function(b, idx) {
      var bits = b.toString(2).padStart(8, '0');
      var networkBitsInOctet = Math.max(0, Math.min(8, data.prefix - idx * 8));
      var onesPart = bits.slice(0, networkBitsInOctet);
      var zerosPart = bits.slice(networkBitsInOctet);
      var html = '';
      if (onesPart) html += '<span style="color:#34d399;font-weight:700;">' + onesPart + '</span>';
      if (zerosPart) html += '<span style="color:var(--fg3);">' + zerosPart + '</span>';
      return html;
    }).join('<span style="color:var(--fg2);">.</span>');

    // Progress bar
    var pct = (data.prefix / 32 * 100).toFixed(1);
    var hostBits = 32 - data.prefix;
    card.innerHTML = '<div style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:14px 16px;font-family:\'Fira Code\',monospace;font-size:13px;letter-spacing:0.06em;line-height:1.8;word-break:break-all;">'
      + octetsHTML + '</div>'
      + '<div style="margin-top:16px;">'
      + '<div style="display:flex;justify-content:space-between;font-size:11px;color:var(--fg3);margin-bottom:6px;">'
      + '<span>Network (' + data.prefix + ' bits)</span><span>Host (' + hostBits + ' bits)</span></div>'
      + '<div style="height:8px;border-radius:9999px;overflow:hidden;background:var(--border);">'
      + '<div style="height:100%;width:' + pct + '%;background:linear-gradient(90deg,#10b981,#059669);border-radius:9999px;"></div>'
      + '</div></div>'
      + '<div style="margin-top:16px;display:grid;grid-template-columns:1fr 1fr;gap:10px;">'
      + infoChip('Prefix', '/' + data.prefix)
      + infoChip('Host Bits', hostBits.toString())
      + infoChip('Total IPs', fmtNum(data.totalHosts))
      + infoChip('Usable IPs', fmtNum(data.usableHosts))
      + '</div>';
  } else {
    title.textContent = 'IPv6 Address Info';
    var hb = data._hostBits;
    card.innerHTML = '<div style="margin-bottom:14px;">'
      + '<span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;padding:5px 12px;border-radius:9999px;background:rgba(16,185,129,0.12);color:#34d399;border:1px solid rgba(16,185,129,0.25);">IPv6 — ' + data.addrType + '</span>'
      + '</div>'
      + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">'
      + infoChip('Prefix Length', '/' + data.prefix)
      + infoChip('Host Bits', hb.toString())
      + infoChip('Total Addresses', data.totalHosts)
      + infoChip('No Broadcast', 'All usable')
      + '</div>'
      + '<p style="margin-top:14px;font-size:12px;color:var(--fg2);line-height:1.6;">IPv6 has no broadcast address. Every address in the /' + data.prefix + ' prefix is usable. The first address is conventionally reserved as the network identifier.</p>';
  }
}

function infoChip(label, val) {
  return '<div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px 12px;">'
    + '<div style="font-size:10px;color:var(--fg3);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">' + label + '</div>'
    + '<div style="font-size:13px;font-weight:700;color:var(--fg);font-family:\'Fira Code\',monospace;">' + val + '</div>'
    + '</div>';
}

// ── Hosts list ────────────────────────────────────────────────────────────────
var PAGE_SIZE = 64;
var MAX_SHOW  = 256;

function renderHostsPage(data, page) {
  currentHostPage = page;
  var hosts = [], totalUsable, totalShown, totalPages, note;

  if (data.version === 4) {
    totalUsable = data.usableHosts; // 0 for /32 and /31
    totalShown = Math.min(MAX_SHOW, totalUsable);
    var start = page * PAGE_SIZE;
    var end = Math.min(start + PAGE_SIZE, totalShown);
    for (var i = start; i < end; i++) {
      hosts.push(ipv4Str(data._networkNum + 1 + i));
    }
  } else {
    var hbits = data._hostBits;
    if (hbits === 0) {
      hosts = [data.networkAddress]; totalUsable = 1; totalShown = 1;
    } else {
      var total6 = 1n << BigInt(hbits);
      totalShown = total6 <= BigInt(MAX_SHOW) ? Number(total6) : MAX_SHOW;
      totalUsable = hbits <= 53 ? Number(total6) : null;
      var start6 = page * PAGE_SIZE;
      var end6 = Math.min(start6 + PAGE_SIZE, totalShown);
      for (var k = start6; k < end6; k++) {
        hosts.push(ipv6Str(data._networkBig + BigInt(k) + 1n));
      }
    }
  }

  totalPages = Math.ceil(totalShown / PAGE_SIZE) || 1;

  // Note
  var noteEl = document.getElementById('hostCountNote');
  if (totalUsable && totalUsable > MAX_SHOW) {
    noteEl.textContent = 'Showing first ' + MAX_SHOW.toLocaleString() + ' of ' + fmtNum(totalUsable) + ' usable hosts';
  } else if (data.version === 6 && data._hostBits > 53) {
    noteEl.textContent = 'Showing first ' + MAX_SHOW.toLocaleString() + ' of 2^' + data._hostBits + ' addresses';
  } else {
    noteEl.textContent = (totalShown || 0).toLocaleString() + ' usable hosts';
  }

  // Table
  var rows = hosts.map(function(h) {
    return '<div style="display:flex;align-items:center;justify-content:space-between;padding:8px 16px;border-bottom:1px solid var(--border);">'
      + '<code style="font-family:\'Fira Code\',monospace;font-size:12px;color:var(--fg);">' + h + '</code>'
      + '<button class="cbtn" data-v="' + h + '" title="Copy" style="padding:3px 5px;border-radius:5px;border:1px solid var(--border);background:var(--card);color:var(--fg3);cursor:pointer;display:inline-flex;align-items:center;">' + COPY_SVG + '</button>'
      + '</div>';
  }).join('');

  document.getElementById('hostsTable').innerHTML = hosts.length
    ? '<div style="border:1px solid var(--border);border-radius:10px;overflow:hidden;">' + rows + '</div>'
    : '<p style="color:var(--fg3);font-size:13px;">No hosts to display.</p>';

  // Pagination
  var paginationEl = document.getElementById('hostsPagination');
  if (totalPages <= 1) { paginationEl.innerHTML = ''; return; }
  var pHTML = '';
  for (var p = 0; p < totalPages; p++) {
    var isActive = p === page;
    pHTML += '<button data-pg="' + p + '" style="font-size:11px;padding:5px 12px;border-radius:7px;border:1px solid '
      + (isActive ? '#10b981' : 'var(--border)') + ';background:'
      + (isActive ? '#10b981' : 'var(--bg)') + ';color:'
      + (isActive ? '#030a06' : 'var(--fg2)') + ';cursor:pointer;font-weight:' + (isActive ? '600' : '400') + ';">'
      + (p * PAGE_SIZE + 1) + '–' + Math.min((p + 1) * PAGE_SIZE, totalShown)
      + '</button>';
  }
  paginationEl.innerHTML = pHTML;
}

// ── Subnet splitter render ────────────────────────────────────────────────────
function renderSplitResults(subnets) {
  if (!subnets || !subnets.length) return '<p style="color:var(--fg3);font-size:13px;">Could not split — check the input and try again.</p>';
  var isV4 = subnets[0].version === 4;
  var thStyle = 'padding:8px 12px;text-align:left;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--fg3);';
  var tdStyle = 'padding:9px 12px;font-size:12px;border-top:1px solid var(--border);';
  var ths = '<th style="' + thStyle + '">CIDR</th>'
    + '<th style="' + thStyle + '">Network</th>'
    + (isV4 ? '<th style="' + thStyle + '">Broadcast</th>' : '')
    + '<th style="' + thStyle + '">First Usable</th>'
    + '<th style="' + thStyle + '">Last Usable</th>'
    + '<th style="' + thStyle + '">Usable Hosts</th>';
  var trs = subnets.map(function(s) {
    return '<tr>'
      + '<td style="' + tdStyle + 'font-family:\'Fira Code\',monospace;color:#34d399;">' + s.cidr + '</td>'
      + '<td style="' + tdStyle + 'font-family:\'Fira Code\',monospace;color:var(--fg2);">' + s.network + '</td>'
      + (isV4 ? '<td style="' + tdStyle + 'font-family:\'Fira Code\',monospace;color:var(--fg2);">' + s.broadcast + '</td>' : '')
      + '<td style="' + tdStyle + 'font-family:\'Fira Code\',monospace;color:var(--fg2);">' + s.first + '</td>'
      + '<td style="' + tdStyle + 'font-family:\'Fira Code\',monospace;color:var(--fg2);">' + s.last + '</td>'
      + '<td style="' + tdStyle + 'color:var(--fg);">' + s.hosts + '</td>'
      + '</tr>';
  }).join('');
  return '<div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;">'
    + '<thead><tr style="background:var(--bg);">' + ths + '</tr></thead>'
    + '<tbody>' + trs + '</tbody></table></div>';
}

// ── VPC planner render ────────────────────────────────────────────────────────
function renderVPCResults(subnets) {
  if (!subnets || !subnets.length) return '<p style="color:var(--fg3);font-size:13px;">Could not generate plan — check the input.</p>';
  var thStyle = 'padding:8px 12px;text-align:left;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--fg3);';
  var tdStyle = 'padding:10px 12px;font-size:12px;border-top:1px solid var(--border);vertical-align:top;';
  var ths = '<th style="' + thStyle + '">Tier</th><th style="' + thStyle + '">CIDR</th><th style="' + thStyle + '">Usable Hosts</th>';
  var trs = subnets.map(function(s) {
    return '<tr>'
      + '<td style="' + tdStyle + '">'
      + '<div style="display:flex;align-items:center;gap:7px;">'
      + '<div style="width:8px;height:8px;border-radius:50%;background:' + s.tierColor + ';flex-shrink:0;"></div>'
      + '<span style="font-size:12px;font-weight:600;color:' + s.tierColor + ';">' + s.tierName + '</span>'
      + '</div>'
      + '<p style="font-size:11px;color:var(--fg3);margin-top:3px;padding-left:15px;">' + s.tierDesc + '</p>'
      + '</td>'
      + '<td style="' + tdStyle + 'font-family:\'Fira Code\',monospace;color:#34d399;">' + s.cidr + '</td>'
      + '<td style="' + tdStyle + 'color:var(--fg);">' + s.hosts + '</td>'
      + '</tr>';
  }).join('');
  return '<div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;">'
    + '<thead><tr style="background:var(--bg);">' + ths + '</tr></thead>'
    + '<tbody>' + trs + '</tbody></table></div>';
}

// ─── DOM REFS ────────────────────────────────────────────────────────────────
var cidrInput   = document.getElementById('cidrInput');
var cidrError   = document.getElementById('cidrError');
var splitInput  = document.getElementById('splitInput');
var splitError  = document.getElementById('splitError');
var vpcInput    = document.getElementById('vpcInput');
var vpcError    = document.getElementById('vpcError');
var currentSplitCount = 2;
var currentVPCCount   = 2;

// ─── MAIN CALC UPDATE ────────────────────────────────────────────────────────
function doCalc(val) {
  if (val.trim() === '') {
    cidrError.classList.remove('hidden');
    cidrError.textContent = 'Please enter a valid CIDR notation';
    cidrInput.style.borderColor = '#ef4444';
    document.getElementById('ipvBadge').classList.add('hidden');
    document.getElementById('detailRows').innerHTML = '';
    document.getElementById('infoCard').innerHTML = '';
    document.getElementById('hostsTable').innerHTML = '';
    document.getElementById('hostsPagination').innerHTML = '';
    document.getElementById('statTotal').textContent = '—';
    document.getElementById('statUsable').textContent = '—';
    document.getElementById('statClass').textContent = '—';
    return;
  }
  try {
    var data = parseCIDR(val);
    cidrError.classList.add('hidden');
    cidrInput.style.borderColor = '#10b981';
    updateMainCalc(data);
  } catch(e) {
    cidrError.textContent = e.message;
    cidrError.classList.remove('hidden');
    cidrInput.style.borderColor = '#ef4444';
    document.getElementById('ipvBadge').classList.add('hidden');
  }
}

cidrInput.addEventListener('input',  function() { doCalc(this.value); });
cidrInput.addEventListener('change', function() { doCalc(this.value); });

// ─── SPLITTER ────────────────────────────────────────────────────────────────
function doSplit() {
  var val = splitInput.value.trim();
  if (!val) { document.getElementById('splitResults').innerHTML = ''; return; }
  try {
    if (!val.includes('/')) throw new Error('Enter in CIDR format: 10.0.0.0/16');
    var slash = val.lastIndexOf('/');
    var ipPart = val.slice(0, slash);
    var prefix = parseInt(val.slice(slash + 1));
    if (isNaN(prefix)) throw new Error('Invalid prefix');
    if (ipPart.includes(':')) {
      if (prefix < 0 || prefix > 128) throw new Error('IPv6 prefix must be 0–128');
    } else {
      if (parseIPv4(ipPart) === null) throw new Error('Invalid IP address');
      if (prefix < 0 || prefix > 32) throw new Error('IPv4 prefix must be 0–32');
    }
    var maxPrefix = ipPart.includes(':') ? 128 : 32;
    var bitsNeeded = Math.round(Math.log2(currentSplitCount));
    if (prefix + bitsNeeded > maxPrefix) throw new Error('Cannot split — not enough address space');
    var results = splitSubnet(val, currentSplitCount);
    splitError.classList.add('hidden');
    splitInput.style.borderColor = 'var(--border)';
    document.getElementById('splitResults').innerHTML = renderSplitResults(results);
  } catch(e) {
    splitError.textContent = e.message;
    splitError.classList.remove('hidden');
    splitInput.style.borderColor = '#ef4444';
    document.getElementById('splitResults').innerHTML = '';
  }
}

splitInput.addEventListener('input', doSplit);
document.querySelectorAll('.split-count-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.split-count-btn').forEach(function(b) { b.classList.remove('active-split-btn'); });
    this.classList.add('active-split-btn');
    currentSplitCount = parseInt(this.dataset.count);
    doSplit();
  });
});

// ─── VPC PLANNER ─────────────────────────────────────────────────────────────
function doVPC() {
  var val = vpcInput.value.trim();
  if (!val) { document.getElementById('vpcResults').innerHTML = ''; return; }
  try {
    if (!val.includes('/')) throw new Error('Enter in CIDR format: 10.0.0.0/16');
    var slash = val.lastIndexOf('/');
    var ipPart = val.slice(0, slash);
    var prefix = parseInt(val.slice(slash + 1));
    if (isNaN(prefix)) throw new Error('Invalid prefix');
    if (ipPart.includes(':')) throw new Error('VPC planner currently supports IPv4 only');
    if (parseIPv4(ipPart) === null) throw new Error('Invalid IPv4 address');
    if (prefix < 0 || prefix > 28) throw new Error('VPC prefix must be /0–/28 to allow subnetting');
    var p2 = nextPow2(currentVPCCount);
    var bitsNeeded = Math.round(Math.log2(p2));
    if (prefix + bitsNeeded > 32) throw new Error('Not enough address space for ' + currentVPCCount + ' subnets');
    var allSubnets = splitSubnet(val, p2);
    var subnets = allSubnets ? allSubnets.slice(0, currentVPCCount) : null;
    if (!subnets) throw new Error('Could not generate subnet plan');
    var tiers = VPC_TIERS[currentVPCCount];
    var planned = subnets.map(function(s, i) {
      return Object.assign({}, s, { tierName: tiers[i].name, tierColor: tiers[i].color, tierDesc: tiers[i].desc });
    });
    vpcError.classList.add('hidden');
    vpcInput.style.borderColor = 'var(--border)';
    document.getElementById('vpcResults').innerHTML = renderVPCResults(planned);
  } catch(e) {
    vpcError.textContent = e.message;
    vpcError.classList.remove('hidden');
    vpcInput.style.borderColor = '#ef4444';
    document.getElementById('vpcResults').innerHTML = '';
  }
}

vpcInput.addEventListener('input', doVPC);
document.querySelectorAll('.vpc-count-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.vpc-count-btn').forEach(function(b) { b.classList.remove('active-vpc-btn'); });
    this.classList.add('active-vpc-btn');
    currentVPCCount = parseInt(this.dataset.count);
    doVPC();
  });
});

// ─── EXAMPLES ────────────────────────────────────────────────────────────────
document.querySelectorAll('.example-card').forEach(function(card) {
  card.addEventListener('click', function() {
    var cidr = this.dataset.cidr;
    cidrInput.value = cidr;
    doCalc(cidr);
    cidrInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });
});

// ─── COPY DELEGATION ─────────────────────────────────────────────────────────
document.addEventListener('click', function(e) {
  var btn = e.target.closest('.cbtn');
  if (!btn) return;
  var text = '';
  if (btn.dataset.t) {
    var el = document.getElementById(btn.dataset.t);
    text = el ? el.textContent.trim() : '';
  } else if (btn.dataset.v) {
    text = btn.dataset.v;
  }
  if (!text || text === '—') return;
  var orig = btn.innerHTML;
  btn.innerHTML = CHECK_SVG;
  btn.style.borderColor = '#22c55e';
  setTimeout(function() { btn.innerHTML = orig; btn.style.borderColor = 'var(--border)'; }, 1500);
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).catch(function() { fallbackCopy(text); });
  } else {
    fallbackCopy(text);
  }
});

function fallbackCopy(text) {
  var ta = document.createElement('textarea');
  ta.value = text;
  Object.assign(ta.style, { position: 'fixed', left: '-9999px', opacity: '0' });
  document.body.appendChild(ta);
  ta.select();
  document.execCommand('copy');
  document.body.removeChild(ta);
}

// ─── HOSTS PAGINATION ────────────────────────────────────────────────────────
document.getElementById('hostsPagination').addEventListener('click', function(e) {
  var btn = e.target.closest('[data-pg]');
  if (!btn || !currentData) return;
  renderHostsPage(currentData, parseInt(btn.dataset.pg));
});

// ─── FAQ ACCORDION ───────────────────────────────────────────────────────────
document.querySelectorAll('.faq-trigger').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var item    = btn.closest('.faq-item');
    var content = item.querySelector('.faq-content');
    var chevron = btn.querySelector('.faq-chevron');
    var isOpen  = !content.classList.contains('hidden');
    content.classList.toggle('hidden', isOpen);
    chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
  });
});

// ─── INPUT FOCUS STYLE ───────────────────────────────────────────────────────
[splitInput, vpcInput].forEach(function(inp) {
  inp.addEventListener('focus', function() { this.style.borderColor = '#10b981'; this.style.boxShadow = '0 0 0 3px rgba(16,185,129,0.15)'; });
  inp.addEventListener('blur',  function() { if (this.style.borderColor !== 'rgb(239, 68, 68)') { this.style.borderColor = 'var(--border)'; this.style.boxShadow = 'none'; } });
});

// ─── RFC 1918 CLICKABLE ROWS ──────────────────────────────────────────────────
document.querySelectorAll('.rfc-row').forEach(function(row) {
  row.addEventListener('click', function() {
    var cidr = this.dataset.cidr;
    cidrInput.value = cidr;
    doCalc(cidr);
    cidrInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });
});

// ─── BOOT ─────────────────────────────────────────────────────────────────────
doCalc('192.168.1.0/24');
splitInput.value  = '10.0.0.0/16';
vpcInput.value    = '10.0.0.0/16';
doSplit();
doVPC();
</script>


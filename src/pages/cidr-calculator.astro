<script is:inline>
// ─── CORE CALCULATION LOGIC ──────────────────────────────────────────────────

// ── IPv4 ──────────────────────────────────────────────────────────────────────
function parseIPv4(s) {
  var p = s.split('.').map(Number);
  if (p.length !== 4) return null;
  if (p.some(function(x) { return isNaN(x) || x < 0 || x > 255 || x !== Math.floor(x); })) return null;
  return ((p[0] << 24) | (p[1] << 16) | (p[2] << 8) | p[3]) >>> 0;
}

function ipv4Str(n) {
  n = n >>> 0;
  return [(n >>> 24) & 255, (n >>> 16) & 255, (n >>> 8) & 255, n & 255].join('.');
}

function calcIPv4(ipStr, prefix) {
  var ip = parseIPv4(ipStr);
  if (ip === null) throw new Error('Invalid IPv4 address');
  if (prefix < 0 || prefix > 32) throw new Error('Prefix must be 0–32');
  var mask = prefix === 0 ? 0 : (~0 << (32 - prefix)) >>> 0;
  var network = (ip & mask) >>> 0;
  var broadcast = (network | ((~mask) >>> 0)) >>> 0;
  var totalHosts = prefix === 32 ? 1 : prefix === 31 ? 2 : Math.pow(2, 32 - prefix);
  var usableHosts, firstUsable, lastUsable;
  if (prefix === 32) {
    // /32 is a single-host route; traditional formula gives 1-2 = -1 → 0 usable
    usableHosts = 0; firstUsable = ipv4Str(network); lastUsable = ipv4Str(network);
  } else if (prefix === 31) {
    // /31 point-to-point: both addresses consumed by network/broadcast → 0 usable
    usableHosts = 0; firstUsable = ipv4Str(network); lastUsable = ipv4Str(broadcast);
  } else {
    usableHosts = totalHosts - 2;
    firstUsable = ipv4Str(network + 1);
    lastUsable = ipv4Str(broadcast - 1);
  }
  var subnetMask = ipv4Str(mask);
  var wildcardMask = ipv4Str((~mask) >>> 0);
  var binaryOctets = [(mask >>> 24) & 255, (mask >>> 16) & 255, (mask >>> 8) & 255, mask & 255];
  var binaryMask = binaryOctets.map(function(b) { return b.toString(2).padStart(8, '0'); }).join('.');
  var first = (ip >>> 24) & 255;
  var netClass = first < 128 ? 'Class A' : first < 192 ? 'Class B' : first < 224 ? 'Class C' : first < 240 ? 'Class D' : 'Class E';
  // Address type
  var addrType = 'Public';
  if ((ip >>> 24) === 10) addrType = 'Private (RFC 1918)';
  else if ((ip >>> 24) === 172 && ((ip >>> 16) & 0xff) >= 16 && ((ip >>> 16) & 0xff) <= 31) addrType = 'Private (RFC 1918)';
  else if ((ip >>> 24) === 192 && ((ip >>> 16) & 0xff) === 168) addrType = 'Private (RFC 1918)';
  else if ((ip >>> 24) === 127) addrType = 'Loopback';
  else if ((ip >>> 24) === 169 && ((ip >>> 16) & 0xff) === 254) addrType = 'Link-Local';
  else if (first >= 224 && first < 240) addrType = 'Multicast';
  return {
    version: 4, networkAddress: ipv4Str(network), broadcastAddress: ipv4Str(broadcast),
    subnetMask: subnetMask, wildcardMask: wildcardMask, firstUsable: firstUsable,
    lastUsable: lastUsable, cidr: ipv4Str(network) + '/' + prefix,
    totalHosts: totalHosts, usableHosts: usableHosts, netClass: netClass,
    binaryMask: binaryMask, binaryOctets: binaryOctets, prefix: prefix,
    addrType: addrType, _networkNum: network, _broadcastNum: broadcast
  };
}

// ── IPv6 ──────────────────────────────────────────────────────────────────────
function parseIPv6(s) {
  try {
    if (s.includes('%')) s = s.slice(0, s.indexOf('%'));
    var groups;
    if (s.includes('::')) {
      var halves = s.split('::');
      if (halves.length !== 2) return null;
      var L = halves[0] ? halves[0].split(':') : [];
      var R = halves[1] ? halves[1].split(':') : [];
      var fill = 8 - L.length - R.length;
      if (fill < 0) return null;
      groups = L.concat(Array(fill).fill('0')).concat(R);
    } else {
      groups = s.split(':');
    }
    if (groups.length !== 8) return null;
    if (groups.some(function(g) { return !/^[0-9a-fA-F]{1,4}$/.test(g); })) return null;
    var n = 0n;
    for (var i = 0; i < groups.length; i++) n = (n << 16n) | BigInt(parseInt(groups[i], 16));
    return n;
  } catch(e) { return null; }
}

function ipv6Str(n) {
  var g = [];
  var t = n;
  for (var i = 0; i < 8; i++) { g.unshift((t & 0xffffn).toString(16)); t >>= 16n; }
  var bs = -1, bl = 0, cs = -1, cl = 0;
  for (var i = 0; i < 8; i++) {
    if (g[i] === '0') {
      if (cs === -1) { cs = i; cl = 1; } else cl++;
      if (cl > bl) { bl = cl; bs = cs; }
    } else { cs = -1; cl = 0; }
  }
  if (bl < 2) return g.join(':');
  var left = g.slice(0, bs), right = g.slice(bs + bl);
  return (left.length ? left.join(':') : '') + '::' + (right.length ? right.join(':') : '');
}

function fmtBigHosts(hostBits) {
  if (hostBits === 0) return '1';
  if (hostBits <= 53) return Number(1n << BigInt(hostBits)).toLocaleString();
  return '2^' + hostBits;
}

function getIPv6Type(ip) {
  var top16 = Number(ip >> 112n) & 0xffff;
  var top8 = (top16 >> 8) & 0xff;
  if (ip === 1n) return 'Loopback (::1)';
  if (top8 === 0xff) return 'Multicast';
  if ((top16 & 0xffc0) === 0xfe80) return 'Link-Local';
  if ((top8 & 0xfe) === 0xfc) return 'Unique Local';
  if ((top8 & 0xe0) === 0x20) return 'Global Unicast';
  if (top8 === 0x20 && ((top16 >> 4) & 0xf) === 0x1) return 'Teredo';
  return 'Global Unicast';
}

function calcIPv6(ipStr, prefix) {
  var ip = parseIPv6(ipStr);
  if (ip === null) throw new Error('Invalid IPv6 address');
  if (prefix < 0 || prefix > 128) throw new Error('Prefix must be 0–128');
  var hostBits = 128 - prefix;
  var maskBig = prefix === 0 ? 0n : ((1n << BigInt(prefix)) - 1n) << BigInt(hostBits);
  var network = ip & maskBig;
  var hostMask = hostBits === 0 ? 0n : (1n << BigInt(hostBits)) - 1n;
  var lastAddr = network | hostMask;
  var firstUsable, lastUsable;
  if (prefix === 128) {
    firstUsable = ipv6Str(network);
    lastUsable = ipv6Str(network);
  } else {
    firstUsable = ipv6Str(network + 1n);
    lastUsable = ipv6Str(lastAddr);
  }
  var totalStr = fmtBigHosts(hostBits);
  return {
    version: 6, networkAddress: ipv6Str(network), firstUsable: firstUsable,
    lastUsable: lastUsable, cidr: ipv6Str(network) + '/' + prefix,
    totalHosts: totalStr, usableHosts: totalStr, prefix: prefix,
    addrType: getIPv6Type(ip), _networkBig: network, _lastBig: lastAddr, _hostBits: hostBits
  };
}

// ── Parse CIDR input ──────────────────────────────────────────────────────────
function parseCIDR(input) {
  input = input.trim();
  if (!input.includes('/')) throw new Error('Enter in CIDR format: 192.168.1.0/24');
  var slash = input.lastIndexOf('/');
  var ipPart = input.slice(0, slash);
  var prefixStr = input.slice(slash + 1);
  var prefix = parseInt(prefixStr, 10);
  if (isNaN(prefix) || String(prefix) !== prefixStr.trim()) throw new Error('Invalid prefix length');
  if (ipPart.includes(':')) return calcIPv6(ipPart, prefix);
  return calcIPv4(ipPart, prefix);
}

// ── Subnet splitter ───────────────────────────────────────────────────────────
function nextPow2(n) { return Math.pow(2, Math.ceil(Math.log2(n))); }

function splitSubnet(cidrStr, count) {
  var slash = cidrStr.lastIndexOf('/');
  var ipPart = cidrStr.slice(0, slash);
  var prefix = parseInt(cidrStr.slice(slash + 1));
  if (isNaN(prefix)) return null;
  var bitsNeeded = Math.round(Math.log2(count));
  var newPrefix = prefix + bitsNeeded;
  if (ipPart.includes(':')) {
    if (newPrefix > 128) return null;
    var ip6 = parseIPv6(ipPart);
    if (!ip6) return null;
    var hb = 128 - prefix;
    var m6 = prefix === 0 ? 0n : ((1n << BigInt(prefix)) - 1n) << BigInt(hb);
    var net6 = ip6 & m6;
    var sz6 = 1n << BigInt(128 - newPrefix);
    var results = [];
    for (var i = 0; i < count; i++) {
      var sn = net6 + BigInt(i) * sz6;
      var sl = sn + sz6 - 1n;
      var nhb = 128 - newPrefix;
      results.push({
        cidr: ipv6Str(sn) + '/' + newPrefix, network: ipv6Str(sn),
        first: ipv6Str(sn + 1n), last: ipv6Str(sl),
        hosts: fmtBigHosts(nhb), version: 6
      });
    }
    return results;
  } else {
    if (newPrefix > 32) return null;
    var ip4 = parseIPv4(ipPart);
    if (ip4 === null) return null;
    var origMask = prefix === 0 ? 0 : (~0 << (32 - prefix)) >>> 0;
    var network4 = (ip4 & origMask) >>> 0;
    var subSize = Math.pow(2, 32 - newPrefix);
    var results4 = [];
    for (var j = 0; j < count; j++) {
      var sNet = (network4 + j * subSize) >>> 0;
      var sBcast = (sNet + subSize - 1) >>> 0;
      var hosts = newPrefix >= 31 ? subSize : subSize - 2;
      results4.push({
        cidr: ipv4Str(sNet) + '/' + newPrefix, network: ipv4Str(sNet),
        broadcast: ipv4Str(sBcast),
        first: newPrefix >= 31 ? ipv4Str(sNet) : ipv4Str(sNet + 1),
        last: newPrefix >= 31 ? ipv4Str(sBcast) : ipv4Str(sBcast - 1),
        hosts: hosts.toLocaleString(), version: 4
      });
    }
    return results4;
  }
}

// ── VPC tier config ───────────────────────────────────────────────────────────
var VPC_TIERS = {
  2: [
    { name: 'Public',    color: '#22c55e', desc: 'ALB, NAT Gateway, Bastion' },
    { name: 'Private',   color: '#6366f1', desc: 'App servers, ECS, Lambda' }

---
import Layout from '../../layouts/Layout.astro';
import kubernetesData from '../../data/cheatsheets/kubernetes.json';
import dockerData from '../../data/cheatsheets/docker.json';
import gitData from '../../data/cheatsheets/git.json';
import awsData from '../../data/cheatsheets/aws.json';
import terraformData from '../../data/cheatsheets/terraform.json';
import helmData from '../../data/cheatsheets/helm.json';
import linuxData from '../../data/cheatsheets/linux.json';
import githubData from '../../data/cheatsheets/github.json';

export function getStaticPaths() {
  return [
    { params: { slug: 'kubernetes' }, props: { data: kubernetesData } },
    { params: { slug: 'docker' }, props: { data: dockerData } },
    { params: { slug: 'git' }, props: { data: gitData } },
    { params: { slug: 'aws' }, props: { data: awsData } },
    { params: { slug: 'terraform' }, props: { data: terraformData } },
    { params: { slug: 'helm' }, props: { data: helmData } },
    { params: { slug: 'linux' }, props: { data: linuxData } },
    { params: { slug: 'github' }, props: { data: githubData } },
  ];
}

const { data } = Astro.props;
const slug = data.slug;

// Brand colors + logos, sourced from files that actually exist in public/logos/.
const brandColors: Record<string, string> = {
  kubernetes: '#326CE5',
  docker: '#2496ED',
  git: '#F05032',
  aws: '#FF9900',
  terraform: '#7B42BC',
  helm: '#0F1689',
  linux: '#FCC624',
  github: '#2DA44E',
};
const brandColor = brandColors[slug] || '#3B82F6';

const brandLogos: Record<string, string | null> = {
  kubernetes: '/logos/kubernetes.svg',
  docker: '/logos/docker.svg',
  git: '/logos/git.svg',
  aws: '/logos/aws-logo.svg',
  terraform: '/logos/terraform.svg',
  helm: '/logos/helm-light.svg',
  linux: '/logos/linux.svg',
  github: '/logos/github.svg',
};
const brandLogo = brandLogos[slug] ?? null;

function hexToRgb(hex: string): string {
  const h = hex.replace('#', '');
  const r = parseInt(h.substring(0, 2), 16);
  const g = parseInt(h.substring(2, 4), 16);
  const b = parseInt(h.substring(4, 6), 16);
  return `${r}, ${g}, ${b}`;
}
const brandRgb = hexToRgb(brandColor);


  @media (max-width: 640px) {
    .pills-row-standalone {
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: thin;
      scrollbar-color: #333333 transparent;
    }
    .pills-row-standalone::-webkit-scrollbar { height: 4px; }
    .pills-row-standalone::-webkit-scrollbar-track { background: transparent; }
    .pills-row-standalone::-webkit-scrollbar-thumb { background: #333333; border-radius: 999px; }
  }
  .cat-pill {
    font-size: 11.5px;
    font-weight: 500;
    padding: 6px 12px;
    border-radius: 20px;
    background: transparent;
    color: var(--fg2);
    border: 1px solid #222222;
    cursor: pointer;
    white-space: nowrap;
    font-family: 'Inter', sans-serif;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .cat-pill:hover { border-color: #334155; color: #F8FAFC; }
  .cat-pill.active {
    background: rgba(var(--brand-rgb), 0.15);
    border-color: var(--brand);
    color: var(--brand);
  }

  .pills-divider {
    width: 1px;
    align-self: stretch;
    background: #222222;
    margin: 2px 2px;
    flex-shrink: 0;
  }

  /* ── Difficulty filter pills ─────────────────────────────────────────────── */
  .diff-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    font-weight: 600;
    padding: 6px 16px;
    border-radius: 20px;
    cursor: pointer;
    white-space: nowrap;
    font-family: 'Inter', sans-serif;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .diff-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .diff-dot-beginner { background: #4ADE80; }
  .diff-dot-intermediate { background: #FBBF24; }
  .diff-dot-advanced { background: #F472B6; }
  .diff-pill-beginner {
    color: #4ADE80;
    background: rgba(74,222,128,0.15);
    border: 1px solid rgba(74,222,128,0.4);
  }
  .diff-pill-beginner.active { background: rgba(74,222,128,0.28); border-color: #4ADE80; }
  .diff-pill-intermediate {
    color: #FBBF24;
    background: rgba(251,191,36,0.15);
    border: 1px solid rgba(251,191,36,0.4);
  }
  .diff-pill-intermediate.active { background: rgba(251,191,36,0.28); border-color: #FBBF24; }
  .diff-pill-advanced {
    color: #F472B6;
    background: rgba(244,114,182,0.15);
    border: 1px solid rgba(244,114,182,0.4);
  }
  .diff-pill-advanced.active { background: rgba(244,114,182,0.28); border-color: #F472B6; }

  .results-meta {
    font-size: 12.5px;
    color: var(--fg3);
    padding: 10px 0 0;
    font-family: 'Inter', sans-serif;
  }

  /* ── Slim sticky search bar (fixed, hidden until scrolled past large bar) ── */
  .sticky-search-bar {
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    z-index: 25;
    background: #0A0A0A;
    border-bottom: 1px solid #222222;
    padding: 4px 0;
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .sticky-search-bar.visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  .sticky-bar-inner {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .sticky-diff-pills {
    display: flex;
    align-items: center;
    gap: 8px;
    overflow-x: auto;
    flex-wrap: nowrap;
    scrollbar-width: thin;
    scrollbar-color: #333333 transparent;
  }
  .sticky-diff-pills::-webkit-scrollbar { height: 4px; }
  .sticky-diff-pills::-webkit-scrollbar-track { background: transparent; }
  .sticky-diff-pills::-webkit-scrollbar-thumb { background: #333333; border-radius: 999px; }
  .sticky-bottom-row {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .sticky-search-wrap {
    position: relative;
    flex: 0 1 320px;
    min-width: 140px;
  }
  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--fg3);
    pointer-events: none;
  }
  .sticky-search-input {
    width: 100%;
    height: 36px;
    padding: 0 14px 0 38px;
    border-radius: 8px;
    background: #111111;
    border: 1px solid #222222;
    color: #F8FAFC;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    outline: none;
    transition: border-color 0.15s;
  }
  .sticky-search-input:focus { border-color: #64748B; }
  .sticky-search-input::placeholder { color: var(--fg3); }

  .sticky-pills {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1 1 auto;
    min-width: 0;
    overflow-x: auto;
    flex-wrap: nowrap;
    scrollbar-width: thin;
    scrollbar-color: #333333 transparent;
  }
  .sticky-pills::-webkit-scrollbar { height: 4px; }
  .sticky-pills::-webkit-scrollbar-track { background: transparent; }
  .sticky-pills::-webkit-scrollbar-thumb { background: #333333; border-radius: 999px; }

  @media (max-width: 480px) {
    .sticky-search-wrap { flex: 0 1 130px; min-width: 100px; }
    .sticky-search-input { font-size: 12px; padding: 0 10px 0 32px; }
  }

  /* ── Command grid ────────────────────────────────────────────────────────── */
  .cmd-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }
  @media (max-width: 900px) {
    .cmd-grid { grid-template-columns: minmax(0, 1fr); }
  }

  .cmd-card {
    background: #111111;
    border: 1px solid #222222;
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .cmd-card.destructive {
    border-left: 3px solid rgba(248,113,113,0.4);
  }
  .cmd-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 12px;
  }
  .cmd-card-title {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #F8FAFC;
    line-height: 1.4;
  }
  .cmd-badges {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .badge {
    font-size: 10px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 20px;
    white-space: nowrap;
    font-family: 'JetBrains Mono', monospace;
  }
  .badge-beginner { color: #4ADE80; background: rgba(74,222,128,0.12); border: 1px solid rgba(74,222,128,0.3); }
  .badge-intermediate { color: #FBBF24; background: rgba(251,191,36,0.12); border: 1px solid rgba(251,191,36,0.3); }
  .badge-advanced { color: #F472B6; background: rgba(244,114,182,0.12); border: 1px solid rgba(244,114,182,0.3); }
  .badge-destructive { color: #F87171; background: rgba(248,113,113,0.12); border: 1px solid rgba(248,113,113,0.3); }
  .badge-deprecated { color: #FB923C; background: rgba(251,146,60,0.12); border: 1px solid rgba(251,146,60,0.3); }

  .cmd-block {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 10px;
    background: #0A0A0A;
    border: 1px solid #222222;
    border-radius: 8px;
    padding: 10px;
    margin-bottom: 14px;
    overflow: hidden;
    min-width: 0;
  }
  .cmd-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    color: #F8FAFC;
    white-space: pre;
    flex: 1;
    overflow-x: auto;
    min-width: 0;
    scrollbar-width: thin;
    scrollbar-color: #333333 transparent;
  }
  .cmd-text::-webkit-scrollbar { height: 4px; }
  .cmd-text::-webkit-scrollbar-track { background: transparent; }
  .cmd-text::-webkit-scrollbar-thumb { background: #333333; border-radius: 999px; }
  .copy-btn {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 500;
    padding: 5px 11px;
    border-radius: 6px;
    background: rgba(248,250,252,0.06);
    color: var(--fg2);
    border: none;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: background 0.15s, color 0.15s;
  }
  .copy-btn:hover { background: rgba(248,250,252,0.12); color: #F8FAFC; }
  .copy-btn.copied { color: #4ADE80 !important; background: rgba(74,222,128,0.12) !important; }

  .cmd-flags {
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin-bottom: 14px;
  }
  .cmd-flag-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-size: 12px;
  }
  .cmd-flag-name {
    font-family: 'JetBrains Mono', monospace;
    color: #60A5FA;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .cmd-flag-desc {
    color: var(--fg2);
    line-height: 1.5;
  }

  .cmd-usecase, .cmd-gotcha {
    border-radius: 8px;
    padding: 10px 12px;
    margin-bottom: 10px;
  }
  .cmd-usecase {
    background: #0A0A0A;
    border: 1px solid #222222;
  }
  .cmd-usecase-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #71717a;
    margin-bottom: 4px;
  }
  .cmd-usecase-text {
    font-size: 12.5px;
    color: var(--fg2);
    line-height: 1.55;
  }
  .cmd-gotcha {
    background: rgba(251,191,36,0.05);
    border: 1px solid rgba(251,191,36,0.15);
    margin-bottom: 0;
  }
  .cmd-gotcha-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #fbbf24;
    margin-bottom: 4px;
  }
  .cmd-gotcha-text {
    font-size: 12.5px;
    color: var(--fg2);
    line-height: 1.55;
  }

  /* ── No results ──────────────────────────────────────────────────────────── */
  .no-results {
    text-align: center;
    padding: 60px 20px;
  }
  .no-results p {
    color: var(--fg2);
    font-size: 14px;
    margin-bottom: 16px;
  }
  .clear-btn {
    background: transparent;
    color: #F8FAFC;
    border: 1px solid #334155;
    padding: 9px 20px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: background 0.15s;
  }
  .clear-btn:hover { background: rgba(248,250,252,0.08); }

  /* ── Section titles (shared) ─────────────────────────────────────────────── */
  .section-title {
    font-size: 20px;
    font-weight: 700;
    color: #F8FAFC;
    font-family: 'Inter', sans-serif;
    margin-bottom: 6px;
  }
  .section-subtitle {
    font-size: 13.5px;
    color: var(--fg2);
    margin-bottom: 18px;
    max-width: 720px;
    line-height: 1.6;
  }

  /* ── Reference Tools collapsible cards ───────────────────────────────────── */
  .ref-tool {
    background: #111111;
    border: 1px solid #222222;
    border-radius: 10px;
    margin-bottom: 12px;
    overflow: hidden;
  }
  .ref-tool-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s;
  }
  .ref-tool-toggle:hover { background: rgba(248,250,252,0.04); }
  .ref-tool-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(248,250,252,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #94A3B8;
  }
  .ref-tool-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .ref-tool-title {
    font-family: 'Inter', sans-serif;
    font-size: 14.5px;
    font-weight: 600;
    color: #F8FAFC;
  }
  .ref-tool-desc {
    font-family: 'Inter', sans-serif;
    font-size: 12.5px;
    color: var(--fg2);
    line-height: 1.4;
  }
  .ref-tool-chevron {
    flex-shrink: 0;
    color: var(--fg3);
    transition: transform 0.25s ease;
  }
  .ref-tool-toggle[aria-expanded="true"] .ref-tool-chevron {
    transform: rotate(180deg);
  }
  .ref-tool-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }
  .ref-tool-panel.expanded {
    grid-template-rows: 1fr;
  }
  .ref-tool-panel-inner {
    overflow: hidden;
    min-height: 0;
    padding: 0 18px 0;
  }
  .ref-tool-panel.expanded .ref-tool-panel-inner {
    padding: 0 18px 22px;
  }

  /* ── Error Message Lookup ────────────────────────────────────────────────── */
  .error-lookup-search-wrap {
    position: relative;
    margin: 0 0 18px;
  }
  .error-lookup-search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--fg3);
    pointer-events: none;
  }
  .error-lookup-search-input {
    width: 100%;
    height: 40px;
    padding: 0 14px 0 40px;
    border-radius: 8px;
    background: #0A0A0A;
    border: 1px solid #222222;
    color: #F8FAFC;
    font-family: 'Inter', sans-serif;
    font-size: 13.5px;
    outline: none;
    transition: border-color 0.15s;
  }
  .error-lookup-search-input:focus { border-color: #64748B; }
  .error-lookup-search-input::placeholder { color: var(--fg3); }
  .error-cards-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .error-card {
    background: #0A0A0A;
    border: 1px solid #222222;
    border-radius: 10px;
    padding: 16px;
    min-width: 0;
  }
  .error-fix-block { margin-bottom: 10px; }
  .error-fix-block .cmd-block { margin-top: 6px; margin-bottom: 0; }
  .error-no-results {
    text-align: center;
    padding: 30px 10px;
    color: var(--fg2);
    font-size: 13px;
  }

  /* ── GitHub Actions Failure Decoder (reuses error-lookup search + card list styles) ── */
  .failure-card {
    background: #0A0A0A;
    border: 1px solid #222222;
    border-radius: 10px;
    padding: 16px;
    min-width: 0;
  }
  .failure-card-title {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #F8FAFC;
    line-height: 1.4;
    margin-bottom: 12px;
  }

  /* ── Go Template Quick Reference ─────────────────────────────────────────── */
  .gotpl-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  @media (max-width: 900px) {
    .gotpl-grid { grid-template-columns: minmax(0, 1fr); }
  }
  .gotpl-card {
    background: #0A0A0A;
    border: 1px solid #222222;
    border-radius: 10px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
  }
  .gotpl-title {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #F8FAFC;
  }
  .gotpl-desc {
    font-size: 12.5px;
    color: var(--fg2);
    line-height: 1.55;
  }
  .gotpl-fixes-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
    background: rgba(74,222,128,0.1);
    border: 1px solid rgba(74,222,128,0.3);
    color: #4ADE80;
    width: fit-content;
  }

  /* ── Distro Rosetta Stone ────────────────────────────────────────────────── */
  .rosetta-gotcha-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 20px;
  }
  @media (max-width: 900px) {
    .rosetta-gotcha-grid { grid-template-columns: minmax(0, 1fr); }
  }
  .rosetta-gotcha {
    background: #0A0A0A;
    border-left: 3px solid #FBBF24;
    border-radius: 0 8px 8px 0;
    padding: 12px 16px;
  }
  .rosetta-gotcha-title {
    font-family: 'Inter', sans-serif;
    font-size: 13.5px;
    font-weight: 600;
    color: #F8FAFC;
    margin-bottom: 5px;
  }
  .rosetta-gotcha-note {
    font-size: 12.5px;
    color: var(--fg2);
    line-height: 1.55;
  }

  /* ── Incident flow ──────────────────────────────────────────────────────── */
  .incident-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
  }
  @media (max-width: 1024px) {
    .incident-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 640px) {
    .incident-grid { grid-template-columns: minmax(0, 1fr); }
  }
  .incident-card {
    background: #0A0A0A;
    border: 1px solid #222222;
    border-radius: 10px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
  }
  .incident-step-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(248,250,252,0.08);
    border: 1px solid #334155;
    color: #F8FAFC;
    font-size: 11px;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
  }
  .incident-cmd-block {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 8px;
    background: #111111;
    border: 1px solid #222222;
    border-radius: 8px;
    padding: 10px;
    overflow: hidden;
    min-width: 0;
  }
  .incident-cmd-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #F8FAFC;
    white-space: pre;
    flex: 1;
    overflow-x: auto;
    min-width: 0;
    scrollbar-width: thin;
    scrollbar-color: #333333 transparent;
  }
  .incident-cmd-text::-webkit-scrollbar { height: 4px; }
  .incident-cmd-text::-webkit-scrollbar-track { background: transparent; }
  .incident-cmd-text::-webkit-scrollbar-thumb { background: #333333; border-radius: 999px; }
  .incident-why {
    font-size: 12.5px;
    color: var(--fg2);
    line-height: 1.55;
  }

  /* ── Credential chain debugger ───────────────────────────────────────────── */
  .cred-steps-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-bottom: 28px;
  }
  @media (max-width: 900px) {
    .cred-steps-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 640px) {
    .cred-steps-grid { grid-template-columns: minmax(0, 1fr); }
  }
  .cred-step-card {
    background: #0A0A0A;
    border: 1px solid #222222;
    border-radius: 10px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }
  .cred-step-source {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #F8FAFC;
  }
  .cred-step-example {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px;
    color: var(--fg2);
    background: #111111;
    border: 1px solid #222222;
    border-radius: 6px;
    padding: 6px 8px;
    white-space: normal;
    overflow-wrap: anywhere;
    line-height: 1.5;
  }
  .cred-step-note {
    font-size: 12.5px;
    color: var(--fg2);
    line-height: 1.55;
  }
  .cred-subtitle {
    font-size: 15px;
    font-weight: 700;
    color: #F8FAFC;
    font-family: 'Inter', sans-serif;
    margin-bottom: 12px;
  }
  .cred-debug-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }
  @media (max-width: 640px) {
    .cred-debug-grid { grid-template-columns: minmax(0, 1fr); }
  }
  .cred-debug-card {
    background: #0A0A0A;
    border: 1px solid #222222;
    border-radius: 10px;
    padding: 16px;
    min-width: 0;
  }
  .cred-debug-title {
    font-family: 'Inter', sans-serif;
    font-size: 13.5px;
    font-weight: 600;
    color: #F8FAFC;
    margin-bottom: 10px;
  }
  .cred-debug-note {
    font-size: 12.5px;
    color: var(--fg2);
    line-height: 1.55;
    margin-top: 10px;
  }

  /* ── S3 operation picker ─────────────────────────────────────────────────── */
  .s3-picker-table {
    background: #0A0A0A;
    border: 1px solid #222222;
    border-radius: 10px;
    overflow: hidden;
  }
  .s3-picker-header-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.6fr) minmax(0, 1.1fr);
    gap: 16px;
    padding: 10px 18px;
    background: rgba(248,250,252,0.04);
    border-bottom: 1px solid #222222;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg2);
  }
  .s3-picker-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.6fr) minmax(0, 1.1fr);
    gap: 16px;
    padding: 16px 18px;
    border-bottom: 1px solid #222222;
    min-width: 0;
  }
  .s3-picker-row:last-child { border-bottom: none; }
  .s3-picker-scenario {
    font-size: 13px;
    color: #F8FAFC;
    line-height: 1.5;
    align-self: center;
  }
  .s3-picker-cmd {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .s3-picker-command-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    color: #60A5FA;
  }
  .s3-picker-note {
    font-size: 12px;
    color: var(--fg2);
    line-height: 1.5;
    align-self: center;
  }
  @media (max-width: 768px) {
    .s3-picker-header-row { display: none; }
    .s3-picker-row {
      grid-template-columns: minmax(0, 1fr);
      gap: 10px;
    }
  }

  /* ── Pod status decoder ─────────────────────────────────────────────────── */
  .decoder-table-wrap {
    overflow-x: auto;
    border-radius: 10px;
    border: 1px solid #222222;
  }
  .decoder-table {
    width: 100%;
    border-collapse: collapse;
    background: #0A0A0A;
  }
  .decoder-table th {
    text-align: left;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg2);
    padding: 12px 16px;
    background: rgba(248,250,252,0.04);
    border-bottom: 1px solid #222222;
    white-space: nowrap;
  }
  .decoder-table td {
    padding: 12px 16px;
    border-bottom: 1px solid #222222;
    vertical-align: top;
    font-size: 13px;
  }
  .decoder-table tr:last-child td { border-bottom: none; }
  .decoder-table tbody tr:hover { background: rgba(248,250,252,0.03); }
  .decoder-status {
    font-family: 'JetBrains Mono', monospace;
    color: #F8FAFC;
    font-weight: 600;
    white-space: nowrap;
  }
  .decoder-meaning, .decoder-action {
    color: var(--fg2);
    line-height: 1.55;
  }

  /* ── Related tools ──────────────────────────────────────────────────────── */
  .related-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  @media (max-width: 640px) {
    .related-grid { grid-template-columns: 1fr; }
  }
  .related-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: #0A0A0A;
    border: 1px solid #222222;
    border-radius: 10px;
    padding: 16px;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .related-item:hover { border-color: #F8FAFC; background: #111111; }
  .related-name {
    font-size: 14px;
    font-weight: 600;
    color: #F8FAFC;
    margin-bottom: 4px;
    font-family: 'Inter', sans-serif;
  }
  .related-desc {
    font-size: 12.5px;
    color: var(--fg2);
    line-height: 1.5;
    font-family: 'Inter', sans-serif;
  }
  .related-arrow {
    color: #F8FAFC;
    font-size: 18px;
    flex-shrink: 0;
  }

  /* ── SEO content ─────────────────────────────────────────────────────────── */
  .seo-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 24px;
  }
  .seo-p {
    font-size: 14px;
    color: var(--fg2);
    line-height: 1.75;
    margin-bottom: 16px;
  }
  .seo-p:last-child { margin-bottom: 0; }

  /* ── FAQ ─────────────────────────────────────────────────────────────────── */
  .faq-item { border-bottom: 1px solid var(--border); }
  .faq-trigger {
    background: transparent;
    border: none;
    cursor: pointer;
    transition: background 0.12s;
  }
  .faq-trigger:hover { background: rgba(248,250,252,0.04); }
</style>

<script>
  function copyText(text: string, btn: HTMLElement) {
    function flash() {
      btn.classList.add('copied');
      const original = btn.textContent;
      btn.textContent = 'Copied';
      setTimeout(() => {
        btn.classList.remove('copied');
        btn.textContent = original;
      }, 1400);
    }
    function fallback() {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0';
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); } catch (e) {}
      document.body.removeChild(ta);
    }
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(flash).catch(() => { fallback(); flash(); });
    } else {
      fallback(); flash();
    }
  }

  // ── Earned Disclosure banner (tracks Beginner command copies) ────────────
  const earnedBanner = document.getElementById('earnedBanner') as HTMLElement | null;
  const earnedBannerClose = document.getElementById('earnedBannerClose') as HTMLElement | null;
  const earnedBannerLink = document.getElementById('earnedBannerLink') as HTMLElement | null;
  const BEGINNER_COPIES_KEY = 'opsbash-beginner-copies';
  const BANNER_DISMISSED_KEY = 'opsbash-earned-banner-dismissed';

  function registerBeginnerCopy() {
    if (localStorage.getItem(BANNER_DISMISSED_KEY) === 'true') return;
    const count = parseInt(localStorage.getItem(BEGINNER_COPIES_KEY) || '0', 10) + 1;
    localStorage.setItem(BEGINNER_COPIES_KEY, String(count));
    if (count >= 3) earnedBanner?.classList.remove('hidden');
  }

  earnedBannerClose?.addEventListener('click', () => {
    earnedBanner?.classList.add('hidden');
    localStorage.setItem(BANNER_DISMISSED_KEY, 'true');
  });

  earnedBannerLink?.addEventListener('click', (e) => {
    e.preventDefault();
    const intermediateCards = Array.from(document.querySelectorAll('.cmd-card[data-difficulty="Intermediate"]')) as HTMLElement[];
    const target = intermediateCards.find((el) => el.style.display !== 'none') || intermediateCards[0];
    target?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = btn.getAttribute('data-copy') || '';
      if (text) copyText(text, btn as HTMLElement);

      const difficultyCard = (btn as HTMLElement).closest('[data-difficulty]');
      if (difficultyCard?.getAttribute('data-difficulty') === 'Beginner') {
        registerBeginnerCopy();
      }
    });
  });

  // ── Start Here collapse/expand ───────────────────────────────────────────
  const startHereSection = document.getElementById('startHereSection') as HTMLElement | null;
  const startHereToggle = document.getElementById('startHereToggle') as HTMLElement | null;
  const STARTHERE_KEY = 'opsbash-starthere-collapsed';

  function setStartHereCollapsed(collapsed: boolean) {
    startHereSection?.classList.toggle('collapsed', collapsed);
    startHereToggle?.setAttribute('aria-expanded', String(!collapsed));
    const label = startHereToggle?.querySelector('.start-here-toggle-label');
    if (label) label.textContent = collapsed ? 'Show' : 'Hide';
  }

  setStartHereCollapsed(localStorage.getItem(STARTHERE_KEY) === 'true');

  startHereToggle?.addEventListener('click', () => {
    const collapsed = !startHereSection?.classList.contains('collapsed');
    setStartHereCollapsed(collapsed);
    localStorage.setItem(STARTHERE_KEY, String(collapsed));
  });

  // ── Search + category + difficulty filtering ─────────────────────────────
  const cmdCards = Array.from(document.querySelectorAll('.cmd-card')) as HTMLElement[];
  const pills = Array.from(document.querySelectorAll('.cat-pill')) as HTMLElement[];
  const diffPills = Array.from(document.querySelectorAll('.diff-pill')) as HTMLElement[];
  const searchLarge = document.getElementById('cmdSearchLarge') as HTMLInputElement | null;
  const searchSlim = document.getElementById('cmdSearchSlim') as HTMLInputElement | null;
  const searchInputs = [searchLarge, searchSlim].filter(Boolean) as HTMLInputElement[];
  const resultsMeta = document.getElementById('resultsMeta') as HTMLElement;
  const noResultsState = document.getElementById('noResultsState') as HTMLElement;
  const clearSearchBtn = document.getElementById('clearSearchBtn') as HTMLButtonElement;
  const cmdGrid = document.getElementById('cmdGrid') as HTMLElement;
  const stickySearchBar = document.getElementById('stickySearchBar') as HTMLElement;

  let activeCategory = 'all';
  const activeDifficulties = new Set<string>();

  function currentQuery(): string {
    return (searchLarge?.value ?? searchSlim?.value ?? '').trim().toLowerCase();
  }

  function syncSearchInputs(source: HTMLInputElement) {
    searchInputs.forEach((el) => {
      if (el !== source) el.value = source.value;
    });
  }

  function applyFilters() {
    const query = currentQuery();
    let visibleCount = 0;

    cmdCards.forEach((card) => {
      const matchesCategory = activeCategory === 'all' || card.getAttribute('data-category') === activeCategory;
      const matchesDifficulty = activeDifficulties.size === 0 || activeDifficulties.has(card.getAttribute('data-difficulty') || '');
      const haystack = card.getAttribute('data-search') || '';
      const matchesSearch = !query || haystack.indexOf(query) !== -1;
      const visible = matchesCategory && matchesDifficulty && matchesSearch;
      card.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    // Results meta text
    let metaText = `${visibleCount} `;
    if (activeDifficulties.size > 0) {
      const order = ['Beginner', 'Intermediate', 'Advanced'];
      metaText += `${order.filter((d) => activeDifficulties.has(d)).join(', ')} command${visibleCount === 1 ? '' : 's'}`;
    } else {
      metaText += `command${visibleCount === 1 ? '' : 's'}`;
    }
    if (activeCategory !== 'all') {
      const activePill = pills.find((p) => p.getAttribute('data-category') === activeCategory);
      const label = activePill ? activePill.textContent!.replace(/\s*\(\d+\)$/, '') : '';
      metaText += ` in ${label}`;
    }
    if (query) {
      metaText += ` matching "${query}"`;
    }
    resultsMeta.textContent = metaText;

    const noResults = visibleCount === 0;
    noResultsState.classList.toggle('hidden', !noResults);
    cmdGrid.style.display = noResults ? 'none' : '';
  }

  searchInputs.forEach((input) => {
    input.addEventListener('input', () => {
      syncSearchInputs(input);
      requestAnimationFrame(applyFilters);
    });
  });

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      const cat = pill.getAttribute('data-category') || 'all';
      if (cat === 'all') {
        activeCategory = 'all';
      } else if (activeCategory === cat) {
        activeCategory = 'all';
      } else {
        activeCategory = cat;
      }
      pills.forEach((p) => {
        const pCat = p.getAttribute('data-category') || 'all';
        p.classList.toggle('active', pCat === activeCategory || (activeCategory === 'all' && pCat === 'all'));
      });
      requestAnimationFrame(applyFilters);
    });
  });

  diffPills.forEach((pill) => {
    pill.addEventListener('click', () => {
      const diff = pill.getAttribute('data-difficulty') || '';
      if (activeDifficulties.has(diff)) {
        activeDifficulties.delete(diff);
      } else {
        activeDifficulties.add(diff);
      }
      diffPills.forEach((p) => {
        p.classList.toggle('active', activeDifficulties.has(p.getAttribute('data-difficulty') || ''));
      });
      requestAnimationFrame(applyFilters);
    });
  });

  function resetAllFilters() {
    searchInputs.forEach((el) => { el.value = ''; });
    activeCategory = 'all';
    activeDifficulties.clear();
    pills.forEach((p) => p.classList.toggle('active', p.getAttribute('data-category') === 'all'));
    diffPills.forEach((p) => p.classList.remove('active'));
    requestAnimationFrame(applyFilters);
  }

  clearSearchBtn?.addEventListener('click', resetAllFilters);

  // ── Keyboard shortcuts: "/" and Ctrl+K focus search, Escape clears ─────────
  document.addEventListener('keydown', (e) => {
    const activeTag = (document.activeElement as HTMLElement)?.tagName;
    const busy = activeTag === 'INPUT' || activeTag === 'TEXTAREA' || activeTag === 'SELECT';
    const isCtrlK = (e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k';
    const isSlash = e.key === '/' && !busy;

    if (isCtrlK || isSlash) {
      e.preventDefault();
      e.stopImmediatePropagation();
      const target = stickySearchBar?.classList.contains('visible') ? searchSlim : searchLarge;
      target?.focus();
      return;
    }

    if (e.key === 'Escape' && busy) {
      resetAllFilters();
      (document.activeElement as HTMLElement)?.blur();
    }
  }, true);

  // ── Sticky search bar via IntersectionObserver ─────────────────────────────
  const sentinel = document.getElementById('searchSentinel');
  if (sentinel && stickySearchBar && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const scrolledPast = !entry.isIntersecting && entry.boundingClientRect.top < 0;
          stickySearchBar.classList.toggle('visible', scrolledPast);
        });
      },
      { threshold: 0, rootMargin: '-64px 0px 0px 0px' }
    );
    observer.observe(sentinel);
  }

  // ── Error Message Lookup search filter ─────────────────────────────────────
  const errorSearchInput = document.getElementById('errorSearchInput') as HTMLInputElement | null;
  const errorCards = Array.from(document.querySelectorAll('.error-card')) as HTMLElement[];
  const errorNoResults = document.getElementById('errorNoResults') as HTMLElement | null;

  errorSearchInput?.addEventListener('input', () => {
    const query = errorSearchInput.value.trim().toLowerCase();
    let visibleCount = 0;
    errorCards.forEach((card) => {
      const matches = !query || (card.getAttribute('data-search') || '').indexOf(query) !== -1;
      card.style.display = matches ? '' : 'none';
      if (matches) visibleCount++;
    });
    errorNoResults?.classList.toggle('hidden', visibleCount !== 0);
  });

  // ── GitHub Actions Failure Decoder search filter ─────────────────────────
  const failureSearchInput = document.getElementById('failureSearchInput') as HTMLInputElement | null;
  const failureCards = Array.from(document.querySelectorAll('.failure-card')) as HTMLElement[];
  const failureNoResults = document.getElementById('failureNoResults') as HTMLElement | null;

  failureSearchInput?.addEventListener('input', () => {
    const query = failureSearchInput.value.trim().toLowerCase();
    let visibleCount = 0;
    failureCards.forEach((card) => {
      const matches = !query || (card.getAttribute('data-search') || '').indexOf(query) !== -1;
      card.style.display = matches ? '' : 'none';
      if (matches) visibleCount++;
    });
    failureNoResults?.classList.toggle('hidden', visibleCount !== 0);
  });

  // ── Reference Tools expand/collapse ────────────────────────────────────────
  document.querySelectorAll('.ref-tool-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const panelId = btn.getAttribute('data-panel');
      if (!panelId) return;
      const panel = document.getElementById(panelId) as HTMLElement | null;
      if (!panel) return;
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
      panel.classList.toggle('expanded', !isExpanded);
    });
  });

  // ── FAQ accordion ─────────────────────────────────────────────────────────
  document.querySelectorAll('.faq-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item') as HTMLElement;
      const content = item.querySelector('.faq-content') as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as HTMLElement;
      const isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden', isOpen);
      chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
    });
  });
</script>

</Layout>

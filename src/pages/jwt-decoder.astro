            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full" style="background: var(--accent2);"></div>
              <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--fg);">Payload</span>
            </div>
            <button data-copy="payload"

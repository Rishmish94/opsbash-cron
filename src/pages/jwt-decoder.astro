---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a JWT decoder?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A JWT decoder is a tool that reads a JSON Web Token and displays its contents in plain readable JSON. A JWT has three parts separated by dots: the header, the payload, and the signature. The header describes the algorithm used to sign the token. The payload contains the actual claims like user ID, expiry time, and issuer. Decoding simply means reading these parts, which are Base64 encoded, not encrypted."
      }
    },
    {
      "@type": "Question",
      "name": "Can I decode a JWT without a secret key?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Decoding a JWT does not require a secret key because the token is encoded not encrypted. Anyone with the token can read the header and payload by Base64 decoding them. The secret key is only needed to verify the signature, which proves the token was issued by a trusted source and has not been tampered with. This tool decodes but does not verify."
      }
    },
    {
      "@type": "Question",
      "name": "What information can I see after decoding a JWT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "After decoding you can see everything in the header and payload. The header typically shows the token type and signing algorithm such as HS256 or RS256. The payload shows claims like sub which is the subject or user identifier, iss which is the issuer, exp which is the expiry timestamp, and iat which is the time the token was issued. Applications can also add custom claims for their own purposes."
      }
    },
    {
      "@type": "Question",
      "name": "Is it safe to decode JWT tokens online?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It is safe when the tool runs entirely in your browser without sending data to a server. This tool processes everything locally using JavaScript. Your token never leaves your machine. That said avoid pasting tokens that are still active and grant access to sensitive production systems in any public tool as a general security practice."
      }
    },
    {
      "@type": "Question",
      "name": "How do I decode a JWT in JavaScript?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can decode a JWT in JavaScript by splitting the token on the dot character, taking the second part which is the payload, and passing it to atob() to Base64 decode it, then parsing the result with JSON.parse(). For production use the jsonwebtoken library on Node.js handles both decoding and verification and is the industry standard."
      }
    },
    {
      "@type": "Question",
      "name": "What are the three parts of a JWT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A JWT consists of three Base64 encoded sections separated by dots. The first is the header which contains the token type and algorithm. The second is the payload which contains the claims or data. The third is the signature which is created by signing the header and payload with a secret key. The signature cannot be decoded, only verified using the original key."
      }
    }
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "JWT Token Decoder",
  "url": "https://opsbash.com/jwt-decoder",
  "description": "Decode JWT tokens instantly in your browser. View header, payload and expiry in plain text. No login required, nothing is uploaded.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<Layout
  title="JWT Decoder – Free Online Token Decoder | OpsBash"
  description="Decode JSON Web Tokens instantly with our free online JWT Decoder. View token header, payload and claims securely. No data is sent to any server."
  canonicalURL="https://opsbash.com/jwt-decoder"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />

<div style="background: var(--bg);">
<div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">


---
import Layout from '../../layouts/Layout.astro';

const skills = [
  'Docker', 'Kubernetes', 'Helm', 'GitHub Actions', 'Jenkins',
  'AWS', 'Terraform', 'Ansible', 'Linux', 'Nginx',
];

const articles = [
  { title: "AWS EventBridge Cron Isn't Unix Cron: Here's Where It Breaks",         slug: 'eventbridge-cron-vs-unix-cron' },
  { title: "Why Your /24 Subnet Only Has 251 Usable IPs (Not 254)",                slug: 'aws-subnet-usable-ips-not-254' },
  { title: "Why chmod 777 in Your Dockerfile Is a Code Smell",                      slug: 'chmod-777-dockerfile-code-smell' },
  { title: "Why Your docker run Command Works But the Equivalent Compose File Doesn't", slug: 'docker-run-vs-compose-networking' },
  { title: "The .gitignore Patterns That Don't Do What You Think",                  slug: 'gitignore-negation-wildcards-explained' },
  { title: "Decoding a JWT Is Not Verifying It",                                    slug: 'jwt-decode-vs-verify' },
  { title: "Why Your Logs Show Epoch Timestamps Instead of Dates",                  slug: 'why-your-logs-show-epoch-timestamps' },
  { title: "The YAML Norway Problem and Other Implicit Type Coercions",              slug: 'yaml-norway-problem-type-coercion' },
];
---

<Layout
  title="Rishabh Mishra | OpsBash"
  description="Rishabh Mishra is a freelance DevOps engineer who built OpsBash. He writes about Docker, Kubernetes, CI/CD, AWS, Terraform, and Linux."
  canonicalURL="https://opsbash.com/author/rishabh"
>
<main class="w-full max-w-3xl mx-auto px-4 py-16">

  <!-- Header -->
  <div class="mb-10">
    <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--fg2);">Author</p>
    <h1 class="text-3xl font-bold tracking-tight mb-1" style="color: var(--fg);">Rishabh Mishra</h1>
    <p class="text-sm" style="color: var(--fg2);">DevOps Engineer · Freelance · Content Creator</p>
  </div>

  <div class="space-y-5">

    <!-- Bio -->
    <div class="rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);">
      <h2 class="text-sm font-semibold mb-3" style="color: var(--fg);">About</h2>
      <p class="text-sm leading-relaxed" style="color: var(--fg2);">
        Freelance DevOps engineer working with Docker, Kubernetes, CI/CD pipelines, AWS, Terraform, and Ansible. Built OpsBash to replace the cluttered, inaccurate DevOps tools I kept running into — every tool here exists because I needed it myself.
      </p>
    </div>

    <!-- Skills -->
    <div class="rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);">
      <h2 class="text-sm font-semibold mb-4" style="color: var(--fg);">What I work with</h2>
      <div class="flex flex-wrap gap-2">
        {skills.map(skill => (
          <span
            class="text-xs font-medium px-3 py-1 rounded-full font-mono"
            style="background: var(--surface-hover); border: 1px solid var(--border); color: var(--fg);"
          >
            {skill}
          </span>
        ))}
      </div>
    </div>

    <!-- Links -->
    <div class="rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);">
      <h2 class="text-sm font-semibold mb-4" style="color: var(--fg);">Links</h2>
      <ul class="space-y-3">

        <li>
          <a href="https://www.linkedin.com/in/rishmish94/" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-3 text-sm transition-colors author-link">
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span>linkedin.com/in/rishmish94</span>
          </a>
        </li>

        <li>
          <a href="https://www.youtube.com/@Rishabhmishradevops" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-3 text-sm transition-colors author-link">
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
            <span>youtube.com/@Rishabhmishradevops</span>
          </a>
        </li>

        <li>
          <a href="https://github.com/Rishmish94/opsbash-cron" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-3 text-sm transition-colors author-link">
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
            <span>github.com/Rishmish94/opsbash-cron</span>
          </a>
        </li>

      </ul>
    </div>

    <!-- Articles -->
    <div class="rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);">
      <h2 class="text-sm font-semibold mb-4" style="color: var(--fg);">Articles</h2>
      <ul class="space-y-1">
        {articles.map(article => (
          <li>
            <a
              href={`/blog/${article.slug}`}
              class="flex items-start gap-3 py-2.5 text-sm article-link"
              style="text-decoration: none; border-bottom: 1px solid var(--border);"
            >
              <span class="shrink-0 mt-0.5" style="color: var(--fg2);">→</span>
              <span style="color: var(--fg);">{article.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

  </div>

</main>
</Layout>

<style>
  .author-link {
    color: var(--fg2);
    text-decoration: none;
  }
  .author-link:hover {
    color: var(--fg);
  }

  .article-link:last-child {
    border-bottom: none !important;
  }
  .article-link:hover span:last-child {
    text-decoration: underline;
  }
</style>

---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.data.slug },
    props:  { post },
  }));
}

const { post }        = Astro.props;
const { Content }     = await render(post);
const canonicalURL    = `https://opsbash.com/blog/${post.data.slug}`;
const ogImage         = `https://opsbash.com${encodeURI(post.data.image)}`;
---

<Layout
  title={`${post.data.title} | OpsBash`}
  description={post.data.description}
  canonicalURL={canonicalURL}
  ogTitle={post.data.title}
  ogDescription={post.data.description}
>
  <!-- OG image injected via named head slot -->
  <meta slot="head" property="og:image" content={ogImage} />

  <article style="max-width:720px;margin:0 auto;padding:48px 20px 96px;">

    <!-- Category + date -->
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
      <span class="cat-pill">{post.data.category}</span>
      <time style="font-size:13px;color:var(--text-secondary);font-family:'Inter',sans-serif;">{post.data.date}</time>
    </div>

    <!-- Title -->
    <h1 style="font-size:clamp(26px,4vw,38px);font-weight:700;color:#F8FAFC;line-height:1.2;margin-bottom:28px;font-family:'Inter',sans-serif;letter-spacing:-0.02em;">
      {post.data.title}
    </h1>

    <!-- Hero image -->
    <img
      src={post.data.image}
      alt={post.data.title}
      style="width:100%;height:auto;max-height:420px;object-fit:cover;border-radius:8px;margin-bottom:44px;display:block;"
      loading="eager"
    />

    <!-- Markdown body -->
    <div class="post-content">
      <Content />
    </div>

    <!-- CTA card -->
    <div class="cta-card">
      <p style="font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#34d399;margin-bottom:10px;font-family:'JetBrains Mono',monospace;">
        Try it yourself
      </p>
      <h2 style="font-size:20px;font-weight:700;color:var(--text-primary);margin-bottom:20px;font-family:'Inter',sans-serif;">
        {post.data.tool.name}
      </h2>
      <a href={post.data.tool.url} class="cta-btn">
        Open the {post.data.tool.name} →
      </a>
    </div>

  </article>
</Layout>

<script>
  document.querySelectorAll('.post-content pre').forEach(pre => {
    const wrap = document.createElement('div');
    wrap.className = 'copy-code-wrap';
    pre.parentNode!.insertBefore(wrap, pre);
    wrap.appendChild(pre);

    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.setAttribute('aria-label', 'Copy code to clipboard');
    btn.textContent = 'Copy';

    btn.addEventListener('click', async () => {
      const text = pre.querySelector('code')?.textContent ?? pre.textContent ?? '';
      try {
        await navigator.clipboard.writeText(text);
        btn.textContent = 'Copied!';
        btn.dataset.copied = 'true';
        setTimeout(() => {
          btn.textContent = 'Copy';
          delete btn.dataset.copied;
        }, 2000);
      } catch {
        btn.textContent = 'Failed';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      }
    });

    wrap.appendChild(btn);
  });
</script>

<style>
  /* ── Category pill ──────────────────────────────────────────────────────── */
  .cat-pill {
    display: inline-block;
    padding: 2px 8px;
    border: 1px solid #F8FAFC;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #F8FAFC;
    font-family: 'JetBrains Mono', monospace;
    white-space: nowrap;
  }

  /* ── Prose ──────────────────────────────────────────────────────────────── */
  .post-content {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-secondary);
    font-family: 'Inter', sans-serif;
  }

  /* Suppress the duplicate H1 (identical to the title above) */
  .post-content :global(h1:first-child) { display: none; }

  .post-content :global(h2) {
    font-size: 22px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 52px 0 16px;
    line-height: 1.3;
    font-family: 'Inter', sans-serif;
    letter-spacing: -0.01em;
  }
  .post-content :global(h3) {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    margin: 36px 0 12px;
    line-height: 1.35;
    font-family: 'Inter', sans-serif;
  }
  .post-content :global(p)  { margin-bottom: 22px; }
  .post-content :global(a)  { color: #34d399; text-decoration: none; }
  .post-content :global(a:hover) { text-decoration: underline; color: #6ee7b7; }

  .post-content :global(ul),
  .post-content :global(ol) { margin: 0 0 22px 24px; }
  .post-content :global(li) { margin-bottom: 6px; }

  .post-content :global(strong) { color: var(--text-primary); font-weight: 600; }
  .post-content :global(em)     { font-style: italic; }

  /* Inline code */
  .post-content :global(code) {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 13.5px;
    background: var(--surface-primary);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 6px;
    color: #F8FAFC;
  }

  /* Code blocks (Shiki wraps in <pre><code>) */
  .post-content :global(pre) {
    background: #111111 !important;
    border: 1px solid #222222;
    border-radius: 8px;
    padding: 20px 22px;
    overflow-x: auto;
    margin: 28px 0;
    line-height: 1.6;
  }
  .post-content :global(pre code) {
    background: none !important;
    border: none !important;
    padding: 0 !important;
    font-size: 13.5px;
    color: inherit;
  }

  /* Tables */
  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 28px 0;
    font-size: 14px;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .post-content :global(th) {
    background: var(--surface-primary);
    color: var(--text-primary);
    font-weight: 600;
    padding: 10px 14px;
    border: 1px solid #222222;
    text-align: left;
    white-space: nowrap;
  }
  .post-content :global(td) {
    padding: 9px 14px;
    border: 1px solid #222222;
    color: var(--text-secondary);
    vertical-align: top;
  }
  .post-content :global(tr:hover td) { background: var(--surface-primary); }

  .post-content :global(blockquote) {
    border-left: 3px solid #F8FAFC;
    padding-left: 18px;
    margin: 28px 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 40px 0;
  }

  /* ── Copy button ─────────────────────────────────────────────────────────── */
  .post-content :global(.copy-code-wrap) {
    position: relative;
  }
  .post-content :global(.copy-btn) {
    position: absolute;
    top: 8px;
    right: 8px;
    background: #1A1A1A;
    border: 1px solid #333333;
    color: #94A3B8;
    border-radius: 4px;
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    padding: 4px 8px;
    line-height: 1;
    cursor: pointer;
    z-index: 1;
    transition: border-color 150ms ease, color 150ms ease;
  }
  .post-content :global(.copy-btn:hover) {
    border-color: #F8FAFC;
    color: #F8FAFC;
  }
  .post-content :global(.copy-btn[data-copied]) {
    color: #34d399;
    border-color: #34d399;
  }

  /* ── CTA card ────────────────────────────────────────────────────────────── */
  .cta-card {
    margin-top: 64px;
    padding: 36px 32px;
    background: #111111;
    border: 1px solid #222222;
    border-radius: 12px;
  }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: #F8FAFC;
    border: 1px solid #F8FAFC;
    padding: 13px 28px;
    border-radius: 9999px;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: background 200ms ease, box-shadow 200ms ease;
  }
  .cta-btn:hover {
    background: rgba(248, 250, 252, 0.08);
    box-shadow: 0 0 20px rgba(248, 250, 252, 0.1);
  }
</style>

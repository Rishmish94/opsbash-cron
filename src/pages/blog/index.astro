---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog');
const sorted   = allPosts.sort((a, b) => a.id.localeCompare(b.id));
const featured = sorted.find(p => p.data.slug === 'eventbridge-cron-vs-unix-cron')!;
const rest     = sorted.filter(p => p.data.slug !== 'eventbridge-cron-vs-unix-cron');
---

<Layout
  title="Blogs | OpsBash"
  description="DevOps tutorials, guides, and deep dives for engineers who work with Linux, AWS, Kubernetes, and CI/CD pipelines."
  canonicalURL="https://opsbash.com/blog"
>
<main class="max-w-[1280px] mx-auto px-5" style="padding-top:56px;padding-bottom:96px;">

  <!-- ── Heading ─────────────────────────────────────────────────────────── -->
  <div class="text-center" style="margin-bottom:52px;">
    <p style="font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#34d399;margin-bottom:12px;font-family:'JetBrains Mono',monospace;">From the Blogs</p>
    <h1 style="font-size:40px;font-weight:700;color:var(--text-primary);font-family:'Inter',sans-serif;letter-spacing:-0.02em;margin-bottom:12px;">
      Latest Posts
    </h1>
    <p style="font-size:16px;color:var(--text-secondary);max-width:540px;margin:0 auto;line-height:1.6;">
      Deep dives for engineers who work with Linux, AWS, Kubernetes, and CI/CD.
    </p>
  </div>

  <!-- ── Featured / hero card ────────────────────────────────────────────── -->
  {featured && (
    <a href={`/blog/${featured.data.slug}`} class="hero-card" style="text-decoration:none;display:block;margin-bottom:52px;">
      <div class="hero-inner">
        <div class="hero-img-wrap">
          <img
            src={featured.data.image}
            alt={featured.data.title}
            class="hero-img"
            loading="eager"
          />
        </div>
        <div class="hero-body">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
            <span class="cat-pill">{featured.data.category}</span>
            <time style="font-size:12px;color:var(--text-secondary);font-family:'Inter',sans-serif;">{featured.data.date}</time>
          </div>
          <h2 class="hero-title">{featured.data.title}</h2>
          <p class="hero-desc">{featured.data.description}</p>
          <span style="font-size:13px;font-weight:500;color:#F8FAFC;margin-top:auto;padding-top:20px;display:block;">Read post →</span>
        </div>
      </div>
    </a>
  )}

  <!-- ── Grid of remaining 6 posts ───────────────────────────────────────── -->
  {rest.length > 0 && (
    <div class="blog-grid">
      {rest.map(post => (
        <a href={`/blog/${post.data.slug}`} class="blog-card" style="text-decoration:none;">
          <div class="card-img-wrap">
            <img
              src={post.data.image}
              alt={post.data.title}
              class="card-img"
              loading="lazy"
            />
          </div>
          <div style="padding:20px;">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
              <span class="cat-pill">{post.data.category}</span>
              <time style="font-size:11px;color:var(--text-secondary);font-family:'Inter',sans-serif;">{post.data.date}</time>
            </div>
            <h3 class="card-title">{post.data.title}</h3>
            <p class="card-desc">{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  )}

</main>
</Layout>

<style>
  /* ── Category pill ──────────────────────────────────────────────────────── */
  .cat-pill {
    display: inline-block;
    padding: 2px 8px;
    border: 1px solid #F8FAFC;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #F8FAFC;
    font-family: 'JetBrains Mono', monospace;
    white-space: nowrap;
  }

  /* ── Hero card ──────────────────────────────────────────────────────────── */
  .hero-card { cursor: pointer; }
  .hero-inner {
    display: grid;
    grid-template-columns: 45% 55%;
    background: #111111;
    border: 1px solid #222222;
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s ease;
    min-height: 360px;
  }
  .hero-card:hover .hero-inner { border-color: #F8FAFC; }
  .hero-img-wrap { overflow: hidden; }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .hero-card:hover .hero-img { transform: scale(1.04); }
  .hero-body {
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero-title {
    font-size: 26px;
    font-weight: 700;
    color: #F8FAFC;
    line-height: 1.3;
    margin-bottom: 14px;
    font-family: 'Inter', sans-serif;
    letter-spacing: -0.015em;
  }
  .hero-desc {
    font-size: 14px;
    color: #94A3B8;
    line-height: 1.65;
    font-family: 'Inter', sans-serif;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Post grid ──────────────────────────────────────────────────────────── */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .blog-card {
    background: #111111;
    border: 1px solid #222222;
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .blog-card:hover { border-color: #F8FAFC; background: #1A1A1A; }
  .card-img-wrap { overflow: hidden; }
  .card-img {
    width: 100%;
    height: 196px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .blog-card:hover .card-img { transform: scale(1.04); }
  .card-title {
    font-size: 15px;
    font-weight: 600;
    color: #F8FAFC;
    line-height: 1.4;
    margin-bottom: 8px;
    font-family: 'Inter', sans-serif;
  }
  .card-desc {
    font-size: 13px;
    color: #94A3B8;
    line-height: 1.6;
    font-family: 'Inter', sans-serif;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Responsive ─────────────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .hero-img { height: 240px; }
    .hero-body { padding: 24px 20px; }
    .hero-title { font-size: 20px; }
  }
  @media (max-width: 600px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact OpsBash — Get in Touch"
  description="Contact the OpsBash team. Email contact@opsbash.com for bug reports, feature requests, or general questions. We respond within 48 hours."
  canonicalURL="https://opsbash.com/contact"
>
<main class="w-full max-w-3xl mx-auto px-4 py-16">

  <div class="mb-10">
    <p class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 uppercase tracking-wider mb-3">Contact</p>
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white tracking-tight mb-2">Get in touch</h1>
    <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">
      Found a bug? Have a feature request? Spotted incorrect output from one of the tools? We read every message and respond within 48 hours.
    </p>
  </div>

  <!-- Contact cards -->
  <div class="grid sm:grid-cols-2 gap-5 mb-8">

    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 shadow-sm">
      <div class="w-9 h-9 rounded-xl bg-indigo-50 dark:bg-indigo-950/50 border border-indigo-100 dark:border-indigo-900 flex items-center justify-center mb-4">
        <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
        </svg>
      </div>
      <h2 class="text-sm font-semibold text-gray-900 dark:text-white mb-1">Email</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">For bugs, feature requests, or general questions.</p>
      <a href="mailto:contact@opsbash.com" class="text-xs text-indigo-600 dark:text-indigo-400 font-medium hover:underline font-mono">contact@opsbash.com</a>
    </div>

    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 shadow-sm">
      <div class="w-9 h-9 rounded-xl bg-green-50 dark:bg-green-950/40 border border-green-100 dark:border-green-900 flex items-center justify-center mb-4">
        <svg class="w-4 h-4 text-green-600 dark:text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <h2 class="text-sm font-semibold text-gray-900 dark:text-white mb-1">Response time</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">We aim to respond to all messages within 48 hours. For urgent issues with the cron builder, please include the specific expression and platform.</p>
      <span class="text-xs text-green-600 dark:text-green-400 font-medium">Within 48 hours</span>
    </div>

  </div>

  <!-- Link back to the tool -->
  <div class="bg-indigo-50 dark:bg-indigo-950/30 border border-indigo-100 dark:border-indigo-900 rounded-2xl p-5 mb-8 flex items-center justify-between gap-4">
    <div>
      <p class="text-sm font-medium text-gray-900 dark:text-white mb-1">Need help with a cron expression?</p>
      <p class="text-xs text-gray-500 dark:text-gray-400">Use the free visual generator — no sign-up required.</p>
    </div>
    <a href="/cron-builder"
      class="shrink-0 inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-medium px-4 py-2 rounded-lg transition-colors whitespace-nowrap">
      Open Cron Builder
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>

  <!-- Contact form -->
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-sm overflow-hidden">
    <div class="p-6 border-b border-gray-100 dark:border-gray-800">
      <h2 class="text-base font-semibold text-gray-900 dark:text-white">Send a message</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Alternatively, email us directly at <a href="mailto:contact@opsbash.com" class="text-indigo-600 dark:text-indigo-400 hover:underline font-mono">contact@opsbash.com</a>.</p>
    </div>
    <form id="contactForm" class="p-6 space-y-4" novalidate>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1.5">Name</label>
          <input type="text" name="name" required
            class="w-full text-sm bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-3.5 py-2.5 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/40 focus:border-indigo-500 transition-all placeholder:text-gray-400"
            placeholder="Your name" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1.5">Email</label>
          <input type="email" name="email" required
            class="w-full text-sm bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-3.5 py-2.5 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/40 focus:border-indigo-500 transition-all placeholder:text-gray-400"
            placeholder="you@example.com" />
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1.5">Subject</label>
        <select name="subject"
          class="w-full text-sm bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-3.5 py-2.5 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/40 focus:border-indigo-500 transition-all">
          <option value="bug">Bug report — tool producing wrong output</option>
          <option value="feature">Feature request</option>
          <option value="question">General question</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1.5">Message</label>
        <textarea name="message" rows="5" required
          class="w-full text-sm bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-3.5 py-2.5 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/40 focus:border-indigo-500 transition-all placeholder:text-gray-400 resize-none"
          placeholder="Describe your issue, question, or feature idea…"></textarea>
      </div>
      <div id="formMsg" class="hidden rounded-xl px-4 py-3 text-sm"></div>
      <button type="submit"
        class="w-full sm:w-auto bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-6 py-2.5 rounded-xl transition-colors flex items-center justify-center gap-2">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        Send message
      </button>
    </form>
  </div>

  <script>
    document.getElementById('contactForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const msg = document.getElementById('formMsg');
      msg.textContent = 'Thanks for reaching out! This form is not yet wired up — please email contact@opsbash.com directly and we\'ll get back to you within 48 hours.';
      msg.className = 'rounded-xl px-4 py-3 text-sm bg-indigo-50 dark:bg-indigo-950/40 text-indigo-700 dark:text-indigo-300 border border-indigo-100 dark:border-indigo-900';
    });
  </script>

</main>
</Layout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact | OpsBash"
  description="Contact the OpsBash team. Email contact@opsbash.com for bug reports, feature requests, or general questions. We respond within 48 hours."
  canonicalURL="https://opsbash.com/contact"
>
<main class="w-full max-w-3xl mx-auto px-4 py-16">

  <div class="mb-10">
    <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: #34d399;">Contact</p>
    <h1 class="text-3xl font-bold tracking-tight mb-2" style="color: var(--fg);">Get in touch</h1>
    <p class="text-sm leading-relaxed" style="color: var(--fg2);">
      Found a bug? Have a feature request? Spotted incorrect output from one of the tools? We read every message and respond within 48 hours.
    </p>
  </div>

  <!-- Contact cards -->
  <div class="grid sm:grid-cols-2 gap-5 mb-8">

    <div class="rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);">
      <div class="w-9 h-9 rounded-xl flex items-center justify-center mb-4"
           style="background: #0f2415; border: 1px solid #1a3a22;">
        <svg class="w-4 h-4" style="color: #34d399;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
        </svg>
      </div>
      <h2 class="text-sm font-semibold mb-1" style="color: var(--fg);">Email</h2>
      <p class="text-xs mb-3" style="color: var(--fg2);">For bugs, feature requests, or general questions.</p>
      <a href="mailto:contact@opsbash.com" class="text-xs font-medium hover:underline font-mono" style="color: #34d399;">contact@opsbash.com</a>
    </div>

    <div class="rounded-2xl p-6" style="background: var(--card); border: 1px solid var(--border);">
      <div class="w-9 h-9 rounded-xl flex items-center justify-center mb-4"
           style="background: #0f2415; border: 1px solid #1a3a22;">
        <svg class="w-4 h-4" style="color: #34d399;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <h2 class="text-sm font-semibold mb-1" style="color: var(--fg);">Response time</h2>
      <p class="text-xs mb-3" style="color: var(--fg2);">We aim to respond to all messages within 48 hours. For urgent issues with the cron builder, please include the specific expression and platform.</p>
      <span class="text-xs font-medium" style="color: #34d399;">Within 48 hours</span>
    </div>

  </div>

  <!-- Link back to the tool -->
  <div class="rounded-2xl p-5 mb-8 flex items-center justify-between gap-4"
       style="background: rgba(16,185,129,0.06); border: 1px solid rgba(16,185,129,0.2);">
    <div>
      <p class="text-sm font-medium mb-1" style="color: var(--fg);">Need help with a cron expression?</p>
      <p class="text-xs" style="color: var(--fg2);">Use the free visual generator — no sign-up required.</p>
    </div>
    <a href="/cron-builder"
      class="shrink-0 inline-flex items-center gap-2 text-xs font-medium px-4 py-2 rounded-lg transition-colors whitespace-nowrap"
      style="background: linear-gradient(135deg, #10b981, #059669); color: #fff;">
      Open Cron Builder
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>

  <!-- Contact form -->
  <div class="rounded-2xl overflow-hidden" style="background: var(--card); border: 1px solid var(--border);">
    <div class="p-6" style="border-bottom: 1px solid var(--border);">
      <h2 class="text-base font-semibold" style="color: var(--fg);">Send a message</h2>
      <p class="text-xs mt-1" style="color: var(--fg2);">Alternatively, email us directly at <a href="mailto:contact@opsbash.com" class="hover:underline font-mono" style="color: #34d399;">contact@opsbash.com</a>.</p>
    </div>
    <form id="contactForm" action="https://api.web3forms.com/submit" method="POST" class="p-6 space-y-4" novalidate>
      <input type="hidden" name="access_key" value="d09a0701-17b4-43e8-999f-eee22e7cca3c">
      <input type="checkbox" name="botcheck" style="display:none">
      <input type="hidden" name="subject" value="New message from OpsBash contact form">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium mb-1.5" style="color: var(--fg2);">Name</label>
          <input type="text" name="name" required
            class="w-full text-sm rounded-xl px-3.5 py-2.5 focus:outline-none transition-all placeholder:opacity-40"
            style="background: var(--bg); border: 1px solid var(--border); color: var(--fg);"
            onfocus="this.style.borderColor='#10b981'; this.style.boxShadow='0 0 0 3px rgba(16,185,129,0.15)'"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none'"
            placeholder="Your name" />
        </div>
        <div>
          <label class="block text-xs font-medium mb-1.5" style="color: var(--fg2);">Email</label>
          <input type="email" name="email" required
            class="w-full text-sm rounded-xl px-3.5 py-2.5 focus:outline-none transition-all placeholder:opacity-40"
            style="background: var(--bg); border: 1px solid var(--border); color: var(--fg);"
            onfocus="this.style.borderColor='#10b981'; this.style.boxShadow='0 0 0 3px rgba(16,185,129,0.15)'"
            onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none'"
            placeholder="you@example.com" />
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium mb-1.5" style="color: var(--fg2);">Subject</label>
        <select name="subject"
          class="w-full text-sm rounded-xl px-3.5 py-2.5 focus:outline-none transition-all"
          style="background: var(--bg); border: 1px solid var(--border); color: var(--fg);"
          onfocus="this.style.borderColor='#10b981'; this.style.boxShadow='0 0 0 3px rgba(16,185,129,0.15)'"
          onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
          <option value="bug">Bug report — tool producing wrong output</option>
          <option value="feature">Feature request</option>
          <option value="question">General question</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium mb-1.5" style="color: var(--fg2);">Message</label>
        <textarea name="message" rows="5" required
          class="w-full text-sm rounded-xl px-3.5 py-2.5 focus:outline-none transition-all placeholder:opacity-40 resize-none"
          style="background: var(--bg); border: 1px solid var(--border); color: var(--fg);"
          onfocus="this.style.borderColor='#10b981'; this.style.boxShadow='0 0 0 3px rgba(16,185,129,0.15)'"
          onblur="this.style.borderColor='var(--border)'; this.style.boxShadow='none'"
          placeholder="Describe your issue, question, or feature idea…"></textarea>
      </div>
      <div id="formMsg" class="hidden rounded-xl px-4 py-3 text-sm"></div>
      <button type="submit"
        class="w-full sm:w-auto text-sm font-medium px-6 py-2.5 rounded-xl transition-all flex items-center justify-center gap-2"
        style="background: linear-gradient(135deg, #10b981, #059669); color: #fff; box-shadow: 0 2px 8px rgba(16,185,129,0.25);">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        Send message
      </button>
    </form>
  </div>

  <script>
    document.getElementById('contactForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const msg = document.getElementById('formMsg');
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: new FormData(this),
        });
        const data = await res.json();
        if (data.success) {
          msg.textContent = "Message sent! We'll get back to you within 48 hours.";
          msg.className = 'rounded-xl px-4 py-3 text-sm';
          msg.style.cssText = 'background: rgba(16,185,129,0.08); color: #34d399; border: 1px solid rgba(16,185,129,0.2);';
          this.reset();
        } else {
          throw new Error(data.message || 'Submission failed');
        }
      } catch {
        msg.textContent = 'Something went wrong. Please email contact@opsbash.com directly.';
        msg.className = 'rounded-xl px-4 py-3 text-sm';
        msg.style.cssText = 'background: rgba(239,68,68,0.08); color: #f87171; border: 1px solid rgba(239,68,68,0.2);';
      }
      msg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  </script>

</main>
</Layout>

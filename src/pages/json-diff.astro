</style>

<script>
  // ── Helpers ──────────────────────────────────────────────────────────────────
  function escHtml(s) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  function sortKeysDeep(val) {
    if (Array.isArray(val)) return val.map(sortKeysDeep);
    if (val !== null && typeof val === 'object') {
      return Object.fromEntries(
        Object.keys(val).sort().map(function(k) { return [k, sortKeysDeep(val[k])]; })
      );
    }
    return val;
  }

  function copyText(text, btn) {
    var origText = btn.textContent;
    function flash() {
      btn.textContent = 'Copied!';
      setTimeout(function() { btn.textContent = origText; }, 1500);
    }
    function fallback() {
      var ta = document.createElement('textarea');
      ta.value = text;
      ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0';
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); } catch(e) {}
      document.body.removeChild(ta);
    }
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(flash).catch(function() { fallback(); flash(); });
    } else {
      fallback(); flash();
    }
  }

  // ── LCS-based line diff ────────────────────────────────────────────────────
  function diffLines(aLines, bLines) {
    var m = aLines.length, n = bLines.length;
    var dp = [];
    var i, j;
    for (i = 0; i <= m; i++) {
      dp[i] = [];
      for (j = 0; j <= n; j++) dp[i][j] = 0;
    }
    for (i = 1; i <= m; i++) {
      for (j = 1; j <= n; j++) {
        if (aLines[i-1] === bLines[j-1]) dp[i][j] = dp[i-1][j-1] + 1;
        else dp[i][j] = dp[i-1][j] > dp[i][j-1] ? dp[i-1][j] : dp[i][j-1];
      }
    }
    var result = [];
    i = m; j = n;
    while (i > 0 || j > 0) {
      if (i > 0 && j > 0 && aLines[i-1] === bLines[j-1]) {
        result.unshift({ type: 'same', line: aLines[i-1] });
        i--; j--;
      } else if (j > 0 && (i === 0 || dp[i][j-1] >= dp[i-1][j])) {
        result.unshift({ type: 'add', line: bLines[j-1] });
        j--;
      } else {
        result.unshift({ type: 'remove', line: aLines[i-1] });
        i--;
      }
    }
    return result;
  }

  // ── Section 1: JSON Diff ─────────────────────────────────────────────────
  var diffOrigEl     = document.getElementById('diffOriginal');
  var diffModEl      = document.getElementById('diffModified');
  var diffOrigErrEl  = document.getElementById('diffOrigError');
  var diffModErrEl   = document.getElementById('diffModError');
  var diffCompareBtnEl = document.getElementById('diffCompareBtn');
  var diffResultEl   = document.getElementById('diffResult');
  var diffSummaryEl  = document.getElementById('diffSummary');
  var diffOutputEl   = document.getElementById('diffOutput');

  // Populate placeholder values
  var DIFF_ORIG_PLACEHOLDER = JSON.stringify({
    "name": "api-service",
    "version": "1.2.0",
    "replicas": 3,
    "resources": { "cpu": "500m", "memory": "256Mi" }
  }, null, 2);

  var DIFF_MOD_PLACEHOLDER = JSON.stringify({
    "env": "production",
    "name": "api-service",
    "replicas": 5,
    "resources": { "cpu": "500m", "memory": "512Mi" },
    "version": "1.3.0"
  }, null, 2);

  if (diffOrigEl) diffOrigEl.value = DIFF_ORIG_PLACEHOLDER;
  if (diffModEl)  diffModEl.value  = DIFF_MOD_PLACEHOLDER;

  diffCompareBtnEl.addEventListener('click', function() {
    var origRaw = diffOrigEl.value.trim();
    var modRaw  = diffModEl.value.trim();

    diffOrigErrEl.classList.add('hidden');
    diffModErrEl.classList.add('hidden');
    diffResultEl.classList.add('hidden');

    if (!origRaw && !modRaw) return;

    var origParsed, modParsed, origErr = false, modErr = false;

    if (!origRaw) {
      origErr = true;
      diffOrigErrEl.textContent = 'Input is empty.';
      diffOrigErrEl.classList.remove('hidden');
    } else {
      try { origParsed = JSON.parse(origRaw); }
      catch(e) {
        origErr = true;
        diffOrigErrEl.textContent = 'Parse error: ' + e.message;
        diffOrigErrEl.classList.remove('hidden');
      }
    }

    if (!modRaw) {
      modErr = true;
      diffModErrEl.textContent = 'Input is empty.';
      diffModErrEl.classList.remove('hidden');
    } else {
      try { modParsed = JSON.parse(modRaw); }
      catch(e) {
        modErr = true;
        diffModErrEl.textContent = 'Parse error: ' + e.message;
        diffModErrEl.classList.remove('hidden');
      }
    }

    if (origErr || modErr) return;

    var origNorm = JSON.stringify(sortKeysDeep(origParsed), null, 2).split('\n');
    var modNorm  = JSON.stringify(sortKeysDeep(modParsed),  null, 2).split('\n');

    var diff = diffLines(origNorm, modNorm);

    var additions = 0, deletions = 0, unchanged = 0;
    diff.forEach(function(d) {
      if (d.type === 'add') additions++;
      else if (d.type === 'remove') deletions++;
      else unchanged++;
    });

    diffSummaryEl.textContent =
      additions + ' addition' + (additions !== 1 ? 's' : '') +
      ' · ' + deletions + ' deletion' + (deletions !== 1 ? 's' : '') +
      ' · ' + unchanged + ' unchanged';

    var html = diff.map(function(d) {
      var line = escHtml(d.line);
      if (d.type === 'add') {
        return '<div style="background:rgba(34,197,94,0.15);padding:2px 10px;white-space:pre;overflow-x:auto;">' +
          '<span style="color:#4ADE80;font-family:\'JetBrains Mono\',monospace;font-size:12px;user-select:none;margin-right:8px;">+</span>' +
          '<span style="color:#4ADE80;font-family:\'JetBrains Mono\',monospace;font-size:12px;">' + line + '</span></div>';
      } else if (d.type === 'remove') {
        return '<div style="background:rgba(239,68,68,0.15);padding:2px 10px;white-space:pre;overflow-x:auto;">' +
          '<span style="color:#F87171;font-family:\'JetBrains Mono\',monospace;font-size:12px;user-select:none;margin-right:8px;">-</span>' +
          '<span style="color:#F87171;font-family:\'JetBrains Mono\',monospace;font-size:12px;">' + line + '</span></div>';
      } else {
        return '<div style="padding:2px 10px;white-space:pre;overflow-x:auto;">' +
          '<span style="color:var(--fg2);font-family:\'JetBrains Mono\',monospace;font-size:12px;user-select:none;margin-right:8px;"> </span>' +
          '<span style="color:var(--fg2);font-family:\'JetBrains Mono\',monospace;font-size:12px;">' + line + '</span></div>';
      }
    }).join('');

    diffOutputEl.innerHTML = html;
    diffResultEl.classList.remove('hidden');
  });

  // ── Section 2: Schema Validator ──────────────────────────────────────────
  function validateSchema(data, schema, path) {
    path = path || '';
    var errors = [];

    if (schema.type !== undefined) {
      var types = Array.isArray(schema.type) ? schema.type : [schema.type];
      var dataType;
      if (Array.isArray(data)) dataType = 'array';
      else if (data === null) dataType = 'null';
      else dataType = typeof data;

      if (types.indexOf(dataType) === -1) {
        errors.push((path || 'root') + ': expected type "' + types.join('" or "') + '" but got "' + dataType + '"');
        return errors;
      }
    }

    if (schema.enum !== undefined) {
      var dataStr = JSON.stringify(data);
      var matched = schema.enum.some(function(v) { return JSON.stringify(v) === dataStr; });
      if (!matched) {
        errors.push((path || 'root') + ': value must be one of [' + schema.enum.map(function(v) { return JSON.stringify(v); }).join(', ') + ']');
      }
    }

    if (typeof data === 'string') {
      if (schema.minLength !== undefined && data.length < schema.minLength) {
        errors.push((path || 'root') + ': string length ' + data.length + ' is less than minLength ' + schema.minLength);
      }
      if (schema.maxLength !== undefined && data.length > schema.maxLength) {
        errors.push((path || 'root') + ': string length ' + data.length + ' exceeds maxLength ' + schema.maxLength);
      }
      if (schema.pattern !== undefined) {
        try {
          if (!new RegExp(schema.pattern).test(data)) {
            errors.push((path || 'root') + ': value does not match pattern /' + schema.pattern + '/');
          }
        } catch(e) {
          errors.push((path || 'root') + ': invalid pattern /' + schema.pattern + '/');
        }
      }
    }

    if (typeof data === 'number') {
      if (schema.minimum !== undefined && data < schema.minimum) {
        errors.push((path || 'root') + ': value ' + data + ' is less than minimum ' + schema.minimum);
      }
      if (schema.maximum !== undefined && data > schema.maximum) {
        errors.push((path || 'root') + ': value ' + data + ' exceeds maximum ' + schema.maximum);
      }
    }

    if (data !== null && typeof data === 'object' && !Array.isArray(data)) {
      if (Array.isArray(schema.required)) {
        schema.required.forEach(function(key) {
          if (!(key in data)) {
            errors.push((path || 'root') + ': missing required property "' + key + '"');
          }
        });
      }

      if (schema.properties && typeof schema.properties === 'object') {
        Object.keys(schema.properties).forEach(function(key) {
          if (key in data) {
            var subPath = path ? path + '.' + key : key;
            var sub = validateSchema(data[key], schema.properties[key], subPath);
            sub.forEach(function(e) { errors.push(e); });
          }
        });
      }

      if (schema.additionalProperties === false && schema.properties) {
        var knownKeys = Object.keys(schema.properties);
        Object.keys(data).forEach(function(key) {
          if (knownKeys.indexOf(key) === -1) {
            errors.push((path || 'root') + ': additional property "' + key + '" is not allowed');
          }
        });
      } else if (schema.additionalProperties !== null && schema.additionalProperties !== undefined &&
                 typeof schema.additionalProperties === 'object') {
        var knownKeys2 = schema.properties ? Object.keys(schema.properties) : [];
        Object.keys(data).forEach(function(key) {
          if (knownKeys2.indexOf(key) === -1) {
            var subPath2 = path ? path + '.' + key : key;
            var sub2 = validateSchema(data[key], schema.additionalProperties, subPath2);
            sub2.forEach(function(e) { errors.push(e); });
          }
        });
      }
    }

    if (Array.isArray(data) && schema.items !== undefined) {
      data.forEach(function(item, idx) {
        var subPath3 = path ? path + '[' + idx + ']' : '[' + idx + ']';
        var sub3 = validateSchema(item, schema.items, subPath3);
        sub3.forEach(function(e) { errors.push(e); });
      });
    }

    return errors;
  }

  var schemaDataEl     = document.getElementById('schemaData');
  var schemaSchemaEl   = document.getElementById('schemaSchema');
  var schemaValidateBtn = document.getElementById('schemaValidateBtn');
  var schemaResultEl   = document.getElementById('schemaResult');

  var SCHEMA_DATA_PLACEHOLDER = JSON.stringify({
    "username": "jdoe",
    "age": 30,
    "email": "jdoe@example.com",
    "role": "admin"
  }, null, 2);

  var SCHEMA_SCHEMA_PLACEHOLDER = JSON.stringify({
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["username", "age", "email"],
    "properties": {
      "username": { "type": "string", "minLength": 3, "maxLength": 20 },
      "age": { "type": "number", "minimum": 0, "maximum": 120 },
      "email": { "type": "string", "pattern": "^[^@]+@[^@]+\\.[^@]+$" },
      "role": { "type": "string", "enum": ["admin", "user", "guest"] }
    },
    "additionalProperties": false
  }, null, 2);

  if (schemaDataEl)   schemaDataEl.value   = SCHEMA_DATA_PLACEHOLDER;
  if (schemaSchemaEl) schemaSchemaEl.value = SCHEMA_SCHEMA_PLACEHOLDER;

  schemaValidateBtn.addEventListener('click', function() {
    var dataRaw   = schemaDataEl.value.trim();
    var schemaRaw = schemaSchemaEl.value.trim();

    schemaResultEl.classList.add('hidden');
    schemaResultEl.innerHTML = '';

    if (!dataRaw && !schemaRaw) return;

    var dataVal, schemaVal;

    try { dataVal = JSON.parse(dataRaw || '{}'); }
    catch(e) {
      schemaResultEl.innerHTML = '<div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:10px;padding:14px 16px;"><p style="color:#EF4444;font-size:13px;font-family:\'JetBrains Mono\',monospace;margin:0;">JSON Data parse error: ' + escHtml(e.message) + '</p></div>';
      schemaResultEl.classList.remove('hidden');
      return;
    }

    try { schemaVal = JSON.parse(schemaRaw || '{}'); }
    catch(e) {
      schemaResultEl.innerHTML = '<div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:10px;padding:14px 16px;"><p style="color:#EF4444;font-size:13px;font-family:\'JetBrains Mono\',monospace;margin:0;">JSON Schema parse error: ' + escHtml(e.message) + '</p></div>';
      schemaResultEl.classList.remove('hidden');
      return;
    }

    var errors = validateSchema(dataVal, schemaVal, '');

    if (errors.length === 0) {
      schemaResultEl.innerHTML =
        '<div style="background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.3);border-radius:10px;padding:14px 16px;">' +
        '<p style="color:#4ADE80;font-size:13px;font-weight:600;margin:0;">&#10003; Valid — your JSON matches the schema</p></div>';
    } else {
      var items = errors.map(function(e) {
        return '<li style="padding:3px 0;font-size:12px;font-family:\'JetBrains Mono\',monospace;">' + escHtml(e) + '</li>';
      }).join('');
      schemaResultEl.innerHTML =
        '<div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:10px;padding:14px 16px;">' +
        '<p style="color:#F87171;font-size:13px;font-weight:600;margin:0 0 10px;">✗ Invalid — ' + errors.length + ' error' + (errors.length !== 1 ? 's' : '') + ' found</p>' +
        '<ul style="list-style:disc;padding-left:18px;color:#F87171;margin:0;">' + items + '</ul></div>';
    }

    schemaResultEl.classList.remove('hidden');
  });

  // ── Section 3: JSON Formatter ─────────────────────────────────────────────
  var fmtInputEl    = document.getElementById('fmtInput');
  var fmtBadgeEl    = document.getElementById('fmtBadge');
  var fmtErrorEl    = document.getElementById('fmtError');
  var fmtBigWarn    = document.getElementById('fmtBigWarning');
  var fmtFormatBtn  = document.getElementById('fmtFormatBtn');
  var fmtMinifyBtn  = document.getElementById('fmtMinifyBtn');
  var fmtOutputWrap = document.getElementById('fmtOutputWrap');
  var fmtOutputEl   = document.getElementById('fmtOutput');
  var fmtCopyBtnEl  = document.getElementById('fmtCopyBtn');

  fmtInputEl.addEventListener('input', function() {
    var raw = fmtInputEl.value;

    if (raw.length > 100 * 1024) {
      fmtBigWarn.classList.remove('hidden');
    } else {
      fmtBigWarn.classList.add('hidden');
    }

    if (!raw.trim()) {
      fmtBadgeEl.classList.add('hidden');
      fmtErrorEl.classList.add('hidden');
      return;
    }

    try {
      JSON.parse(raw);
      fmtBadgeEl.textContent = 'Valid JSON';
      fmtBadgeEl.style.background = 'rgba(34,197,94,0.15)';
      fmtBadgeEl.style.color = '#4ADE80';
      fmtBadgeEl.style.borderColor = 'rgba(34,197,94,0.4)';
      fmtBadgeEl.classList.remove('hidden');
      fmtErrorEl.classList.add('hidden');
    } catch(e) {
      fmtBadgeEl.textContent = 'Invalid JSON';
      fmtBadgeEl.style.background = 'rgba(239,68,68,0.15)';
      fmtBadgeEl.style.color = '#F87171';
      fmtBadgeEl.style.borderColor = 'rgba(239,68,68,0.4)';
      fmtBadgeEl.classList.remove('hidden');
      fmtErrorEl.textContent = e.message;
      fmtErrorEl.classList.remove('hidden');
    }
  });

  function runFmt(pretty) {
    var raw = fmtInputEl.value.trim();
    if (!raw) return;
    try {
      var parsed = JSON.parse(raw);
      fmtOutputEl.value = pretty ? JSON.stringify(parsed, null, 2) : JSON.stringify(parsed);
      fmtOutputWrap.classList.remove('hidden');
    } catch(e) {
      // live badge already shows error
    }
  }

  fmtFormatBtn.addEventListener('click', function() { runFmt(true); });
  fmtMinifyBtn.addEventListener('click', function() { runFmt(false); });

  fmtCopyBtnEl.addEventListener('click', function() {
    var text = fmtOutputEl.value;
    if (!text) return;
    copyText(text, fmtCopyBtnEl);
  });

  // ── FAQ accordion ──────────────────────────────────────────────────────────
  document.querySelectorAll('.faq-trigger').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.faq-item');
      var content = item.querySelector('.faq-content');
      var chevron = btn.querySelector('.faq-chevron');
      var open = !content.classList.contains('hidden');
      content.classList.toggle('hidden', open);
      chevron.style.transform = open ? '' : 'rotate(180deg)';
    });
  });
</script>

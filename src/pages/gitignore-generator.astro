        <button class="preset-btn rounded-xl px-4 py-2 text-sm font-medium transition-all"
                style="background: var(--card); border: 1px solid var(--border); color: var(--fg2);"
                data-preset="devops">DevOps</button>
        <button class="preset-btn rounded-xl px-4 py-2 text-sm font-medium transition-all"
                style="background: var(--card); border: 1px solid var(--border); color: var(--fg2);"
                data-preset="java-project">Java Project</button>
        <button class="preset-btn rounded-xl px-4 py-2 text-sm font-medium transition-all"

---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a .gitignore file?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A .gitignore file tells Git which files and directories to ignore when tracking changes in a repository. Any file or pattern listed in it will not be committed. This is essential for keeping build artifacts, dependency folders like node_modules, environment files with secrets, and editor settings out of your codebase. Without one your repository quickly fills up with files that should never have been committed in the first place."
      }
    },
    {
      "@type": "Question",
      "name": "Where should I put the .gitignore file?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Place it in the root directory of your repository. Git reads it automatically when you run any git command. You can also have multiple .gitignore files in subdirectories if you need to ignore files only within specific parts of your project, but a single root level file covers most use cases and is the standard convention."
      }
    },
    {
      "@type": "Question",
      "name": "Can I add a .gitignore file after files have already been committed?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes but there is a catch. Adding a pattern to .gitignore only prevents future tracking of that file. If the file was already committed Git will continue tracking it. To stop tracking a previously committed file run git rm --cached filename first, then commit that change. After that the .gitignore rule takes effect going forward."
      }
    },
    {
      "@type": "Question",
      "name": "Should I commit my .gitignore file to the repository?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, always commit it. It should be one of the first files you add to any new repository. Committing ensures every contributor gets the same ignore rules automatically when they clone the repository, keeping everyone's working directory clean and consistent."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between .gitignore and .gitkeep?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "They serve opposite purposes. A .gitignore file tells Git to ignore certain files. A .gitkeep file is a convention used to force Git to track an otherwise empty directory since Git does not track empty folders by default. The .gitkeep file has no special meaning to Git, it is just a placeholder that developers use by convention."
      }
    },
    {
      "@type": "Question",
      "name": "How do I ignore a file that is already being tracked?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "First add the file pattern to your .gitignore file. Then run git rm --cached filename to remove it from Git's tracking index without deleting the actual file from your disk. Finally commit that change. From that point Git ignores the file even though it still exists locally."
      }
    }
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "gitignore Generator",
  "url": "https://opsbash.com/gitignore-generator",
  "description": "Generate .gitignore files instantly for any technology stack. Select your languages and frameworks and download a clean .gitignore file in one click.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---


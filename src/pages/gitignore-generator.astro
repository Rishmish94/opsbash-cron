  };

  // ── Presets ────────────────────────────────────────────────────────────────
  var PRESETS = {
    'web-frontend':   ['React', 'Node', 'VSCode'],
    'python-project': ['Python', 'Jupyter', 'VSCode'],
    'devops':         ['Docker', 'Kubernetes', 'Terraform', 'Ansible'],
    'java-project':   ['Java', 'Maven', 'Gradle', 'JetBrains'],
    'go-project':     ['Go', 'VSCode'],
    'mobile':         ['Android', 'Flutter', 'Xcode']
  };

  var ALL_TECHS = Object.keys(GITIGNORE_DATA).sort(function (a, b) {
    return a.toLowerCase().localeCompare(b.toLowerCase());
  });

  // ── State ─────────────────────────────────────────────────────────────────
  var selected = [];
  var dropdownOpen = false;

  // ── DOM refs ─────────────────────────────────────────────────────────────
  var techSearch      = document.getElementById('techSearch');
  var techDropdown    = document.getElementById('techDropdown');
  var selectedChips   = document.getElementById('selectedChips');
  var emptyChipsMsg   = document.getElementById('emptyChipsMsg');
  var clearAllBtn     = document.getElementById('clearAllBtn');
  var previewEmpty    = document.getElementById('previewEmpty');
  var previewContent  = document.getElementById('previewContent');
  var lineCount       = document.getElementById('lineCount');
  var copyBtn         = document.getElementById('copyBtn');
  var copyBtnText     = document.getElementById('copyBtnText');
  var downloadBtn     = document.getElementById('downloadBtn');

  // ── Generate content ──────────────────────────────────────────────────────
  function generateContent() {
    if (selected.length === 0) return '';
    var lines = ['# Generated by OpsBash gitignore Generator', '# https://opsbash.com/gitignore-generator', ''];
    selected.forEach(function (tech) {
      if (GITIGNORE_DATA[tech]) {
        lines.push(GITIGNORE_DATA[tech]);
        lines.push('');
      }
    });
    return lines.join('\n').replace(/\n{3,}/g, '\n\n').trimEnd() + '\n';
  }

  // ── Update preview ────────────────────────────────────────────────────────
  function updatePreview() {
    var content = generateContent();
    if (!content) {
      previewEmpty.style.display = '';
      previewContent.classList.add('hidden');
      lineCount.textContent = '0 lines';
    } else {
      previewEmpty.style.display = 'none';
      previewContent.classList.remove('hidden');
      previewContent.textContent = content;
      var count = content.split('\n').length;
      lineCount.textContent = count + (count === 1 ? ' line' : ' lines');
    }
  }

  // ── Render chips ──────────────────────────────────────────────────────────
  function renderChips() {
    var existing = selectedChips.querySelectorAll('.tech-chip');
    existing.forEach(function (el) { el.remove(); });

    if (selected.length === 0) {
      emptyChipsMsg.style.display = '';
      clearAllBtn.classList.add('hidden');
    } else {
      emptyChipsMsg.style.display = 'none';
      clearAllBtn.classList.remove('hidden');
      selected.forEach(function (tech) {
        var chip = document.createElement('div');
        chip.className = 'tech-chip flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-medium';
        chip.style.cssText = 'background: #1A1A1A; color: #F8FAFC; border: 1px solid #334155;';
        chip.innerHTML = '<span>' + escapeHtml(tech) + '</span>'
          + '<button class="chip-remove flex items-center justify-center w-3.5 h-3.5 rounded-full transition-all" '
          + 'style="color: rgba(16,185,129,0.7);" data-tech="' + escapeAttr(tech) + '" '
          + 'aria-label="Remove ' + escapeAttr(tech) + '">'
          + '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="10" height="10">'
          + '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'
          + '</button>';
        selectedChips.appendChild(chip);
      });
    }
  }

  // ── Render dropdown ───────────────────────────────────────────────────────
  function renderDropdown() {
    var q = techSearch.value.toLowerCase();
    var filtered = ALL_TECHS.filter(function (t) {
      return t.toLowerCase().indexOf(q) !== -1;
    });
    techDropdown.innerHTML = '';
    if (filtered.length === 0) {
      var empty = document.createElement('div');
      empty.className = 'px-4 py-3 text-xs';
      empty.style.color = 'var(--fg3)';
      empty.textContent = 'No technologies found';
      techDropdown.appendChild(empty);
    } else {
      filtered.forEach(function (tech) {
        var isSelected = selected.indexOf(tech) !== -1;
        var item = document.createElement('button');
        item.type = 'button';
        item.className = 'w-full flex items-center justify-between px-4 py-2.5 text-sm font-medium text-left transition-all';
        item.style.cssText = 'color: ' + (isSelected ? '#F8FAFC' : 'var(--fg2)') + '; background: transparent;';
        item.setAttribute('data-tech', tech);
        item.innerHTML = '<span>' + escapeHtml(tech) + '</span>'
          + (isSelected
            ? '<svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="color:#F8FAFC"><polyline points="20 6 9 17 4 12"/></svg>'
            : '');
        item.addEventListener('mouseover', function () {
          item.style.background = 'rgba(16,185,129,0.07)';
          item.style.color = 'var(--fg)';
        });
        item.addEventListener('mouseout', function () {
          item.style.background = 'transparent';
          item.style.color = isSelected ? '#F8FAFC' : 'var(--fg2)';
        });
        item.addEventListener('mousedown', function (e) {
          e.preventDefault();
          toggleTech(tech);
          techSearch.value = '';
          renderDropdown();
        });
        techDropdown.appendChild(item);
      });
    }
  }

  // ── Toggle technology ─────────────────────────────────────────────────────
  function toggleTech(tech) {
    var idx = selected.indexOf(tech);
    if (idx === -1) {
      selected.push(tech);
    } else {
      selected.splice(idx, 1);
    }
    renderChips();
    updatePreview();
  }

  // ── Open/close dropdown ───────────────────────────────────────────────────
  function openDropdown() {
    renderDropdown();
    techDropdown.classList.remove('hidden');
    dropdownOpen = true;
    techSearch.style.borderColor = '#F8FAFC';
    techSearch.style.boxShadow   = '0 0 0 3px rgba(100,116,139,0.2)';
  }

  function closeDropdown() {
    techDropdown.classList.add('hidden');
    dropdownOpen = false;
    techSearch.style.borderColor = 'var(--border)';
    techSearch.style.boxShadow   = 'none';
  }

  // ── Search input events ───────────────────────────────────────────────────
  techSearch.addEventListener('focus', function () { openDropdown(); });
  techSearch.addEventListener('input', function () {
    if (!dropdownOpen) openDropdown();
    else renderDropdown();
  });
  techSearch.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') { closeDropdown(); techSearch.blur(); }
  });

  // ── Chip remove (delegated) ───────────────────────────────────────────────
  selectedChips.addEventListener('click', function (e) {
    var btn = e.target.closest('.chip-remove');
    if (btn) toggleTech(btn.getAttribute('data-tech'));
  });

  // ── Clear all ─────────────────────────────────────────────────────────────
  clearAllBtn.addEventListener('click', function () {
    selected = [];
    renderChips();
    updatePreview();
    if (dropdownOpen) renderDropdown();
  });

  // ── Preset buttons ────────────────────────────────────────────────────────
  document.querySelectorAll('.preset-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var key = btn.getAttribute('data-preset');
      if (PRESETS[key]) {
        selected = [];
        PRESETS[key].forEach(function (tech) {
          if (selected.indexOf(tech) === -1) selected.push(tech);
        });
        renderChips();
        updatePreview();
        if (dropdownOpen) renderDropdown();
      }
    });
    btn.addEventListener('mouseover', function () {
      btn.style.borderColor = '#F8FAFC';
      btn.style.color       = 'var(--fg)';
    });
    btn.addEventListener('mouseout', function () {
      btn.style.borderColor = 'var(--border)';
      btn.style.color       = 'var(--fg2)';
    });
  });

  // ── Click outside to close dropdown ──────────────────────────────────────
  document.addEventListener('click', function (e) {
    if (dropdownOpen && !document.getElementById('searchContainer').contains(e.target)) {
      closeDropdown();
    }
  });

  // ── Copy button ───────────────────────────────────────────────────────────
  copyBtn.addEventListener('click', function () {
    var content = generateContent();
    if (!content) return;
    function flash() {
      copyBtnText.textContent   = 'Copied!';
      copyBtn.style.background  = 'rgba(248,250,252,0.12)';
      setTimeout(function () {
        copyBtnText.textContent = 'Copy';
        copyBtn.style.background = 'rgba(248,250,252,0.06)';
      }, 2000);
    }
    if (navigator.clipboard) {
      navigator.clipboard.writeText(content).then(flash).catch(function () { fbCopy(content); flash(); });
    } else { fbCopy(content); flash(); }
  });

  function fbCopy(text) {
    var ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0';
    document.body.appendChild(ta);
    ta.select();
    try { document.execCommand('copy'); } catch (e) {}
    document.body.removeChild(ta);
  }

  // ── Download button ───────────────────────────────────────────────────────
  downloadBtn.addEventListener('click', function () {
    var content = generateContent();
    if (!content) return;
    var blob = new Blob([content], { type: 'text/plain' });
    var url  = URL.createObjectURL(blob);
    var a    = document.createElement('a');
    a.href     = url;
    a.download = 'gitignore.txt';
    a.style.display = 'none';
    document.body.appendChild(a);
    a.click();
    setTimeout(function () {
      URL.revokeObjectURL(url);
      document.body.removeChild(a);
    }, 100);
  });

  // ── FAQ accordion ─────────────────────────────────────────────────────────
  document.querySelectorAll('.faq-q').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = btn.closest('.faq-item');
      var ans  = item.querySelector('.faq-a');
      var chev = btn.querySelector('.faq-chevron');
      var open = !ans.classList.contains('hidden');
      ans.classList.toggle('hidden', open);
      if (chev) chev.style.transform = open ? '' : 'rotate(180deg)';
    });
  });

  // ── Helpers ───────────────────────────────────────────────────────────────
  function escapeHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function escapeAttr(str) {
    return str.replace(/"/g,'&quot;');
  }

  // ── Init ──────────────────────────────────────────────────────────────────
  renderChips();
  updatePreview();

})();
</script>

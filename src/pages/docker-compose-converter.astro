---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between docker run and Docker Compose?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "docker run is a single command for starting one container at a time with all configuration passed as flags directly in the terminal. Docker Compose is a tool for defining and running containers using a YAML file. For a single container, both achieve the same result, but Docker Compose files are easier to version control, share with teammates, and reproduce consistently across environments. Anyone on your team can clone the repo and run docker compose up to get the exact same setup."
      }
    },
    {
      "@type": "Question",
      "name": "Can I convert any docker run command to a Compose file?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most docker run flags have a direct equivalent in Docker Compose. Common ones like name, ports, environment variables, volumes, network, and restart policy all map cleanly. A small number of flags like --rm have no meaningful equivalent in Compose since Compose manages container lifecycle differently. This converter handles all the most common flags accurately including environment variables, bind mounts, named volumes, port mappings, custom networks, and resource limits."
      }
    },
    {
      "@type": "Question",
      "name": "What does the version field in docker-compose.yml mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The version field at the top of a docker-compose.yml file specifies which version of the Compose file format to use. Different versions support different features. Many modern setups omit the version field entirely, which tells Docker Compose to use the latest format automatically. This converter generates files without a version field to be forward-compatible with current Docker and Docker Compose releases."
      }
    },
    {
      "@type": "Question",
      "name": "How do I use a generated docker-compose.yml file?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Save the output as docker-compose.yml in your project directory. Then run docker compose up -d to start the container in detached mode, docker compose down to stop and remove it, and docker compose logs to view output. You can also run docker compose ps to see running containers defined in your file. If you have Docker Compose V2 installed the command is docker compose as two words. Older versions use docker-compose with a hyphen."
      }
    },
    {
      "@type": "Question",
      "name": "What is the restart policy in Docker Compose?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The restart field controls what Docker does when a container exits unexpectedly. The value no means Docker never restarts the container, which is the default. always means Docker always restarts it even after a manual stop. unless-stopped means Docker restarts it automatically but respects manual stops. on-failure means Docker only restarts if the container exits with a non-zero error code. For production services that need to stay running, unless-stopped is usually the right choice."
      }
    },
    {
      "@type": "Question",
      "name": "Can Docker Compose replace docker run entirely?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For development and most production use cases, yes. Docker Compose files are strictly better than bare docker run commands because they are declarative, reproducible, and easy to read. You define what you want rather than how to achieve it, and anyone can reproduce the exact same container by running docker compose up. The only time bare docker run is more convenient is for quick one-off commands or testing where the overhead of creating a Compose file is not worth it."
      }
    }
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Docker Run to Compose Converter",
  "url": "https://opsbash.com/docker-compose-converter",
  "description": "Convert docker run commands to docker-compose.yml instantly. Paste any docker run command and get a ready-to-use Compose file. Also converts Compose files back to docker run commands.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<Layout

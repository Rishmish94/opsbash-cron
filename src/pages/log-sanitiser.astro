<script>
// ─── PLACEHOLDERS ────────────────────────────────────────────────────────────

const PLACEHOLDER = {
  ip: '[REDACTED-IP]',
  email: '[REDACTED-EMAIL]',
  jwt: '[REDACTED-JWT]',
  apiKey: '[REDACTED-API-KEY]',
  awsAccessKey: '[REDACTED-AWS-ACCESS-KEY]',
  awsSecret: '[REDACTED-AWS-SECRET]',
  password: '[REDACTED-PASSWORD]',
  db: '[REDACTED-DB-CREDENTIALS]',
  creditCard: '[REDACTED-CREDIT-CARD]',
  privateKey: '[REDACTED-PRIVATE-KEY]',
  phone: '[REDACTED-PHONE]',
};

// ─── HELPERS ─────────────────────────────────────────────────────────────────

function luhnValid(digits: string): boolean {
  let sum = 0;
  let alt = false;
  for (let i = digits.length - 1; i >= 0; i--) {
    let n = digits.charCodeAt(i) - 48;
    if (alt) { n *= 2; if (n > 9) n -= 9; }
    sum += n;
    alt = !alt;
  }
  return sum % 10 === 0;
}

const IPV6_RE = new RegExp(
  '(?<![0-9A-Fa-f:.])(' +
  '(?:[0-9A-Fa-f]{1,4}:){7}[0-9A-Fa-f]{1,4}|' +
  '(?:[0-9A-Fa-f]{1,4}:){1,7}:|' +
  '(?:[0-9A-Fa-f]{1,4}:){1,6}:[0-9A-Fa-f]{1,4}|' +
  '(?:[0-9A-Fa-f]{1,4}:){1,5}(?::[0-9A-Fa-f]{1,4}){1,2}|' +
  '(?:[0-9A-Fa-f]{1,4}:){1,4}(?::[0-9A-Fa-f]{1,4}){1,3}|' +
  '(?:[0-9A-Fa-f]{1,4}:){1,3}(?::[0-9A-Fa-f]{1,4}){1,4}|' +
  '(?:[0-9A-Fa-f]{1,4}:){1,2}(?::[0-9A-Fa-f]{1,4}){1,5}|' +
  '[0-9A-Fa-f]{1,4}:(?:(?::[0-9A-Fa-f]{1,4}){1,6})|' +
  ':(?:(?::[0-9A-Fa-f]{1,4}){1,7}|:)' +
  ')(?![0-9A-Fa-f:.])',
  'g'
);

const IPV4_RE = /\b(?:(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)\.){3}(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)\b/g;
const EMAIL_RE = /\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}\b/g;
const JWT_RE = /\beyJ[A-Za-z0-9_-]{5,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{4,}\b/g;
const BEARER_RE = /\bBearer\s+[A-Za-z0-9\-_.]{20,}\b/gi;
const SK_PK_RE = /\b(?:sk|pk)-(?:live|test)-[A-Za-z0-9]{20,}\b/g;
const AWS_ACCESS_KEY_RE = /\bAKIA[A-Z0-9]{16}\b/g;
const AWS_SECRET_RE = /\b((?:aws[_-]?secret(?:[_-]?access[_-]?key)?)\s*[:=]\s*)([A-Za-z0-9+/]{40})\b/gi;
const PASSWORD_RE = /\b((?:password|passwd|pwd|secret)[a-zA-Z0-9_]*\s*[:=]\s*)(\S+)/gi;
const DB_RE = /\b(postgres(?:ql)?|mysql|mongodb(?:\+srv)?|redis):\/\/([^:@/\s]+):([^@/\s]+)@/gi;
const CREDIT_CARD_RE = /\b\d[\d -]{11,22}\d\b/g;
const PRIVATE_KEY_RE = /-----BEGIN (RSA PRIVATE KEY|PRIVATE KEY|EC PRIVATE KEY)-----[\s\S]*?-----END \1-----/g;
const PHONE_RE = /(?<![\d.])(\+\d{1,3}[-.\s])?\(?\d{2,4}\)?[-.\s]\d{3,4}[-.\s]\d{4}(?!\d)/g;

function escapeHtml(str: string): string {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

function copyText(text: string, btn: HTMLElement) {
  function flash() {
    const original = btn.innerHTML;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.innerHTML = original; }, 1500);
  }
  function fallback() {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0';
    document.body.appendChild(ta);
    ta.select();
    try { document.execCommand('copy'); } catch (e) {}
    document.body.removeChild(ta);
  }
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(flash).catch(() => { fallback(); flash(); });
  } else {
    fallback(); flash();
  }
}

// ─── SANITISE ENGINE ─────────────────────────────────────────────────────────

interface Stats {
  ip: number; email: number; jwt: number; apiKey: number; aws: number;
  password: number; db: number; creditCard: number; privateKey: number;
  phone: number; custom: number;
}

function emptyStats(): Stats {
  return { ip: 0, email: 0, jwt: 0, apiKey: 0, aws: 0, password: 0, db: 0, creditCard: 0, privateKey: 0, phone: 0, custom: 0 };
}

function sanitise(text: string, rules: Record<string, boolean>, customPattern: string, customLabel: string): { out: string; stats: Stats } {
  const stats = emptyStats();
  let out = text;

  if (rules.privateKey) {
    out = out.replace(PRIVATE_KEY_RE, () => { stats.privateKey++; return PLACEHOLDER.privateKey; });
  }

  if (rules.db) {
    out = out.replace(DB_RE, (_m, proto) => { stats.db++; return `${proto}://${PLACEHOLDER.db}@`; });
  }

  if (rules.password) {
    out = out.replace(PASSWORD_RE, (_m, prefix) => { stats.password++; return prefix + PLACEHOLDER.password; });
  }

  if (rules.aws) {
    out = out.replace(AWS_ACCESS_KEY_RE, () => { stats.aws++; return PLACEHOLDER.awsAccessKey; });
    out = out.replace(AWS_SECRET_RE, (_m, prefix) => { stats.aws++; return prefix + PLACEHOLDER.awsSecret; });
  }

  if (rules.jwt) {
    out = out.replace(JWT_RE, () => { stats.jwt++; return PLACEHOLDER.jwt; });
  }

  if (rules.apiKey) {
    out = out.replace(BEARER_RE, () => { stats.apiKey++; return `Bearer ${PLACEHOLDER.apiKey}`; });
    out = out.replace(SK_PK_RE, () => { stats.apiKey++; return PLACEHOLDER.apiKey; });
  }

  if (rules.creditCard) {
    out = out.replace(CREDIT_CARD_RE, (m) => {
      const digits = m.replace(/[ -]/g, '');
      if (digits.length >= 13 && digits.length <= 19 && luhnValid(digits)) {
        stats.creditCard++;
        return PLACEHOLDER.creditCard;
      }
      return m;
    });
  }

  if (rules.email) {
    out = out.replace(EMAIL_RE, () => { stats.email++; return PLACEHOLDER.email; });
  }

  if (rules.ip) {
    out = out.replace(IPV6_RE, () => { stats.ip++; return PLACEHOLDER.ip; });
    out = out.replace(IPV4_RE, () => { stats.ip++; return PLACEHOLDER.ip; });
  }

  if (rules.phone) {
    out = out.replace(PHONE_RE, () => { stats.phone++; return PLACEHOLDER.phone; });
  }

  if (rules.custom && customPattern && customLabel) {
    try {
      const re = new RegExp(customPattern, 'g');
      out = out.replace(re, () => { stats.custom++; return `[REDACTED-${customLabel.toUpperCase()}]`; });
      customPatternError.classList.add('hidden');
      customPatternInput.classList.remove('input-invalid');
    } catch {
      customPatternError.classList.remove('hidden');
      customPatternInput.classList.add('input-invalid');
    }
  } else {
    customPatternError.classList.add('hidden');
    customPatternInput.classList.remove('input-invalid');
  }

  return { out, stats };
}

// ─── DOM WIRING ──────────────────────────────────────────────────────────────

const logInput = document.getElementById('logInput') as HTMLTextAreaElement;
const logOutput = document.getElementById('logOutput') as HTMLTextAreaElement;
const statsTotal = document.getElementById('statsTotal') as HTMLSpanElement;
const statsBreakdown = document.getElementById('statsBreakdown') as HTMLSpanElement;
const statsSize = document.getElementById('statsSize') as HTMLSpanElement;
const customPatternInput = document.getElementById('customPatternInput') as HTMLInputElement;
const customLabelInput = document.getElementById('customLabelInput') as HTMLInputElement;
const customPatternError = document.getElementById('customPatternError') as HTMLParagraphElement;
const ruleCheckboxes = Array.from(document.querySelectorAll('[data-rule]')) as HTMLInputElement[];
const customCheckbox = document.getElementById('rule-custom') as HTMLInputElement;

function pluralize(n: number, singular: string, plural: string): string {
  return `${n} ${n === 1 ? singular : plural}`;
}

function formatKB(bytes: number): string {
  return (bytes / 1024).toFixed(2) + ' KB';
}

function getRules(): Record<string, boolean> {
  const rules: Record<string, boolean> = { custom: customCheckbox.checked };
  ruleCheckboxes.forEach((cb) => { rules[cb.dataset.rule as string] = cb.checked; });
  return rules;
}

function updateStats(stats: Stats, inputText: string, outputText: string) {
  const total = Object.values(stats).reduce((a, b) => a + b, 0);
  const parts: string[] = [];
  if (stats.ip) parts.push(pluralize(stats.ip, 'IP', 'IPs'));
  if (stats.email) parts.push(pluralize(stats.email, 'email', 'emails'));
  if (stats.jwt) parts.push(pluralize(stats.jwt, 'JWT', 'JWTs'));
  if (stats.apiKey) parts.push(pluralize(stats.apiKey, 'API key', 'API keys'));
  if (stats.aws) parts.push(pluralize(stats.aws, 'AWS credential', 'AWS credentials'));
  if (stats.password) parts.push(pluralize(stats.password, 'password', 'passwords'));
  if (stats.db) parts.push(pluralize(stats.db, 'DB credential', 'DB credentials'));
  if (stats.creditCard) parts.push(pluralize(stats.creditCard, 'credit card', 'credit cards'));
  if (stats.privateKey) parts.push(pluralize(stats.privateKey, 'private key', 'private keys'));
  if (stats.phone) parts.push(pluralize(stats.phone, 'phone number', 'phone numbers'));
  if (stats.custom) {
    const label = (customLabelInput.value.trim() || 'custom match').toLowerCase();
    parts.push(pluralize(stats.custom, label, label + 's'));
  }

  statsTotal.textContent = `${total} item${total === 1 ? '' : 's'} redacted`;
  statsBreakdown.textContent = parts.length ? parts.join(' · ') : '—';
  statsSize.textContent = `${formatKB(new Blob([inputText]).size)} → ${formatKB(new Blob([outputText]).size)}`;
}

function runSanitise() {
  const rules = getRules();
  const { out, stats } = sanitise(logInput.value, rules, customPatternInput.value.trim(), customLabelInput.value.trim());
  logOutput.value = out;
  updateStats(stats, logInput.value, out);
}

let debounceTimer: ReturnType<typeof setTimeout>;
logInput.addEventListener('input', () => {
  clearTimeout(debounceTimer);
  debounceTimer = setTimeout(runSanitise, 300);
});

let customDebounceTimer: ReturnType<typeof setTimeout>;
[customPatternInput, customLabelInput].forEach((el) => {
  el.addEventListener('input', () => {
    clearTimeout(customDebounceTimer);
    customDebounceTimer = setTimeout(runSanitise, 300);
  });
});

[...ruleCheckboxes, customCheckbox].forEach((cb) => {
  cb.addEventListener('change', runSanitise);
});

// ─── ACTION BUTTONS ──────────────────────────────────────────────────────────

const copyOutputBtn = document.getElementById('copyOutputBtn') as HTMLButtonElement;
const downloadBtn = document.getElementById('downloadBtn') as HTMLButtonElement;
const clearAllBtn = document.getElementById('clearAllBtn') as HTMLButtonElement;

copyOutputBtn.addEventListener('click', () => copyText(logOutput.value, copyOutputBtn));

downloadBtn.addEventListener('click', () => {
  const blob = new Blob([logOutput.value], { type: 'text/plain' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'sanitised-log.txt';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
});

clearAllBtn.addEventListener('click', () => {
  logInput.value = '';
  logOutput.value = '';
  runSanitise();
});

// ─── DETECTION RULES PANEL TOGGLE ────────────────────────────────────────────

const rulesToggle = document.getElementById('rulesToggle') as HTMLButtonElement;
const rulesBody = document.getElementById('rulesBody') as HTMLDivElement;
const rulesChevron = document.getElementById('rulesChevron') as HTMLElement;

rulesToggle.addEventListener('click', () => {
  const isOpen = !rulesBody.classList.contains('hidden');
  rulesBody.classList.toggle('hidden', isOpen);
  rulesChevron.style.transform = isOpen ? 'rotate(-90deg)' : '';
});

// ─── AI PROMPT HELPER ────────────────────────────────────────────────────────

const aiPromptArea = document.getElementById('aiPromptArea') as HTMLTextAreaElement;
const insertPromptBtn = document.getElementById('insertPromptBtn') as HTMLButtonElement;
const copyPromptBtn = document.getElementById('copyPromptBtn') as HTMLButtonElement;

const PROMPT_PLACEHOLDER = '[PASTE YOUR SANITISED LOG HERE]';
const DEFAULT_PROMPT = `I need help debugging the following log output. I have already sanitised all sensitive values and replaced them with [REDACTED-*] placeholders.

${PROMPT_PLACEHOLDER}

Please help me identify the root cause of the issue.`;

aiPromptArea.value = DEFAULT_PROMPT;

insertPromptBtn.addEventListener('click', () => {
  aiPromptArea.value = DEFAULT_PROMPT.replace(PROMPT_PLACEHOLDER, logOutput.value || '');
});

copyPromptBtn.addEventListener('click', () => copyText(aiPromptArea.value, copyPromptBtn));

// ─── FAQ ACCORDION ───────────────────────────────────────────────────────────

document.querySelectorAll('.faq-trigger').forEach((btn) => {
  btn.addEventListener('click', () => {
    const item = btn.closest('.faq-item') as HTMLElement;
    const content = item.querySelector('.faq-content') as HTMLElement;
    const chevron = btn.querySelector('.faq-chevron') as HTMLElement;
    const isOpen = !content.classList.contains('hidden');
    content.classList.toggle('hidden', isOpen);
    chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
  });
});

// ─── BOOT ─────────────────────────────────────────────────────────────────────
runSanitise();
</script>


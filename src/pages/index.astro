---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="OpsBash — Free DevOps Tools for Engineers | Cron Builder & More"
  description="Free browser-based tools for DevOps engineers. Build cron expressions for Linux, AWS, Kubernetes and GitHub Actions. No sign-up, no paywalls, runs in your browser."
  canonicalURL="https://opsbash.com/"
>

<main>
  <!-- HERO -->
  <section class="max-w-4xl mx-auto px-4 pt-20 pb-16 text-center">
    <div class="flex justify-center mb-6">
      <div class="w-16 h-16 rounded-2xl bg-indigo-600 flex items-center justify-center shadow-lg shadow-indigo-500/30">
        <svg class="w-9 h-9 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
    </div>
    <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white tracking-tight mb-5 leading-tight">
      DevOps Tools<br class="hidden sm:block" /> for Engineers
    </h1>
    <p class="text-gray-500 dark:text-gray-400 text-lg max-w-xl mx-auto leading-relaxed mb-8">
      Free, fast, and no-nonsense tools for operations engineers. No sign-up, no bloat — just the tools you need.
    </p>
    <a href="/cron-builder"
      class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm shadow-md shadow-indigo-500/20">
      Try Cron Builder
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </section>

  <!-- TOOLS GRID -->
  <section class="max-w-6xl mx-auto px-4 pb-20">
    <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider text-center mb-8">Available Tools</p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">

      <!-- Cron Builder card -->
      <a href="/cron-builder"
        class="group relative bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 shadow-sm hover:shadow-md hover:border-indigo-200 dark:hover:border-indigo-800 transition-all">
        <div class="w-10 h-10 rounded-xl bg-indigo-50 dark:bg-indigo-950/60 flex items-center justify-center mb-4 border border-indigo-100 dark:border-indigo-900 group-hover:bg-indigo-100 dark:group-hover:bg-indigo-950 transition-colors">
          <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h2 class="font-semibold text-gray-900 dark:text-white text-sm mb-2 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">Cron Expression Builder</h2>
        <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
          Build and validate cron expressions visually. Get plain-English explanations, next run times in your timezone, and platform-specific output for Linux, AWS, GitHub Actions, and Kubernetes.
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="text-[10px] font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-full">Linux</span>
          <span class="text-[10px] font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-full">AWS</span>
          <span class="text-[10px] font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-full">GitHub Actions</span>
          <span class="text-[10px] font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-full">Kubernetes</span>
        </div>
        <div class="absolute top-5 right-5 text-gray-300 dark:text-gray-700 group-hover:text-indigo-400 transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- CIDR Calculator card -->
      <a href="/cidr-calculator"
        class="group relative bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 shadow-sm hover:shadow-md hover:border-indigo-200 dark:hover:border-indigo-800 transition-all">
        <div class="w-10 h-10 rounded-xl bg-indigo-50 dark:bg-indigo-950/60 flex items-center justify-center mb-4 border border-indigo-100 dark:border-indigo-900 group-hover:bg-indigo-100 dark:group-hover:bg-indigo-950 transition-colors">
          <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </div>
        <h2 class="font-semibold text-gray-900 dark:text-white text-sm mb-2 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">CIDR Calculator</h2>
        <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed mb-4">
          Calculate subnet details, usable hosts, and network ranges instantly. Split CIDRs into equal subnets, plan AWS VPC layouts, and copy any value with one click.
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="text-[10px] font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-full">IPv4</span>
          <span class="text-[10px] font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-full">IPv6</span>
          <span class="text-[10px] font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-full">AWS VPC</span>
          <span class="text-[10px] font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-full">Subnetting</span>
        </div>
        <div class="absolute top-5 right-5 text-gray-300 dark:text-gray-700 group-hover:text-indigo-400 transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Coming soon cards -->
      <div class="bg-white dark:bg-gray-900 border border-dashed border-gray-200 dark:border-gray-800 rounded-2xl p-6 opacity-60">
        <div class="w-10 h-10 rounded-xl bg-gray-50 dark:bg-gray-800 flex items-center justify-center mb-4 border border-gray-100 dark:border-gray-700">
          <svg class="w-5 h-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
          </svg>
        </div>
        <h2 class="font-semibold text-gray-500 dark:text-gray-500 text-sm mb-2">Regex Tester</h2>
        <p class="text-xs text-gray-400 dark:text-gray-600 leading-relaxed">Test and debug regular expressions with live match highlighting.</p>
        <p class="mt-3 text-[10px] font-medium text-gray-400 dark:text-gray-600 uppercase tracking-wider">Coming soon</p>
      </div>

      <div class="bg-white dark:bg-gray-900 border border-dashed border-gray-200 dark:border-gray-800 rounded-2xl p-6 opacity-60">
        <div class="w-10 h-10 rounded-xl bg-gray-50 dark:bg-gray-800 flex items-center justify-center mb-4 border border-gray-100 dark:border-gray-700">
          <svg class="w-5 h-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <h2 class="font-semibold text-gray-500 dark:text-gray-500 text-sm mb-2">Base64 Encoder / Decoder</h2>
        <p class="text-xs text-gray-400 dark:text-gray-600 leading-relaxed">Quickly encode and decode Base64 strings and files.</p>
        <p class="mt-3 text-[10px] font-medium text-gray-400 dark:text-gray-600 uppercase tracking-wider">Coming soon</p>
      </div>

    </div>
  </section>

  <!-- WHY SECTION -->
  <section class="border-t border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/50">
    <div class="max-w-4xl mx-auto px-4 py-16 text-center">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 tracking-tight">Built for the terminal crowd</h2>
      <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed max-w-lg mx-auto mb-10">
        No ads, no paywalls, no account required. Every tool on opsbash.com is free and works in your browser.
      </p>
      <div class="grid sm:grid-cols-3 gap-6 text-left">
        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-5">
          <div class="w-8 h-8 rounded-lg bg-green-50 dark:bg-green-950/40 border border-green-100 dark:border-green-900 flex items-center justify-center mb-3">
            <svg class="w-4 h-4 text-green-600 dark:text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <p class="text-xs font-semibold text-gray-800 dark:text-gray-200 mb-1">Always free</p>
          <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">No pricing tiers, no credits, no limits.</p>
        </div>
        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-5">
          <div class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-950/40 border border-blue-100 dark:border-blue-900 flex items-center justify-center mb-3">
            <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <p class="text-xs font-semibold text-gray-800 dark:text-gray-200 mb-1">Private by default</p>
          <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">Everything runs in your browser. Nothing is sent to our servers.</p>
        </div>
        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-5">
          <div class="w-8 h-8 rounded-lg bg-purple-50 dark:bg-purple-950/40 border border-purple-100 dark:border-purple-900 flex items-center justify-center mb-3">
            <svg class="w-4 h-4 text-purple-600 dark:text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <p class="text-xs font-semibold text-gray-800 dark:text-gray-200 mb-1">Instant results</p>
          <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">No round trips. Results update as you type.</p>
        </div>
      </div>
    </div>
  </section>
</main>

</Layout>

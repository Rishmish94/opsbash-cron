---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="OpsBash — Free DevOps Tools for Engineers | Cron Builder & More"
  description="Free browser-based tools for DevOps engineers. Build cron expressions for Linux, AWS, Kubernetes and GitHub Actions. No sign-up, no paywalls, runs in your browser."
  canonicalURL="https://opsbash.com/"
>

<main>

  <!-- ── HERO ──────────────────────────────────────────────────────────────── -->
  <section class="flex flex-col items-center justify-center px-4 pt-16 pb-12 text-center animate-fade-in-up"
           style="min-height: calc(100vh - 56px);">

    <!-- Eyebrow badge -->
    <div class="hero-badge inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold mb-6"
         style="background: rgba(16,185,129,0.12); color: #10b981; border: 1px solid rgba(16,185,129,0.25);">
      ⚡ Free for engineers, forever
    </div>

    <!-- H1 -->
    <h1 class="hero-main font-black tracking-tight mb-4 leading-tight"
        style="font-size: clamp(2.4rem, 6vw, 4rem); letter-spacing: -0.04em; background: linear-gradient(135deg, #ecfdf5 20%, #34d399 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; max-width: 700px;">
      DevOps Tools<br class="hidden sm:block" /> for Engineers
    </h1>

    <!-- Subtitle -->
    <p class="text-base sm:text-lg max-w-xl mx-auto leading-relaxed mb-8" style="color: var(--fg2);">
      No sign-up. No install. All tools run entirely in your browser.
    </p>

    <!-- Live mini cron tool -->
    <div class="hero-terminal w-full max-w-lg mx-auto mb-8 rounded-2xl text-left overflow-hidden"
         style="background: var(--card); border: 1px solid var(--border); box-shadow: 0 8px 32px rgba(16,185,129,0.08);">
      <!-- Window chrome -->
      <div class="flex items-center gap-1.5 px-4 py-3" style="background: #0a1a0f; border-bottom: 1px solid var(--border);">
        <div class="w-3 h-3 rounded-full" style="background: #ff5f57;"></div>
        <div class="w-3 h-3 rounded-full" style="background: #febc2e;"></div>
        <div class="w-3 h-3 rounded-full" style="background: #28c840;"></div>
        <span class="ml-3 text-xs font-mono" style="color: var(--fg3);">cron-expression</span>
      </div>
      <!-- Input area -->
      <div class="p-5">
        <p class="text-[10px] font-semibold uppercase tracking-wider mb-2" style="color: var(--fg3);">Try it live</p>
        <input id="heroCronInput" type="text" value="* * * * *" spellcheck="false" autocomplete="off"
          class="w-full rounded-xl px-4 py-3 focus:outline-none transition-all"
          style="font-family: 'Fira Code', monospace; font-size: 20px; letter-spacing: 0.1em; color: #34d399; background: var(--bg); border: 1px solid #10b981; box-shadow: 0 0 0 3px rgba(16,185,129,0.12);" />
        <p id="heroCronExpl" class="mt-3 text-sm font-medium leading-snug" style="color: #10b981;">
          Runs every minute
        </p>
        <p id="heroCronNext" class="mt-1 text-xs" style="color: var(--fg3);">Next run in — seconds</p>
      </div>
    </div>

    <!-- CTA buttons -->
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href="/cron-builder"
        class="inline-flex items-center gap-2 font-semibold px-6 py-3 rounded-xl transition-all text-sm"
        style="background: linear-gradient(135deg, #10b981, #059669); color: #fff; box-shadow: 0 4px 16px rgba(16,185,129,0.3); text-decoration: none;">
        Open Cron Builder
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="/cidr-calculator"
        class="inline-flex items-center gap-2 font-semibold px-6 py-3 rounded-xl transition-all text-sm"
        style="border: 1px solid var(--border); color: var(--fg); background: var(--card); text-decoration: none;"
        onmouseover="this.style.borderColor='#10b981'"
        onmouseout="this.style.borderColor='var(--border)'">
        CIDR Calculator
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- ── SOCIAL PROOF ───────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-16 reveal">
    <div class="grid grid-cols-3 gap-4">
      <div class="social-card rounded-2xl p-5 text-center" style="background: var(--card); border: 1px solid var(--border);">
        <div class="social-val text-2xl font-black mb-1" style="color: #10b981;">0</div>
        <p class="text-xs font-medium" style="color: var(--fg2);">Sign-ups required</p>
      </div>
      <div class="social-card rounded-2xl p-5 text-center" style="background: var(--card); border: 1px solid var(--border);">
        <div class="social-val text-2xl font-black mb-1" style="color: #10b981;">100%</div>
        <p class="text-xs font-medium" style="color: var(--fg2);">Free forever</p>
      </div>
      <div class="social-card rounded-2xl p-5 text-center" style="background: var(--card); border: 1px solid var(--border);">
        <div class="social-val text-xl font-black mb-1" style="color: #10b981;">✓</div>
        <p class="text-xs font-medium" style="color: var(--fg2);">Works offline</p>
      </div>
    </div>
  </section>

  <!-- ── TOOLS BENTO GRID ───────────────────────────────────────────────────── -->
  <section class="max-w-6xl mx-auto px-4 pb-20">
    <p class="text-xs font-semibold uppercase tracking-wider text-center mb-8 reveal" style="color: var(--fg3);">Available Tools</p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">

      <!-- Cron Builder card (wide, spans 2 cols on lg) -->
      <a href="/cron-builder"
        class="reveal relative rounded-2xl p-6 transition-all lg:col-span-2"
        style="background: var(--card); border: 1px solid var(--border); text-decoration: none;"
        onmouseover="this.style.borderColor='#10b981'; this.style.boxShadow='0 4px 24px rgba(16,185,129,0.1)'"
        onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0"
               style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);">
            <svg class="w-5 h-5" style="color: #10b981;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <h2 class="font-semibold text-base mb-2" style="color: var(--fg);">Cron Expression Builder</h2>
            <p class="text-sm leading-relaxed mb-4" style="color: var(--fg2);">
              Build and validate cron expressions visually. Get plain-English explanations, next run times in your timezone, and platform-specific output for Linux, AWS, GitHub Actions, and Kubernetes.
            </p>
            <div class="flex flex-wrap gap-1.5">
              <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">Linux</span>
              <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">AWS</span>
              <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">GitHub Actions</span>
              <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">Kubernetes</span>
            </div>
          </div>
        </div>
        <div class="absolute top-5 right-5" style="color: var(--border);">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- CIDR Calculator card -->
      <a href="/cidr-calculator"
        class="reveal relative rounded-2xl p-6 transition-all"
        style="background: var(--card); border: 1px solid var(--border); text-decoration: none;"
        onmouseover="this.style.borderColor='#10b981'; this.style.boxShadow='0 4px 24px rgba(16,185,129,0.1)'"
        onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
             style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);">
          <svg class="w-5 h-5" style="color: #10b981;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </div>
        <h2 class="font-semibold text-base mb-2" style="color: var(--fg);">CIDR Calculator</h2>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--fg2);">
          Calculate subnet details, usable hosts, and network ranges. Split CIDRs, plan AWS VPC layouts, and copy any value with one click.
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">IPv4</span>
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">IPv6</span>
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">AWS VPC</span>
        </div>
        <div class="absolute top-5 right-5" style="color: var(--border);">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- JSON YAML Converter card -->
      <a href="/json-yaml-converter"
        class="reveal relative rounded-2xl p-6 transition-all"
        style="background: var(--card); border: 1px solid var(--border); text-decoration: none;"
        onmouseover="this.style.borderColor='#10b981'; this.style.boxShadow='0 4px 24px rgba(16,185,129,0.1)'"
        onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
             style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);">
          <svg class="w-5 h-5" style="color: #10b981;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <h2 class="font-semibold text-base mb-2" style="color: var(--fg);">JSON YAML Converter</h2>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--fg2);">
          Convert JSON to YAML and YAML to JSON instantly. Client side, no data leaves your browser.
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">JSON</span>
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">YAML</span>
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">Config</span>
        </div>
        <div class="absolute top-5 right-5" style="color: var(--border);">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- JWT Decoder card -->
      <a href="/jwt-decoder"
        class="reveal relative rounded-2xl p-6 transition-all"
        style="background: var(--card); border: 1px solid var(--border); text-decoration: none;"
        onmouseover="this.style.borderColor='#10b981'; this.style.boxShadow='0 4px 24px rgba(16,185,129,0.1)'"
        onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
             style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);">
          <svg class="w-5 h-5" style="color: #10b981;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h2 class="font-semibold text-base mb-2" style="color: var(--fg);">JWT Decoder</h2>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--fg2);">Decode and inspect JWT tokens without sending them anywhere. View header, payload, expiry, and algorithm instantly.</p>
        <div class="flex flex-wrap gap-1.5">
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">Auth</span>
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">Token</span>
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">Security</span>
        </div>
        <div class="absolute top-5 right-5" style="color: var(--border);">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- chmod Calculator -->
      <a href="/chmod-calculator"
        class="reveal relative rounded-2xl p-6 transition-all"
        style="background: var(--card); border: 1px solid var(--border); text-decoration: none;"
        onmouseover="this.style.borderColor='#10b981'; this.style.boxShadow='0 4px 24px rgba(16,185,129,0.1)'"
        onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
             style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);">
          <svg class="w-5 h-5" style="color: #10b981;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><line x1="8" y1="15" x2="10" y2="15"/><line x1="12" y1="15" x2="16" y2="15"/>
          </svg>
        </div>
        <h2 class="font-semibold text-base mb-2" style="color: var(--fg);">chmod Calculator</h2>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--fg2);">Calculate Linux file permissions instantly. Convert between octal notation, symbolic notation and chmod commands with a visual permission builder.</p>
        <div class="flex flex-wrap gap-1.5">
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">Linux</span>
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">Permissions</span>
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">DevOps</span>
        </div>
        <div class="absolute top-5 right-5" style="color: var(--border);">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- gitignore Generator -->
      <a href="/gitignore-generator"
        class="reveal relative rounded-2xl p-6 transition-all"
        style="background: var(--card); border: 1px solid var(--border); text-decoration: none;"
        onmouseover="this.style.borderColor='#10b981'; this.style.boxShadow='0 4px 24px rgba(16,185,129,0.1)'"
        onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
             style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);">
          <svg class="w-5 h-5" style="color: #10b981;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
        </div>
        <h2 class="font-semibold text-base mb-2" style="color: var(--fg);">gitignore Generator</h2>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--fg2);">Generate .gitignore files for any tech stack instantly. Search and select your languages and frameworks to get accurate ignore patterns in one click.</p>
        <div class="flex flex-wrap gap-1.5">
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">Git</span>
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">DevOps</span>
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">Productivity</span>
        </div>
        <div class="absolute top-5 right-5" style="color: var(--border);">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Docker Compose Converter -->
      <a href="/docker-compose-converter"
        class="reveal relative rounded-2xl p-6 transition-all"
        style="background: var(--card); border: 1px solid var(--border); text-decoration: none;"
        onmouseover="this.style.borderColor='#10b981'; this.style.boxShadow='0 4px 24px rgba(16,185,129,0.1)'"
        onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
             style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);">
          <svg class="w-5 h-5" style="color: #10b981;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <h2 class="font-semibold text-base mb-2" style="color: var(--fg);">Docker Compose Converter</h2>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--fg2);">Convert docker run commands to docker-compose.yml instantly. Paste any docker run command and get a production-ready Compose file, or convert Compose files back to docker run.</p>
        <div class="flex flex-wrap gap-1.5">
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">Docker</span>
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">DevOps</span>
          <span class="tool-tag text-[10px] font-medium px-2 py-0.5 rounded-full" style="background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">Containers</span>
        </div>
        <div class="absolute top-5 right-5" style="color: var(--border);">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

    </div>
  </section>

  <!-- ── WHY SECTION ────────────────────────────────────────────────────────── -->
  <section style="border-top: 1px solid var(--border); background: var(--ftr-bg);">
    <div class="max-w-4xl mx-auto px-4 py-16 text-center">
      <h2 class="text-2xl font-bold mb-4 tracking-tight reveal" style="color: var(--fg);">Built for the terminal crowd</h2>
      <p class="text-sm leading-relaxed max-w-lg mx-auto mb-10 reveal" style="color: var(--fg2);">
        No ads, no paywalls, no account required. Every tool runs entirely in your browser.
      </p>
      <div class="grid sm:grid-cols-3 gap-6 text-left">
        <div class="reveal rounded-xl p-5" style="background: var(--card); border: 1px solid var(--border);">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-3"
               style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);">

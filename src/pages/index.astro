        <span>Grafana</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/argo.svg" alt="Argo" width="36" height="36" />
        <span>Argo</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/helm.svg" alt="Helm" width="36" height="36" />
        <span>Helm</span>
      </div>
    </div>
    <div class="marquee-set" aria-hidden="true">
      <div class="marquee-item">
        <img src="/logos/docker.svg" alt="Docker" width="36" height="36" />
        <span>Docker</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/kubernetes.svg" alt="Kubernetes" width="36" height="36" />
        <span>Kubernetes</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/pulumi.svg" alt="Pulumi" width="36" height="36" />
        <span>Pulumi</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/terraform.svg" alt="Terraform" width="36" height="36" />
        <span>Terraform</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/git.svg" alt="Git" width="36" height="36" />
        <span>Git</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/github.svg" alt="GitHub" width="36" height="36" />
        <span>GitHub</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/ansible.svg" alt="Ansible" width="36" height="36" />
        <span>Ansible</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/linux.svg" alt="Linux" width="36" height="36" />
        <span>Linux</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/prometheus.svg" alt="Prometheus" width="36" height="36" />
        <span>Prometheus</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/grafana.svg" alt="Grafana" width="36" height="36" />
        <span>Grafana</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/argo.svg" alt="Argo" width="36" height="36" />
        <span>Argo</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/helm.svg" alt="Helm" width="36" height="36" />

---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
import { getCollection } from 'astro:content';
import kubectlCheatsheet from '../data/cheatsheets/kubectl.json';
import dockerCheatsheet from '../data/cheatsheets/docker.json';
import gitCheatsheet from '../data/cheatsheets/git.json';
import awsCheatsheet from '../data/cheatsheets/aws.json';

const allPosts   = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => a.id.localeCompare(b.id))
  .slice(0, 3);

const cheatsheetCards = [kubectlCheatsheet, dockerCheatsheet, gitCheatsheet, awsCheatsheet];

const cheatsheetCardDescriptions: Record<string, string> = {
  kubectl: '78 commands for pods, deployments, debugging, and cluster management.',
  docker: '49 commands for images, containers, volumes, and Docker Compose.',
  git: '49 commands for branching, commits, remotes, and recovery.',
  aws: '119 commands for S3, EC2, IAM, Lambda, and more.',
};

const trustItems = [
  '100% Client-Side',
  'No Login Required',
  'Open Source',
  'Privacy First',
  'Runs in Browser',
];

const toolCards = [
  {
    href: '/cron-builder',
    cat: 'Automation',
    name: 'Cron Builder',
    desc: 'Build and validate cron expressions for Linux, AWS, Kubernetes and GitHub Actions.',
    icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  },
  {
    href: '/cidr-calculator',
    cat: 'Networking',
    name: 'CIDR Calculator',
    desc: 'Subnet masks, usable hosts, and network ranges for IPv4 and IPv6.',
    icon: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  },
  {
    href: '/jwt-decoder',
    cat: 'Security',
    name: 'JWT Decoder',
    desc: 'Decode JWT tokens and inspect the header, payload, and expiry status instantly.',
    icon: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  },
  {
    href: '/json-yaml-converter',
    cat: 'Development',
    name: 'JSON to YAML Converter',
    desc: 'Convert between JSON and YAML in real time. Bidirectional with error highlighting.',
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  },
  {
    href: '/chmod-calculator',
    cat: 'Linux',
    name: 'chmod Calculator',
    desc: 'Calculate Linux file permissions between octal, symbolic, and visual formats.',
    icon: '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>',
  },
  {
    href: '/gitignore-generator',
    cat: 'Development',
    name: 'gitignore Generator',
    desc: 'Generate .gitignore files for any technology stack. Download with one click.',
    icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/>',
  },
  {
    href: '/docker-compose-converter',
    cat: 'Containers',
    name: 'Docker Run to Compose',
    desc: 'Convert docker run commands into docker-compose.yml — and back.',
    icon: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>',
  },
  {
    href: '/timestamp-converter',
    cat: 'Time',
    name: 'Timestamp Converter',
    desc: 'Convert Unix epoch timestamps to human dates and back, with batch mode.',
    icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  },
  {
    href: '/json-diff',
    cat: 'Development',
    name: 'JSON Diff & Schema Validator',
    desc: 'Compare JSON files semantically and validate against schemas.',
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  },
  {
    href: '/k8s-secret-decoder',
    cat: 'Kubernetes',
    name: 'Kubernetes Secret Decoder',
    desc: 'Decode Kubernetes Secret YAML and convert .env files to K8s Secrets',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  },
  {
    href: '/log-sanitiser',
    cat: 'Security',
    name: 'Log Sanitiser & PII Redactor',
    desc: 'Redact PII and sensitive data from logs before sharing with AI tools',
    icon: '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>',
  },
  {
    href: '/base64',
    cat: 'Encoding',
    name: 'Base64 Encoder/Decoder',
    desc: 'Encode and decode Base64 strings and files instantly in your browser',
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  },
];
---

<Layout
  title="OpsBash | Free DevOps Tools"
  description="Free browser-based DevOps tools for engineers. Cron builder, CIDR calculator, JWT decoder, Kubernetes Secret decoder, log sanitiser, and more. No sign-up, no paywalls, runs entirely in your browser."
  canonicalURL="https://opsbash.com/"
>

<main>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- HERO                                                                       -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<section class="hero-section" style="padding: 48px 0 52px; position: relative; overflow: hidden;">

  <!-- Grid pulse background -->
  <canvas id="grid-canvas" aria-hidden="true"></canvas>

  <!-- Headline + subheadline -->
  <div class="max-w-[900px] mx-auto px-5 text-center" style="position:relative;z-index:1;">
    <h1 class="hero-headline" style="font-weight:700;letter-spacing:-0.025em;margin-bottom:18px;background:linear-gradient(135deg,#F8FAFC 0%,#E2E8F0 30%,#CBD5E1 60%,#94A3B8 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
      DevOps Tools Built for Engineers
    </h1>
    <p style="font-size:18px;color:var(--text-secondary);max-width:600px;margin:0 auto 24px;line-height:1.7;">
      Fast, privacy-first utilities that run entirely in your browser.
      No login. No tracking. No server processing.
    </p>
  </div>

  <!-- Terminal -->
  <div style="max-width:700px;margin:0 auto;padding:0 20px;position:relative;z-index:1;">
    <Terminal />
  </div>

  <!-- CTA + search bar -->
  <div style="text-align:center;margin-top:20px;padding:0 20px;position:relative;z-index:1;">
    <a href="#tools" class="browse-btn">
      Browse Tools
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </a>

    <div style="margin-top:16px;display:flex;justify-content:center;">
      <button
        id="hero-search-trigger"
        type="button"
        style="display:flex;align-items:center;gap:10px;width:100%;max-width:500px;height:48px;background:var(--surface-primary);border:1px solid var(--border);border-radius:8px;padding:0 16px;cursor:text;text-align:left;transition:border-color 0.15s;font-family:'Inter',sans-serif;"
        onmouseover="this.style.borderColor='#64748B'"
        onmouseout="this.style.borderColor='var(--border)'"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             style="color:var(--text-secondary);flex-shrink:0;" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <span style="flex:1;font-size:14px;color:var(--text-secondary);">Search tools... Press / to open</span>
        <kbd style="font-family:'JetBrains Mono',monospace;font-size:11px;background:var(--surface-hover);border:1px solid var(--border);border-radius:4px;padding:1px 6px;color:var(--text-secondary);flex-shrink:0;">/</kbd>
      </button>
    </div>
  </div>

</section>


<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- MARQUEE — image files from public/logos/, two identical sets              -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<div class="marquee-outer">
  <div class="marquee-inner">
    <div class="marquee-set">
      <div class="marquee-item">
        <img src="/logos/docker.svg" alt="Docker" width="36" height="36" />
        <span>Docker</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/kubernetes.svg" alt="Kubernetes" width="36" height="36" />
        <span>Kubernetes</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/pulumi.svg" alt="Pulumi" width="36" height="36" />
        <span>Pulumi</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/terraform.svg" alt="Terraform" width="36" height="36" />
        <span>Terraform</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/git.svg" alt="Git" width="36" height="36" />
        <span>Git</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/github.svg" alt="GitHub" width="36" height="36" />
        <span>GitHub</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/ansible.svg" alt="Ansible" width="36" height="36" />
        <span>Ansible</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/linux.svg" alt="Linux" width="36" height="36" />
        <span>Linux</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/prometheus.svg" alt="Prometheus" width="36" height="36" />
        <span>Prometheus</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/grafana.svg" alt="Grafana" width="36" height="36" />
        <span>Grafana</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/argo.svg" alt="Argo" width="36" height="36" />
        <span>Argo</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/helm.svg" alt="Helm" width="36" height="36" />
        <span>Helm</span>
      </div>
    </div>
    <div class="marquee-set" aria-hidden="true">
      <div class="marquee-item">
        <img src="/logos/docker.svg" alt="Docker" width="36" height="36" />
        <span>Docker</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/kubernetes.svg" alt="Kubernetes" width="36" height="36" />
        <span>Kubernetes</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/pulumi.svg" alt="Pulumi" width="36" height="36" />
        <span>Pulumi</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/terraform.svg" alt="Terraform" width="36" height="36" />
        <span>Terraform</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/git.svg" alt="Git" width="36" height="36" />
        <span>Git</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/github.svg" alt="GitHub" width="36" height="36" />
        <span>GitHub</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/ansible.svg" alt="Ansible" width="36" height="36" />
        <span>Ansible</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/linux.svg" alt="Linux" width="36" height="36" />
        <span>Linux</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/prometheus.svg" alt="Prometheus" width="36" height="36" />
        <span>Prometheus</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/grafana.svg" alt="Grafana" width="36" height="36" />
        <span>Grafana</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/argo.svg" alt="Argo" width="36" height="36" />
        <span>Argo</span>
      </div>
      <div class="marquee-item">
        <img src="/logos/helm.svg" alt="Helm" width="36" height="36" />
        <span>Helm</span>
      </div>
    </div>
  </div>
</div>


<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- TRUST STRIP                                                                -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<div style="background:var(--surface-primary);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
  <div class="trust-strip max-w-[1280px] mx-auto px-5" style="padding-top:14px;padding-bottom:14px;display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:6px 0;">
    {trustItems.map((item, i) => (
      <>
        <div class="trust-item" style="display:inline-flex;align-items:center;gap:5px;padding:0 14px;">
          <span style="color:var(--accent-secondary);font-size:13px;font-weight:600;">✓</span>
          <span style="font-size:13px;color:var(--text-secondary);">{item}</span>
        </div>
        {i < trustItems.length - 1 && (
          <span class="trust-sep" style="color:var(--border);font-size:13px;" aria-hidden="true">·</span>
        )}
      </>
    ))}
  </div>
</div>


<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- FROM THE BLOG                                                              -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<section class="max-w-[1280px] mx-auto px-5" style="padding-top:56px;padding-bottom:20px;">

  <div class="text-center reveal" style="margin-bottom:40px;">
    <h2 style="font-size:32px;font-weight:700;color:var(--text-primary);font-family:'Inter',sans-serif;margin-bottom:10px;">
      From the Blogs
    </h2>
    <p style="font-size:15px;color:var(--text-secondary);">Articles and guides for DevOps engineers</p>
  </div>

  <div class="home-blog-grid">
    {recentPosts.map((post, i) => (
      <a
        href={`/blog/${post.data.slug}`}
        class={'reveal home-blog-card' + (i === 1 ? ' reveal-delay-1' : i === 2 ? ' reveal-delay-2' : '')}
        style="text-decoration:none;"
      >
        <div class="home-card-img-wrap">
          <img
            src={post.data.image}
            alt={post.data.title}
            class="home-card-img"
            loading="lazy"
          />
        </div>
        <div style="padding:16px;">
          <div style="display:flex;align-items:center;flex-wrap:wrap;gap:6px;margin-bottom:8px;">
            <span class="home-cat-pill">{post.data.category}</span>
            <span style="color:#94A3B8;font-size:11px;user-select:none;">·</span>
            <time style="font-size:11px;color:var(--text-secondary);font-family:'Inter',sans-serif;">{post.data.date}</time>
            <span style="color:#94A3B8;font-size:11px;user-select:none;">·</span>
            <span style="font-size:11px;color:#94A3B8;font-family:'Inter',sans-serif;">By Rishabh Mishra</span>
          </div>
          <p class="home-card-title">{post.data.title}</p>
        </div>
      </a>
    ))}
  </div>

  <div style="text-align:center;margin-top:36px;">
    <a href="/blog" class="browse-btn">
      View all posts →
    </a>
  </div>

</section>


<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- CHEAT SHEETS                                                               -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<section class="max-w-[1280px] mx-auto px-5" style="padding-top:20px;padding-bottom:20px;">

  <div class="text-center reveal" style="margin-bottom:40px;">
    <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-secondary);margin-bottom:10px;">Cheat Sheets</p>
    <h2 style="font-size:32px;font-weight:700;color:var(--text-primary);font-family:'Inter',sans-serif;margin-bottom:10px;">
      Quick Reference for the Tools You Use Every Day
    </h2>
    <p style="font-size:15px;color:var(--text-secondary);">Searchable, copy-ready command references. Everything runs in your browser.</p>
  </div>

  <div class="cheatsheet-grid">
    {cheatsheetCards.map((sheet, i) => (
      <a
        href={`/cheatsheets/${sheet.slug}`}
        class={'reveal cheatsheet-card' + (i === 1 ? ' reveal-delay-1' : i === 2 ? ' reveal-delay-2' : i === 3 ? ' reveal-delay-3' : '')}
      >
        <p class="cheatsheet-card-title">{sheet.title}</p>
        <p class="cheatsheet-card-desc">{cheatsheetCardDescriptions[sheet.slug] ?? sheet.description}</p>
        <p class="cheatsheet-card-count">{sheet.commands.length}+ commands</p>
      </a>
    ))}
  </div>

  <div style="text-align:center;margin-top:36px;">
    <a href="/cheatsheets" class="browse-btn">
      Browse all cheat sheets →
    </a>
  </div>

</section>


<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- TOOL GRID — tools-grid class enforces 3-col via global.css                -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<section id="tools" class="max-w-[1280px] mx-auto px-5" style="padding-top:48px;padding-bottom:80px;">

  <div class="text-center reveal" style="margin-bottom:48px;">
    <h2 style="font-size:32px;font-weight:700;color:var(--text-primary);font-family:'Inter',sans-serif;margin-bottom:10px;">
      Tools
    </h2>
    <p style="font-size:15px;color:var(--text-secondary);">Everything runs in your browser</p>
  </div>

  <div class="tools-grid">
    {toolCards.map((card, i) => (
      <a
        href={card.href}
        class={'reveal tool-card' + (i % 3 === 1 ? ' reveal-delay-1' : i % 3 === 2 ? ' reveal-delay-2' : '')}
      >
        <div class="tool-card-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2">
            <g set:html={card.icon}></g>
          </svg>
        </div>
        <div class="tool-card-content">
          <div class="tool-card-name">{card.name}</div>
          <div class="tool-card-desc">{card.desc}</div>
          <div class="tool-card-tag">{card.cat}</div>
        </div>
      </a>
    ))}
  </div>
</section>

</main>

<style>
  /* ── Browse Tools button ─────────────────────────────────────────────────── */
  .browse-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: #F8FAFC;
    border: 1px solid #F8FAFC;
    padding: 14px 32px;
    border-radius: 9999px;
    font-family: Inter, sans-serif;
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 200ms ease;
    white-space: nowrap;
  }
  .browse-btn:hover {
    background: rgba(248, 250, 252, 0.08);
    border-color: #F8FAFC;
    color: #F8FAFC;
    box-shadow: 0 0 20px rgba(248, 250, 252, 0.1);
  }

  /* ── Home blog cards ────────────────────────────────────────────────────── */
  .home-blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .home-blog-card {
    background: #111111;
    border: 1px solid #222222;
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .home-blog-card:hover { border-color: #F8FAFC; background: #1A1A1A; }
  .home-card-img-wrap { overflow: hidden; }
  .home-card-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .home-blog-card:hover .home-card-img { transform: scale(1.04); }
  .home-cat-pill {
    display: inline-block;
    padding: 2px 7px;
    border: 1px solid #F8FAFC;
    border-radius: 4px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #F8FAFC;
    font-family: 'JetBrains Mono', monospace;
    white-space: nowrap;
  }
  .home-card-title {
    font-size: 14px;
    font-weight: 600;
    color: #F8FAFC;
    line-height: 1.4;
    font-family: 'Inter', sans-serif;
  }
  @media (max-width: 1024px) {
    .home-blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .home-blog-grid { grid-template-columns: 1fr; }
  }

  /* ── Cheat sheet preview cards ──────────────────────────────────────────── */
  .cheatsheet-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  @media (max-width: 900px) {
    .cheatsheet-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .cheatsheet-grid { grid-template-columns: 1fr; }
  }
  .cheatsheet-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: #111111;
    border: 1px solid #222222;
    border-radius: 8px;
    padding: 16px;
    text-decoration: none;
    transition: all 200ms ease;
  }
  .cheatsheet-card:hover {
    background: #1A1A1A;
    border-color: #F8FAFC;
  }
  .cheatsheet-card-title {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #F8FAFC;
  }
  .cheatsheet-card-desc {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #94A3B8;
    line-height: 1.55;
    flex: 1;
  }
  .cheatsheet-card-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #71717a;
    margin-top: 4px;
  }

  /* ── Tool cards ──────────────────────────────────────────────────────────── */
  .tool-card {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 16px;
    background: #111111;
    border: 1px solid #222222;
    border-radius: 8px;
    padding: 16px;
    cursor: pointer;
    text-decoration: none;
    transition: all 200ms ease;
  }
  .tool-card:hover {
    background: #1A1A1A;
    border-color: #F8FAFC;
  }
  .tool-card-icon {

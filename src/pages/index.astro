<script is:inline>
(function() {
  var MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  var DAYS   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

  function explainCron(expr) {
    var e = expr.trim();
    var p = e.split(/\s+/);
    if (p.length < 5 || p.length > 6) return 'Type a cron expression (e.g. "*/5 * * * *")';

    if (e === '* * * * *') return 'Runs every minute';
    if (e === '@yearly' || e === '0 0 1 1 *') return 'Runs once a year at midnight, Jan 1st';
    if (e === '@monthly' || e === '0 0 1 * *') return 'Runs once a month at midnight';
    if (e === '@weekly' || e === '0 0 * * 0') return 'Runs once a week on Sunday at midnight';
    if (e === '@daily' || e === '0 0 * * *')  return 'Runs once a day at midnight';
    if (e === '@hourly' || e === '0 * * * *')  return 'Runs once an hour at :00';

    var min = p[0], hour = p[1], day = p[2], month = p[3], wday = p[4];

    // Every N minutes
    var mStep = min.match(/^\*\/(\d+)$/);
    if (mStep && hour === '*' && day === '*' && month === '*' && wday === '*') {
      return 'Runs every ' + mStep[1] + ' minutes';
    }

    // At minute :00, every N hours
    var hStep = hour.match(/^\*\/(\d+)$/);
    if (min === '0' && hStep && day === '*' && month === '*' && wday === '*') {
      return 'Runs every ' + hStep[1] + ' hours';
    }

    // Daily at specific hour
    var hNum = hour.match(/^(\d+)$/);
    if (min === '0' && hNum && day === '*' && month === '*' && wday === '*') {
      var h = parseInt(hNum[1]);
      var ampm = h === 0 ? '12:00 AM (midnight)' : h < 12 ? h + ':00 AM' : h === 12 ? '12:00 PM' : (h - 12) + ':00 PM';
      return 'Runs daily at ' + ampm;
    }

    // Weekdays (Mon-Fri)
    if (min === '0' && hNum && day === '*' && month === '*' && (wday === '1-5' || wday === 'MON-FRI')) {
      var h = parseInt(hNum[1]);
      var ampm = h === 0 ? 'midnight' : h < 12 ? h + ' AM' : h === 12 ? '12 PM' : (h - 12) + ' PM';
      return 'Runs on weekdays (Mon–Fri) at ' + ampm;
    }

    // Every Sunday
    if (min === '0' && hour === '0' && day === '*' && month === '*' && wday === '0') {
      return 'Runs every Sunday at midnight';
    }

    // 1st of month
    if (min === '0' && hour === '0' && day === '1' && month === '*' && wday === '*') {
      return 'Runs on the 1st of every month at midnight';
    }

    return 'Custom schedule: ' + e;
  }

  var heroCronInput = document.getElementById('heroCronInput');
  var heroCronExpl  = document.getElementById('heroCronExpl');
  var heroCronNext  = document.getElementById('heroCronNext');

  if (heroCronInput) {
    heroCronInput.addEventListener('input', function() {
      if (heroCronExpl) heroCronExpl.textContent = explainCron(this.value);
    });
    // Focus ring style
    heroCronInput.addEventListener('focus', function() {
      this.style.boxShadow = '0 0 0 3px rgba(16,185,129,0.2), 0 0 20px rgba(16,185,129,0.1)';
    });
    heroCronInput.addEventListener('blur', function() {
      this.style.boxShadow = '0 0 0 3px rgba(16,185,129,0.12)';
    });
  }

  function updateCountdown() {
    if (!heroCronNext) return;
    var now  = new Date();
    var secs = 60 - now.getSeconds();
    heroCronNext.textContent = 'Next run in ' + secs + ' second' + (secs === 1 ? '' : 's');
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);
})();
</script>


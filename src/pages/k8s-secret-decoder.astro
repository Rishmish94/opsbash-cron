<script>
import jsyaml from 'js-yaml';

// ─── HELPERS ─────────────────────────────────────────────────────────────────

function escapeHtml(str: string): string {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function isLikelyValidBase64(str: string): boolean {
  if (typeof str !== 'string') return false;
  const trimmed = str.trim();
  if (trimmed === '' || trimmed.length % 4 !== 0) return false;
  return /^[A-Za-z0-9+/]+={0,2}$/.test(trimmed);
}

function b64DecodeUtf8(str: string): string {
  const binary = atob(str.trim());
  const bytes = Uint8Array.from(binary, (c) => c.charCodeAt(0));
  return new TextDecoder('utf-8', { fatal: true }).decode(bytes);
}

function b64EncodeUtf8(str: string): string {
  return btoa(unescape(encodeURIComponent(str)));
}

function copyText(text: string, btn: HTMLElement) {
  function flash() {
    const original = btn.innerHTML;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.innerHTML = original; }, 1500);
  }
  function fallback() {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0';
    document.body.appendChild(ta);
    ta.select();
    try { document.execCommand('copy'); } catch (e) {}
    document.body.removeChild(ta);
  }
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(flash).catch(() => { fallback(); flash(); });
  } else {
    fallback(); flash();
  }
}

// ─── DECODE TAB ──────────────────────────────────────────────────────────────

interface DecodedPair { key: string; value: string; valid: boolean; }

const decodeInput = document.getElementById('decodeInput') as HTMLTextAreaElement;
const decodeBtn = document.getElementById('decodeBtn') as HTMLButtonElement;
const decodeError = document.getElementById('decodeError') as HTMLDivElement;
const decodeResultsCard = document.getElementById('decodeResultsCard') as HTMLDivElement;
const decodeResultsBody = document.getElementById('decodeResultsBody') as HTMLDivElement;
const copyAllEnvBtn = document.getElementById('copyAllEnvBtn') as HTMLButtonElement;

let lastDecodedPairs: DecodedPair[] = [];

function showDecodeError(msg: string) {
  decodeError.textContent = msg;
  decodeError.classList.remove('hidden');
  decodeResultsCard.classList.add('hidden');
}

function clearDecodeError() {
  decodeError.classList.add('hidden');
  decodeError.textContent = '';
}

function runDecode() {
  const raw = decodeInput.value;

  if (!raw.trim()) {
    clearDecodeError();
    decodeResultsCard.classList.add('hidden');
    return;
  }

  let parsed: any;
  try {
    parsed = jsyaml.load(raw);
  } catch (e: any) {
    showDecodeError('Invalid YAML: ' + (e?.message || 'could not parse the input.'));
    return;
  }

  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed) || !parsed.data || typeof parsed.data !== 'object' || Array.isArray(parsed.data)) {
    showDecodeError('No data section found in Secret.');
    return;
  }

  clearDecodeError();

  const keys = Object.keys(parsed.data);
  lastDecodedPairs = keys.map((k) => {
    const raw64 = String(parsed.data[k]);
    if (isLikelyValidBase64(raw64)) {
      try {
        return { key: k, value: b64DecodeUtf8(raw64), valid: true };
      } catch {
        return { key: k, value: raw64, valid: false };
      }
    }
    return { key: k, value: raw64, valid: false };
  });

  decodeResultsBody.innerHTML = lastDecodedPairs.map((p, i) => `
    <div class="decode-row" data-i="${i}" style="display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 20px;border-bottom:1px solid var(--border);flex-wrap:wrap;">
      <code class="decode-key" style="font-family:'JetBrains Mono','Fira Code',monospace;font-size:13px;font-weight:600;color:#4ADE80;flex-shrink:0;">${escapeHtml(p.key)}</code>
      <div class="decode-value-wrap" style="display:flex;align-items:center;gap:10px;flex:1;min-width:0;justify-content:flex-end;">
        ${p.valid ? '' : '<span class="badge-warn" style="font-size:10px;font-weight:600;padding:2px 8px;border-radius:20px;background:rgba(245,158,11,0.12);color:#F59E0B;border:1px solid rgba(245,158,11,0.35);white-space:nowrap;flex-shrink:0;">Invalid base64</span>'}
        <code class="decode-value" style="font-family:'JetBrains Mono','Fira Code',monospace;font-size:13px;color:#F8FAFC;word-break:break-all;text-align:right;flex:1;min-width:0;">${escapeHtml(p.value)}</code>
        <button class="copy-row-btn" data-i="${i}" style="font-size:11px;font-weight:500;padding:4px 10px;border-radius:6px;background:rgba(248,250,252,0.06);color:var(--fg2);border:none;cursor:pointer;flex-shrink:0;white-space:nowrap;">Copy</button>
      </div>
    </div>
  `).join('');
  decodeResultsBody.querySelectorAll('.decode-row').forEach((row, i, arr) => {
    if (i === arr.length - 1) (row as HTMLElement).style.borderBottom = 'none';
  });

  decodeResultsCard.classList.remove('hidden');
}

decodeBtn.addEventListener('click', runDecode);

decodeResultsBody.addEventListener('click', (e) => {
  const target = e.target as HTMLElement;
  const btn = target.closest('.copy-row-btn') as HTMLButtonElement | null;
  if (!btn) return;
  const i = parseInt(btn.getAttribute('data-i') || '-1', 10);
  const pair = lastDecodedPairs[i];
  if (pair) copyText(pair.value, btn);
});

copyAllEnvBtn.addEventListener('click', () => {
  const text = lastDecodedPairs.map((p) => `${p.key}=${p.value}`).join('\n');
  copyText(text, copyAllEnvBtn);
});

// ─── ENCODE TAB ──────────────────────────────────────────────────────────────

const envInput = document.getElementById('envInput') as HTMLTextAreaElement;
const secretNameInput = document.getElementById('secretNameInput') as HTMLInputElement;
const namespaceInput = document.getElementById('namespaceInput') as HTMLInputElement;
const encodeBtn = document.getElementById('encodeBtn') as HTMLButtonElement;
const encodeWarning = document.getElementById('encodeWarning') as HTMLDivElement;
const encodeOutputCard = document.getElementById('encodeOutputCard') as HTMLDivElement;
const encodeOutput = document.getElementById('encodeOutput') as HTMLPreElement;
const copyYamlBtn = document.getElementById('copyYamlBtn') as HTMLButtonElement;
const copyKubectlBtn = document.getElementById('copyKubectlBtn') as HTMLButtonElement;

function parseEnv(text: string): { pairs: [string, string][]; badLines: number[] } {
  const lines = text.split(/\r?\n/);
  const pairs: [string, string][] = [];
  const badLines: number[] = [];

  lines.forEach((line, idx) => {
    const trimmed = line.trim();
    if (trimmed === '' || trimmed.startsWith('#')) return;

    const eqIdx = trimmed.indexOf('=');
    if (eqIdx <= 0) {
      badLines.push(idx + 1);
      return;
    }

    const key = trimmed.slice(0, eqIdx).trim();
    let value = trimmed.slice(eqIdx + 1).trim();

    if (!/^[A-Za-z_][A-Za-z0-9_]*$/.test(key)) {
      badLines.push(idx + 1);
      return;
    }

    if ((value.startsWith('"') && value.endsWith('"') && value.length >= 2) ||
        (value.startsWith("'") && value.endsWith("'") && value.length >= 2)) {
      value = value.slice(1, -1);
    }

    pairs.push([key, value]);
  });

  return { pairs, badLines };
}

function buildSecretYaml(pairs: [string, string][], name: string, namespace: string): string {
  const dataLines = pairs.map(([k, v]) => `  ${k}: ${b64EncodeUtf8(v)}`).join('\n');
  return `apiVersion: v1\nkind: Secret\nmetadata:\n  name: ${name}\n  namespace: ${namespace}\ntype: Opaque\ndata:\n${dataLines}\n`;
}

function runEncode() {
  const raw = envInput.value;

  if (!raw.trim()) {
    encodeWarning.classList.add('hidden');
    encodeOutputCard.classList.add('hidden');
    return;
  }

  const name = secretNameInput.value.trim() || 'my-secret';
  const namespace = namespaceInput.value.trim() || 'default';
  const { pairs, badLines } = parseEnv(raw);

  if (badLines.length) {
    encodeWarning.textContent = `Skipped line${badLines.length > 1 ? 's' : ''} ${badLines.join(', ')} — not in KEY=VALUE format.`;
    encodeWarning.classList.remove('hidden');
  } else {
    encodeWarning.classList.add('hidden');
  }

  if (!pairs.length) {
    encodeOutputCard.classList.add('hidden');
    return;
  }

  encodeOutput.textContent = buildSecretYaml(pairs, name, namespace);
  encodeOutputCard.classList.remove('hidden');
}

encodeBtn.addEventListener('click', runEncode);

copyYamlBtn.addEventListener('click', () => {
  copyText(encodeOutput.textContent || '', copyYamlBtn);
});

copyKubectlBtn.addEventListener('click', () => {
  const yamlText = encodeOutput.textContent || '';
  const cmd = `kubectl apply -f - <<EOF\n${yamlText}EOF`;
  copyText(cmd, copyKubectlBtn);
});

// ─── FAQ ACCORDION ───────────────────────────────────────────────────────────

document.querySelectorAll('.faq-trigger').forEach((btn) => {
  btn.addEventListener('click', () => {
    const item = btn.closest('.faq-item') as HTMLElement;
    const content = item.querySelector('.faq-content') as HTMLElement;
    const chevron = btn.querySelector('.faq-chevron') as HTMLElement;
    const isOpen = !content.classList.contains('hidden');
    content.classList.toggle('hidden', isOpen);
    chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
  });
});

// ─── PAGE-LEVEL TAB SWITCHING ────────────────────────────────────────────────

const pageTabDecode = document.getElementById('page-tab-decode') as HTMLButtonElement;
const pageTabEncode = document.getElementById('page-tab-encode') as HTMLButtonElement;
const tabDecode = document.getElementById('tab-decode') as HTMLDivElement;
const tabEncode = document.getElementById('tab-encode') as HTMLDivElement;

function switchPageTab(tab: 'decode' | 'encode') {
  if (tab === 'decode') {
    pageTabDecode.classList.add('page-tab-active');
    pageTabEncode.classList.remove('page-tab-active');
    tabDecode.classList.remove('hidden');
    tabEncode.classList.add('hidden');
  } else {
    pageTabEncode.classList.add('page-tab-active');
    pageTabDecode.classList.remove('page-tab-active');
    tabEncode.classList.remove('hidden');
    tabDecode.classList.add('hidden');
  }
}

pageTabDecode.addEventListener('click', () => switchPageTab('decode'));
pageTabEncode.addEventListener('click', () => switchPageTab('encode'));
</script>


---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is base64 encoding the same as encryption?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Base64 is a reversible encoding scheme, not encryption. Anyone with the encoded string can decode it back to plaintext instantly with no key or password required, using a single command like `echo '...' | base64 -d` or this tool. Kubernetes Secrets store values as base64 purely so the YAML/JSON manifest can safely hold binary or multi-line data as plain text — it is not intended as a security boundary. Real protection comes from encryption at rest (etcd encryption), RBAC restricting who can read Secret objects, and tools like Sealed Secrets or the External Secrets Operator."
      }
    },
    {
      "@type": "Question",
      "name": "How do I create a Kubernetes Secret from a .env file using kubectl?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Run kubectl create secret generic my-secret --from-env-file=.env. This reads every KEY=VALUE line in the .env file (skipping blank lines and comments) and creates a Secret named my-secret with each key base64 encoded automatically — you never have to encode values by hand. Add --namespace=your-namespace to target a specific namespace. Use the Encode tab on this page to preview the exact YAML that command would generate before you apply it."
      }
    },
    {
      "@type": "Question",
      "name": "How do I decode all values in a Kubernetes Secret at once?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Run kubectl get secret my-secret -o json | jq -r '.data | map_values(@base64d)' to decode every key in one shot with jq. Without jq, kubectl get secret my-secret -o jsonpath='{.data}' prints the raw base64 map, which you then pipe per-key through base64 --decode. Paste the same YAML into the Decode tab on this page to see every key and value listed side by side without running any command."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between Opaque and kubernetes.io/dockerconfigjson secret types?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Opaque is the generic, freeform Secret type used for arbitrary key-value data such as database credentials, API keys, and tokens — Kubernetes places no structure requirements on the data. kubernetes.io/dockerconfigjson is a specialized type built for container registry authentication: it must contain a single key named .dockerconfigjson holding a base64 encoded Docker config JSON blob, and Kubernetes uses it specifically for imagePullSecrets when pulling private container images. Other built-in types include kubernetes.io/tls for certificate/key pairs and kubernetes.io/basic-auth for username/password pairs."
      }
    },
    {
      "@type": "Question",
      "name": "How do I rotate a Kubernetes Secret without downtime?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Update the Secret's data in place with kubectl apply or kubectl create secret ... --dry-run=client -o yaml | kubectl apply -f -, then trigger a rolling restart of the workloads that mount it with kubectl rollout restart deployment/your-app. Because a rolling restart replaces pods gradually while old pods keep serving traffic, there is no downtime as long as your readiness probes are configured correctly. If a Secret is mounted as a volume rather than an environment variable, the kubelet updates the mounted file automatically within about a minute, though your application still needs to reload the file or restart to pick up the new value — environment variables never update without a pod restart."
      }
    }
  ]
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to decode a Kubernetes Secret and encode a .env file into one",
  "description": "Step by step guide to decoding Kubernetes Secret YAML and converting .env files into Secret manifests",
  "step": [
    {
      "@type": "HowToStep",
      "name": "Paste your Secret YAML",
      "text": "Paste the output of kubectl get secret my-secret -o yaml into the Decode Secret tab"
    },
    {
      "@type": "HowToStep",
      "name": "Click Decode",
      "text": "Every key in the data section is decoded from base64 to plaintext instantly in your browser"
    },
    {
      "@type": "HowToStep",
      "name": "Copy values or export as .env",
      "text": "Copy an individual decoded value or click Copy all as .env to get every key=value pair at once"
    },
    {
      "@type": "HowToStep",
      "name": "Or paste a .env file to encode",
      "text": "Switch to the Encode tab, paste .env contents, set a Secret name and namespace"
    },
    {
      "@type": "HowToStep",
      "name": "Copy the generated Secret YAML",
      "text": "Click Encode to get a ready-to-apply Kubernetes Secret manifest, or copy a full kubectl apply command"
    }
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Kubernetes Secret Decoder",
  "url": "https://opsbash.com/k8s-secret-decoder",
  "description": "Decode Kubernetes Secret YAML to plaintext and convert .env files into ready-to-apply Kubernetes Secret manifests. Runs entirely client-side.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<Layout
  title="Kubernetes Secret Decoder & .env to Secret Converter | OpsBash"
  description="Decode Kubernetes Secret YAML to plaintext instantly, or convert a .env file into a ready-to-apply Kubernetes Secret manifest. Free, client-side, no data ever leaves your browser."
  canonicalURL="https://opsbash.com/k8s-secret-decoder"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

<!-- ── PAGE CONTENT ───────────────────────────────────────────────────────────── -->
<div style="background: var(--bg);">

<!-- PAGE-LEVEL TAB NAV -->
<div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
  <div class="flex gap-0 pt-6 pb-0" style="border-bottom: 1px solid var(--border);">
    <button id="page-tab-decode" class="page-tab page-tab-active" data-page-tab="decode">
      Decode Secret
    </button>
    <button id="page-tab-encode" class="page-tab" data-page-tab="encode">
      Encode .env to Secret
    </button>
  </div>
</div>

<!-- ── DECODE TAB ─────────────────────────────────────────────────────────────── -->
<div id="tab-decode">
<div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">

  <!-- HERO -->
  <section class="pt-8 pb-5">
    <div class="inline-flex items-center gap-2 text-xs font-medium px-3 py-1.5 rounded-full mb-4"
         style="background: transparent; color: #F8FAFC; border: 1px solid #334155;">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      Free Kubernetes Secret Decoder
    </div>
    <h1 class="text-3xl sm:text-4xl font-bold mb-3 tracking-tight" style="color: #F8FAFC;">
      Kubernetes Secret Decoder
    </h1>
    <p class="text-base max-w-xl" style="color: var(--fg2);">
      Paste a Kubernetes Secret manifest and instantly decode every base64 value to plaintext. Runs entirely in your browser — nothing is uploaded anywhere.
    </p>
  </section>

  <!-- INPUT CARD -->
  <div class="rounded-[14px] mb-6 overflow-hidden" style="background: var(--card); border: 1px solid var(--border);">
